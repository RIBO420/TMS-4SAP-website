---
export interface Props {
  title: string;
  description: string;
  date: string;
  author: string;
  category: string;
  slug: string;
}

const { title, description, date, author, category, slug } = Astro.props;

const href = `/blog/${slug}`;

const formattedDate = new Date(date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<article class="blog-card" data-animate>
  <div class="blog-card-content">
    <div class="blog-card-meta">
      <span class="blog-card-category">{category}</span>
      <span class="blog-card-dot" aria-hidden="true"></span>
      <time class="blog-card-date" datetime={date}>{formattedDate}</time>
    </div>
    <h3 class="blog-card-title">
      <a href={href}>{title}</a>
    </h3>
    <p class="blog-card-desc">{description}</p>
    <div class="blog-card-footer">
      <span class="blog-card-author">{author}</span>
      <a href={href} class="blog-card-link" aria-label={`Read more about ${title}`}>
        Read more <span aria-hidden="true">&rarr;</span>
      </a>
    </div>
  </div>
</article>

<style>
  .blog-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: all 0.3s var(--ease);
  }

  .blog-card:hover {
    background: var(--bg-card-hover);
    border-color: var(--border-hover);
    transform: translateY(-2px);
  }

  .blog-card-content {
    padding: 28px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .blog-card-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.8125rem;
  }

  .blog-card-category {
    display: inline-block;
    padding: 3px 10px;
    background: var(--amber-dim);
    border: 1px solid rgba(245, 158, 11, 0.15);
    border-radius: 100px;
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--amber);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .blog-card-dot {
    width: 3px;
    height: 3px;
    background: var(--text-dim);
    border-radius: 50%;
  }

  .blog-card-date {
    color: var(--text-dim);
    font-size: 0.8125rem;
  }

  .blog-card-title {
    font-family: var(--font-heading);
    font-size: 1.125rem;
    font-weight: 600;
    line-height: 1.3;
    letter-spacing: -0.01em;
  }

  .blog-card-title a {
    color: var(--text);
    text-decoration: none;
    transition: color 0.2s var(--ease);
  }

  .blog-card-title a:hover {
    color: var(--amber);
  }

  .blog-card-desc {
    font-size: 0.9375rem;
    color: var(--text-muted);
    line-height: 1.6;
    flex-grow: 1;
    /* Clamp to 3 lines */
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .blog-card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 4px;
    padding-top: 16px;
    border-top: 1px solid var(--border);
  }

  .blog-card-author {
    font-size: 0.8125rem;
    color: var(--text-dim);
  }

  .blog-card-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--amber);
    transition: gap 0.2s var(--ease);
  }

  .blog-card-link:hover {
    gap: 10px;
  }

  /* Tablet */
  @media (max-width: 768px) {
    .blog-card-content {
      padding: 22px;
      gap: 10px;
    }

    .blog-card-title {
      font-size: 1.0625rem;
    }

    .blog-card-desc {
      font-size: 0.875rem;
    }
  }

  /* iPhone (375px-430px) */
  @media (max-width: 480px) {
    .blog-card-content {
      padding: 16px;
      gap: 8px;
    }

    .blog-card-meta {
      font-size: 0.75rem;
      gap: 6px;
    }

    .blog-card-category {
      font-size: 0.6875rem;
      padding: 2px 8px;
    }

    .blog-card-date {
      font-size: 0.75rem;
    }

    .blog-card-title {
      font-size: 1rem;
      line-height: 1.35;
      word-break: break-word;
    }

    .blog-card-desc {
      font-size: 0.8125rem;
      line-height: 1.55;
      -webkit-line-clamp: 2;
    }

    .blog-card-footer {
      padding-top: 12px;
      gap: 8px;
    }

    .blog-card-author {
      font-size: 0.75rem;
    }

    .blog-card-link {
      font-size: 0.8125rem;
    }

    .blog-card:hover {
      transform: none;
    }
  }
</style>
