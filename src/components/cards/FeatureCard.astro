---
interface Props {
  icon: string;
  title: string;
  description: string;
}

const { icon, title, description } = Astro.props;
---

<div class="feature-card" data-animate>
  <div class="feature-icon">
    <Fragment set:html={icon} />
  </div>
  <h3>{title}</h3>
  <p>{description}</p>
</div>

<style>
  .feature-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 28px;
    transition: all 0.3s var(--ease);
    display: flex;
    flex-direction: column;
    gap: 12px;
    cursor: pointer;
  }

  .feature-card:hover {
    background: var(--bg-card-hover);
    border-color: rgba(245, 158, 11, 0.25);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(245, 158, 11, 0.06), 0 0 0 1px rgba(245, 158, 11, 0.1);
  }

  .feature-card:hover .feature-icon {
    transform: scale(1.1);
  }

  .feature-icon {
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--amber-dim);
    border-radius: var(--radius-sm);
    color: var(--amber);
    flex-shrink: 0;
    transition: transform 0.2s var(--ease);
  }

  .feature-card h3 {
    font-family: var(--font-heading);
    font-size: 1.125rem;
    font-weight: 600;
    line-height: 1.3;
  }

  .feature-card p {
    font-size: 0.9375rem;
    color: var(--text-muted);
    line-height: 1.6;
  }

  /* Tablet */
  @media (max-width: 768px) {
    .feature-card {
      padding: 22px;
      gap: 10px;
    }

    .feature-card h3 {
      font-size: 1.0625rem;
    }

    .feature-card p {
      font-size: 0.875rem;
    }
  }

  /* iPhone (375px-430px) */
  @media (max-width: 480px) {
    .feature-card {
      padding: 16px;
      gap: 8px;
    }

    .feature-icon {
      width: 38px;
      height: 38px;
    }

    .feature-icon :global(svg) {
      width: 20px;
      height: 20px;
    }

    .feature-card h3 {
      font-size: 1rem;
      word-break: break-word;
    }

    .feature-card p {
      font-size: 0.8125rem;
      line-height: 1.55;
    }

    .feature-card:hover {
      transform: none;
    }
  }
</style>
