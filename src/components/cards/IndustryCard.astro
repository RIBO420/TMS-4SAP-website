---
import type { IndustryData } from "@data/industries";

interface Props {
  industry: IndustryData;
}

const { industry } = Astro.props;
const href = `/industries/${industry.slug}`;

const iconMap: Record<string, string> = {
  car: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 17h2c.6 0 1-.4 1-1v-3c0-.9-.7-1.7-1.5-1.9C18.7 10.6 16 10 16 10s-1.3-1.4-2.2-2.3c-.5-.4-1.1-.7-1.8-.7H5c-.6 0-1.1.4-1.4.9l-1.4 2.9A3.7 3.7 0 0 0 2 12v4c0 .6.4 1 1 1h2"/><circle cx="7" cy="17" r="2"/><path d="M9 17h6"/><circle cx="17" cy="17" r="2"/></svg>`,
  utensils: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 2v7c0 1.1.9 2 2 2h4a2 2 0 0 0 2-2V2"/><path d="M7 2v20"/><path d="M21 15V2v0a5 5 0 0 0-5 5v6c0 1.1.9 2 2 2h3zm0 0v7"/></svg>`,
  hammer: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 12-8.5 8.5c-.83.83-2.17.83-3 0 0 0 0 0 0 0a2.12 2.12 0 0 1 0-3L12 9"/><path d="M17.64 15 22 10.64"/><path d="m20.91 11.7-1.25-1.25c-.6-.6-.93-1.4-.93-2.25v-.86L16.01 4.6a5.56 5.56 0 0 0-3.94-1.64H9l.92.82A6.18 6.18 0 0 1 12 8.4v1.56l2 2h2.47l2.26 1.91"/></svg>`,
  cpu: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="4" width="16" height="16" rx="2"/><rect x="9" y="9" width="6" height="6"/><path d="M15 2v2"/><path d="M15 20v2"/><path d="M2 15h2"/><path d="M2 9h2"/><path d="M20 15h2"/><path d="M20 9h2"/><path d="M9 2v2"/><path d="M9 20v2"/></svg>`,
};

const svgIcon = iconMap["cpu"];
---

<a href={href} class="industry-card" data-animate aria-label={industry.title}>
  <div class="industry-thumb" aria-hidden="true">
    <svg class="industry-thumb-icon" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
      <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
      <circle cx="8.5" cy="8.5" r="1.5"/>
      <polyline points="21 15 16 10 5 21"/>
    </svg>
  </div>
  <div class="industry-icon" aria-hidden="true">
    <Fragment set:html={svgIcon} />
  </div>
  <h3>{industry.title}</h3>
  <p>{industry.description}</p>
  <span class="industry-link" aria-hidden="true">
    Explore
    <svg
      width="14"
      height="14"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <path d="M5 12h14"></path>
      <path d="m12 5 7 7-7 7"></path>
    </svg>
  </span>
</a>

<style>
  .industry-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 28px;
    transition: all 0.3s var(--ease);
    display: flex;
    flex-direction: column;
    gap: 12px;
    text-decoration: none;
    color: inherit;
    cursor: pointer;
  }

  .industry-card:hover {
    background: var(--bg-card-hover);
    border-color: rgba(245, 158, 11, 0.25);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(245, 158, 11, 0.06), 0 0 0 1px rgba(245, 158, 11, 0.1);
  }

  .industry-card:hover .industry-icon {
    transform: scale(1.1);
  }

  .industry-icon {
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--amber-dim);
    border-radius: var(--radius-sm);
    color: var(--amber);
    flex-shrink: 0;
    transition: transform 0.2s var(--ease);
  }

  .industry-card h3 {
    font-family: var(--font-heading);
    font-size: 1.125rem;
    font-weight: 600;
    line-height: 1.3;
  }

  .industry-card p {
    font-size: 0.9375rem;
    color: var(--text-muted);
    line-height: 1.6;
    flex-grow: 1;
  }

  .industry-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--amber);
    margin-top: 4px;
    transition: gap 0.2s var(--ease);
  }

  .industry-card:hover .industry-link {
    gap: 10px;
  }

  .industry-thumb {
    width: 100%;
    height: 140px;
    background: linear-gradient(135deg, rgba(245, 158, 11, 0.06) 0%, rgba(9, 9, 11, 0.4) 50%, rgba(245, 158, 11, 0.04) 100%);
    border-radius: var(--radius-sm);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 4px;
    border: 1px dashed rgba(245, 158, 11, 0.15);
  }

  .industry-thumb-icon {
    color: rgba(245, 158, 11, 0.2);
  }

  /* Tablet */
  @media (max-width: 768px) {
    .industry-card {
      padding: 22px;
      gap: 10px;
    }

    .industry-thumb {
      height: 120px;
    }

    .industry-card h3 {
      font-size: 1.0625rem;
    }

    .industry-card p {
      font-size: 0.875rem;
    }
  }

  /* iPhone (375px-430px) */
  @media (max-width: 480px) {
    .industry-card {
      padding: 16px;
      gap: 8px;
    }

    .industry-thumb {
      height: 100px;
      margin-bottom: 2px;
    }

    .industry-thumb-icon {
      width: 24px;
      height: 24px;
    }

    .industry-icon {
      width: 38px;
      height: 38px;
    }

    .industry-icon :global(svg) {
      width: 20px;
      height: 20px;
    }

    .industry-card h3 {
      font-size: 1rem;
      word-break: break-word;
    }

    .industry-card p {
      font-size: 0.8125rem;
      line-height: 1.55;
    }

    .industry-link {
      font-size: 0.8125rem;
    }

    .industry-card:hover {
      transform: none;
    }
  }
</style>
