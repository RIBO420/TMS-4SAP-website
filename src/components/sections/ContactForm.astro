---
interface Props {
  variant: "full" | "compact";
  title?: string;
  description?: string;
}

const {
  variant,
  title = "Ready to transform your",
  description = "Our team is ready to show you how TMS can empower your SAP Business One environment.",
} = Astro.props;

const isFull = variant === "full";
---

<section id="contact" class="section">
  <div class="container">
    {isFull ? (
      <div class="contact-grid">
        <div class="contact-info" data-animate>
          <span class="section-tag">Get in Touch</span>
          <h2>
            {title} <span class="text-amber">manufacturing?</span>
          </h2>
          <p class="contact-desc">{description}</p>
          <div class="contact-details">
            <div class="contact-item">
              <div class="contact-icon">
                <svg
                  width="20"
                  height="20"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
                  <circle cx="12" cy="10" r="3" />
                </svg>
              </div>
              <div>
                <span class="contact-label">Headquarters</span>
                <span class="contact-value">
                  Il Flore, Avenue Ceramique 221
                  <br />
                  6221 KX, Maastricht, The Netherlands
                </span>
              </div>
            </div>
            <div class="contact-item">
              <div class="contact-icon">
                <svg
                  width="20"
                  height="20"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z" />
                </svg>
              </div>
              <div>
                <span class="contact-label">Direct Line</span>
                <a
                  href="tel:+31432340050"
                  class="contact-value contact-link"
                >
                  +31 43 234 00 50
                </a>
              </div>
            </div>
            <div class="contact-item">
              <div class="contact-icon">
                <svg
                  width="20"
                  height="20"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <rect width="20" height="16" x="2" y="4" rx="2" />
                  <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
                </svg>
              </div>
              <div>
                <span class="contact-label">Email</span>
                <a
                  href="mailto:info@themanufacturingsuite.com"
                  class="contact-value contact-link"
                >
                  info@themanufacturingsuite.com
                </a>
              </div>
            </div>
          </div>
        </div>
        <div class="contact-form-card" data-animate>
          <form class="contact-form" id="contactForm" novalidate data-contact-form>
            {/* Honeypot field - bots fill this, humans don't */}
            <input
              type="text"
              name="website"
              tabindex="-1"
              autocomplete="off"
              aria-hidden="true"
              class="honeypot"
              style="position:absolute;left:-9999px;"
            />
            <div class="form-group">
              <label for="contact-name">
                Full Name <span class="required" aria-hidden="true">*</span>
                <span class="sr-only">required</span>
              </label>
              <input
                type="text"
                id="contact-name"
                name="name"
                placeholder="John Doe"
                required
                aria-required="true"
                autocomplete="name"
              />
            </div>
            <div class="form-group">
              <label for="contact-email">
                Work Email <span class="required" aria-hidden="true">*</span>
                <span class="sr-only">required</span>
              </label>
              <input
                type="email"
                id="contact-email"
                name="email"
                placeholder="john@company.com"
                required
                aria-required="true"
                autocomplete="email"
              />
            </div>
            <div class="form-group">
              <label for="contact-company">Company</label>
              <input
                type="text"
                id="contact-company"
                name="company"
                placeholder="Your Company"
                autocomplete="organization"
              />
            </div>
            <div class="form-group">
              <label for="contact-message">
                Message <span class="required" aria-hidden="true">*</span>
                <span class="sr-only">required</span>
              </label>
              <textarea
                id="contact-message"
                name="message"
                rows="4"
                placeholder="Tell us about your manufacturing needs..."
                required
                aria-required="true"
              ></textarea>
            </div>
            <label class="form-consent">
              <input type="checkbox" name="consent" required aria-required="true" />
              <span>I agree to the <a href="/legal/privacy">Privacy Policy</a> and consent to being contacted about my enquiry.</span>
            </label>
            <div id="contact-status" role="status" aria-live="polite" class="form-status"></div>
            <button type="submit" class="btn btn-primary btn-lg btn-full">
              Send Message
              <svg
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <line x1="22" y1="2" x2="11" y2="13" />
                <polygon points="22 2 15 22 11 13 2 9 22 2" />
              </svg>
            </button>
          </form>
        </div>
      </div>
    ) : (
      <div class="contact-compact" data-animate>
        {title && (
          <div class="section-header">
            <h2>{title}</h2>
            {description && <p class="section-desc">{description}</p>}
          </div>
        )}
        <div class="contact-form-card contact-compact-card">
          <form class="contact-form" id="contactFormCompact" novalidate data-contact-form>
            {/* Honeypot field - bots fill this, humans don't */}
            <input
              type="text"
              name="website"
              tabindex="-1"
              autocomplete="off"
              aria-hidden="true"
              class="honeypot"
              style="position:absolute;left:-9999px;"
            />
            <div class="form-group">
              <label for="compact-name">
                Full Name <span class="required" aria-hidden="true">*</span>
                <span class="sr-only">required</span>
              </label>
              <input
                type="text"
                id="compact-name"
                name="name"
                placeholder="John Doe"
                required
                aria-required="true"
                autocomplete="name"
              />
            </div>
            <div class="form-group">
              <label for="compact-email">
                Work Email <span class="required" aria-hidden="true">*</span>
                <span class="sr-only">required</span>
              </label>
              <input
                type="email"
                id="compact-email"
                name="email"
                placeholder="john@company.com"
                required
                aria-required="true"
                autocomplete="email"
              />
            </div>
            <div class="form-group">
              <label for="compact-company">Company</label>
              <input
                type="text"
                id="compact-company"
                name="company"
                placeholder="Your Company"
                autocomplete="organization"
              />
            </div>
            <div class="form-group">
              <label for="compact-message">
                Message <span class="required" aria-hidden="true">*</span>
                <span class="sr-only">required</span>
              </label>
              <textarea
                id="compact-message"
                name="message"
                rows="4"
                placeholder="Tell us about your manufacturing needs..."
                required
                aria-required="true"
              ></textarea>
            </div>
            <label class="form-consent">
              <input type="checkbox" name="consent" required aria-required="true" />
              <span>I agree to the <a href="/legal/privacy">Privacy Policy</a> and consent to being contacted about my enquiry.</span>
            </label>
            <div id="contact-status-compact" role="status" aria-live="polite" class="form-status"></div>
            <button type="submit" class="btn btn-primary btn-lg btn-full">
              Send Message
              <svg
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <line x1="22" y1="2" x2="11" y2="13" />
                <polygon points="22 2 15 22 11 13 2 9 22 2" />
              </svg>
            </button>
          </form>
        </div>
      </div>
    )}
  </div>
</section>

<script>
  // Replace with your real Formspree (or similar) endpoint:
  // e.g. 'https://formspree.io/f/xxxxxxxx'
  const FORM_ENDPOINT = 'https://formspree.io/f/REPLACE_ME';

  function initContactFormSection() {
    const forms = document.querySelectorAll<HTMLFormElement>('form[data-contact-form]');
    forms.forEach((form) => {
      if ((form as any).__wired) return;
      (form as any).__wired = true;

      const statusEl =
        form.querySelector<HTMLElement>('.form-status') ||
        document.getElementById('contact-status');

      form.addEventListener('submit', async (e: Event) => {
        e.preventDefault();

        // Honeypot check - silent drop
        const hp = (form.elements.namedItem('website') as HTMLInputElement | null);
        if (hp && hp.value) {
          return;
        }

        // Clear previous aria-invalid state
        form.querySelectorAll('[aria-invalid]').forEach((el) => {
          el.removeAttribute('aria-invalid');
        });

        // Validate required
        const requiredFields = form.querySelectorAll<HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement>('[required]');
        let valid = true;
        requiredFields.forEach((field) => {
          const isCheckbox = (field as HTMLInputElement).type === 'checkbox';
          const ok = isCheckbox ? (field as HTMLInputElement).checked : !!field.value.trim();
          if (!ok) {
            field.setAttribute('aria-invalid', 'true');
            valid = false;
          }
        });

        const emailField = form.querySelector<HTMLInputElement>('input[type="email"]');
        if (emailField && emailField.value && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(emailField.value)) {
          emailField.setAttribute('aria-invalid', 'true');
          valid = false;
        }

        if (!valid) {
          if (statusEl) {
            statusEl.textContent = 'Please complete the required fields.';
            statusEl.classList.remove('is-success');
            statusEl.classList.add('is-error');
          }
          return;
        }

        if (statusEl) {
          statusEl.textContent = 'Sending...';
          statusEl.classList.remove('is-success', 'is-error');
        }

        try {
          const data = new FormData(form);
          const res = await fetch(FORM_ENDPOINT, {
            method: 'POST',
            body: data,
            headers: { Accept: 'application/json' },
          });
          if (!res.ok) throw new Error('Network response was not ok');
          if (statusEl) {
            statusEl.textContent = "Thank you, we'll respond within 1 business day.";
            statusEl.classList.add('is-success');
            statusEl.classList.remove('is-error');
          }
          form.reset();
        } catch (err) {
          if (statusEl) {
            statusEl.textContent = 'Submission failed, please email hello@tms4sap.com directly.';
            statusEl.classList.add('is-error');
            statusEl.classList.remove('is-success');
          }
        }
      });
    });
  }

  initContactFormSection();
  document.addEventListener('astro:page-load', initContactFormSection);
</script>

<style>
  .contact-compact {
    max-width: 600px;
    margin: 0 auto;
  }

  .contact-compact .section-header {
    text-align: center;
    margin-bottom: clamp(2rem, 4vw, 3rem);
  }

  .contact-compact-card {
    margin: 0 auto;
  }

  .honeypot {
    position: absolute !important;
    left: -9999px !important;
    width: 1px;
    height: 1px;
    opacity: 0;
    pointer-events: none;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .form-consent {
    display: flex;
    gap: 10px;
    align-items: flex-start;
    font-size: 0.8125rem;
    color: var(--text-muted);
    line-height: 1.5;
  }

  .form-consent input[type="checkbox"] {
    margin-top: 3px;
    flex-shrink: 0;
  }

  .form-consent a {
    color: var(--amber);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .form-status {
    min-height: 1.25em;
    font-size: 0.875rem;
    color: var(--text-muted);
  }

  .form-status.is-success {
    color: #4ade80;
  }

  .form-status.is-error {
    color: #ef4444;
  }

  [aria-invalid="true"] {
    border-color: #ef4444 !important;
    box-shadow: 0 0 0 3px rgba(239, 68, 68, 0.1) !important;
  }
</style>
