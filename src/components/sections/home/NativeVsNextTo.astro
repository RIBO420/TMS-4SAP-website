    </ScrollReveal>

    <div class="native-grid">
      <!-- LEFT PANEL: Typical -->
      <ScrollReveal client:visible direction="left">
        <figure class="panel panel--typical">
          <div class="panel-title-row">
            <span class="panel-index">01</span>
