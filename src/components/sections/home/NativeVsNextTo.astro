            </text>

            <!-- sync arrow: MES -> APS -->
            <line
              x1="240"
              y1="104"
              x2="240"
              y2="148"
              stroke="var(--border, #27272a)"
              stroke-width="1"
              stroke-dasharray="4 4"
            />
            <polygon
              points="236,146 240,154 244,146"
              fill="var(--border, #27272a)"
            />
            <text
              x="252"
              y="130"
              font-size="10"
              fill="var(--text-muted, #a1a1aa)"
              style="font-family: ui-monospace, 'JetBrains Mono', 'IBM Plex Mono', monospace;"
            >
              {copy.diagramLinks.nightlySync}
            </text>

            <!-- APS bolt-on -->
            <rect
              x="120"
              y="154"
              width="240"
              height="64"
              rx="6"
              fill="var(--text, #fafafa)"
              fill-opacity="0.02"
              stroke="var(--border, #27272a)"
              stroke-width="1.5"
            />
            <text
              x="240"
              y="191"
              text-anchor="middle"
              font-size="13"
              fill="var(--text-muted, #a1a1aa)"
              style="font-family: ui-monospace, 'JetBrains Mono', 'IBM Plex Mono', monospace;"
            >
              {copy.diagramNodes.apsBoltOn}
            </text>

            <!-- sync arrow: APS -> SAP B1 -->
            <line
              x1="240"
              y1="218"
              x2="240"
              y2="262"
              stroke="var(--border, #27272a)"
              stroke-width="1"
              stroke-dasharray="4 4"
            />
            <polygon
              points="236,260 240,268 244,260"
              fill="var(--border, #27272a)"
            />
            <text
              x="252"
              y="244"
              font-size="10"
              fill="var(--text-muted, #a1a1aa)"
              style="font-family: ui-monospace, 'JetBrains Mono', 'IBM Plex Mono', monospace;"
            >
              {copy.diagramLinks.flatFile}
            </text>

            <!-- SAP Business One -->
            <rect
              x="120"
              y="268"
              width="240"
              height="64"
              rx="6"
              fill="var(--text, #fafafa)"
              fill-opacity="0.02"
              stroke="var(--amber, #f59e0b)"
              stroke-width="1.5"
            />
            <text
              x="240"
              y="305"
              text-anchor="middle"
              font-size="13"
              fill="var(--amber, #f59e0b)"
              style="font-family: ui-monospace, 'JetBrains Mono', 'IBM Plex Mono', monospace;"
            >
              {copy.diagramNodes.sapB1}
            </text>
          </svg>

          <figcaption class="panel-caption">
            <span class="caption-label">{copy.leftLabel}</span>
            <p class="caption-bullets">
              {copy.leftBullets.join(" \u00B7 ")}
