---
// §8 — Inside SAP Business One. Not next to it.
// Side-by-side architecture comparison: Typical (ERP + MES + APS wired together
// with nightly sync) vs TMS 4SAP (one unified box). Clean 2D orthographic SVG.
// No isometric. No 3D. No illustration. See HOMEPAGE-REDESIGN.md §8.
import ScrollReveal from "@components/motion/ScrollReveal";
import { getModulesSorted } from "@data/modules";

interface Props {
  lang?: "en" | "nl" | "de";
}
const { lang = "en" } = Astro.props;

// 9 module abbreviations (PPS APS MES PDC QM PDM BI VC DMS) — source of truth.
const moduleAbbrs = getModulesSorted().map((m) => m.abbr);

const copy = {
  en: {
    eyebrow: "08 \u00B7 ARCHITECTURE",
    heading: "Inside SAP Business One. Not next to it.",
    sub:
      "No nightly sync. No mapping layer. ISA-95 levels 3 and 4 in the same client your controllers already use.",
    leftTitle: "Typical",
    leftLabel: "Typical stack",
    rightTitle: "TMS 4SAP",
    rightLabel: "TMS 4SAP",
    leftBullets: [
      "3 separate databases",
      "Sync windows measured in hours",
      "Traceability breaks at every hop",
    ],
    rightBullets: [
      "One database, one transaction log",
      "Changes are immediate, not batched",
      "One audit trail, end to end",
    ],
    diagramNodes: {
      thirdPartyMes: "Third-party MES",
      apsBoltOn: "APS bolt-on",
      sapB1: "SAP Business One",
    },
    diagramLinks: {
      nightlySync: "nightly sync",
      flatFile: "flat file import",
    },
  },
  nl: {
    eyebrow: "08 \u00B7 ARCHITECTUUR",
    heading: "In SAP Business One. Niet ernaast.",
    sub:
      "Geen nachtelijke synchronisatie. Geen mappinglaag. ISA-95 niveaus 3 en 4 in dezelfde client die uw controllers al gebruiken.",
    leftTitle: "Gebruikelijk",
    leftLabel: "Gebruikelijke stack",
    rightTitle: "TMS 4SAP",
    rightLabel: "TMS 4SAP",
    leftBullets: [
      "3 aparte databases",
      "Sync-vensters in uren gemeten",
      "Traceerbaarheid breekt bij elke stap",
    ],
    rightBullets: [
      "\u00E9\u00E9n database, \u00e9\u00e9n transactielog",
      "Wijzigingen zijn direct, niet in batches",
      "\u00e9\u00e9n audit trail, van begin tot eind",
    ],
    diagramNodes: {
      thirdPartyMes: "Extern MES",
      apsBoltOn: "APS bolt-on",
      sapB1: "SAP Business One",
    },
    diagramLinks: {
      nightlySync: "nachtelijke sync",
      flatFile: "flat file import",
    },
  },
  de: {
    eyebrow: "08 \u00B7 ARCHITEKTUR",
    heading: "In SAP Business One. Nicht daneben.",
    sub:
      "Keine n\u00e4chtliche Synchronisation. Keine Mapping-Schicht. ISA-95 Ebenen 3 und 4 in demselben Client, den Ihre Controller bereits nutzen.",
    leftTitle: "\u00dcblich",
    leftLabel: "\u00dcblicher Stack",
    rightTitle: "TMS 4SAP",
    rightLabel: "TMS 4SAP",
    leftBullets: [
      "3 getrennte Datenbanken",
      "Sync-Fenster in Stunden gemessen",
      "R\u00fcckverfolgbarkeit bricht bei jedem Schritt",
    ],
    rightBullets: [
      "Eine Datenbank, ein Transaktionslog",
      "\u00c4nderungen sind sofort, nicht gestapelt",
      "Ein Audit-Trail, Ende zu Ende",
    ],
    diagramNodes: {
      thirdPartyMes: "Drittanbieter-MES",
      apsBoltOn: "APS-Bolt-on",
      sapB1: "SAP Business One",
    },
    diagramLinks: {
      nightlySync: "n\u00e4chtliche Sync",
      flatFile: "Flat-File-Import",
    },
  },
}[lang];

// --- Right panel geometry ---------------------------------------------------
// Place the 9 module nodes in a neat 3x3 grid inside the SAP B1 box.
const rightViewBox = { w: 480, h: 360 };
const rightBox = { x: 40, y: 60, w: 400, h: 240 };
const grid = { cols: 3, rows: 3, padX: 48, padY: 52 };
const cellW = (rightBox.w - grid.padX * 2) / (grid.cols - 1);
const cellH = (rightBox.h - grid.padY * 2) / (grid.rows - 1);

const nodes = moduleAbbrs.map((abbr, i) => {
  const col = i % grid.cols;
  const row = Math.floor(i / grid.cols);
  return {
    abbr,
    cx: rightBox.x + grid.padX + col * cellW,
    cy: rightBox.y + grid.padY + row * cellH,
  };
});

// Solid connecting lines — a ring through adjacent grid neighbours.
// Horizontal links within each row + vertical links between adjacent rows in col 1.
const links: Array<{ x1: number; y1: number; x2: number; y2: number }> = [];
for (let r = 0; r < grid.rows; r++) {
  for (let c = 0; c < grid.cols - 1; c++) {
    const a = nodes[r * grid.cols + c]!;
    const b = nodes[r * grid.cols + c + 1]!;
    links.push({ x1: a.cx, y1: a.cy, x2: b.cx, y2: b.cy });
  }
}
for (let r = 0; r < grid.rows - 1; r++) {
  const a = nodes[r * grid.cols + 1]!;
  const b = nodes[(r + 1) * grid.cols + 1]!;
  links.push({ x1: a.cx, y1: a.cy, x2: b.cx, y2: b.cy });
}
---

<section class="home-section home-section--native" data-section="8" data-lang={lang}>
  <div class="container">
    <ScrollReveal client:visible direction="up">
      <header class="native-header">
        <p class="eyebrow">{copy.eyebrow}</p>
