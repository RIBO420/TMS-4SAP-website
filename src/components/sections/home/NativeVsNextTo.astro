          </figcaption>
        </figure>
      </ScrollReveal>

      <!-- RIGHT PANEL: TMS 4SAP -->
      <ScrollReveal client:visible direction="right">
        <figure class="panel panel--native">
          <div class="panel-title-row">
            <span class="panel-index">02</span>
            <h3 class="panel-title">{copy.rightTitle}</h3>
          </div>

          <svg
            class="panel-svg"
            viewBox={`0 0 ${rightViewBox.w} ${rightViewBox.h}`}
            role="img"
            aria-label={copy.rightLabel}
            xmlns="http://www.w3.org/2000/svg"
          >
            <!-- SAP Business One unified container (pulses) -->
            <rect
              class="sap-pulse"
              x={rightBox.x}
              y={rightBox.y}
              width={rightBox.w}
              height={rightBox.h}
              rx="10"
              fill="var(--amber, #f59e0b)"
              fill-opacity="0.04"
              stroke="var(--amber, #f59e0b)"
              stroke-width="1.5"
            />

            <!-- SAP Business One label, top-left inside the box -->
            <text
              x={rightBox.x + 16}
              y={rightBox.y + 26}
              font-size="12"
              fill="var(--amber, #f59e0b)"
              style="font-family: ui-monospace, 'JetBrains Mono', 'IBM Plex Mono', monospace;"
            >
              {copy.diagramNodes.sapB1}
            </text>

            <!-- solid connecting lines between module nodes -->
            {links.map((l) => (
              <line
                x1={l.x1}
                y1={l.y1}
                x2={l.x2}
                y2={l.y2}
                stroke="var(--amber, #f59e0b)"
                stroke-opacity="0.35"
                stroke-width="1"
              />
            ))}

            <!-- 9 module nodes -->
            {nodes.map((n) => (
              <g>
                <circle
                  cx={n.cx}
                  cy={n.cy}
                  r="22"
                  fill="var(--text, #fafafa)"
                  fill-opacity="0.02"
                  stroke="var(--amber, #f59e0b)"
                  stroke-width="1.5"
                />
                <text
                  x={n.cx}
                  y={n.cy + 4}
                  text-anchor="middle"
                  font-size="11"
                  fill="var(--text, #fafafa)"
                  style="font-family: ui-monospace, 'JetBrains Mono', 'IBM Plex Mono', monospace;"
                >
                  {n.abbr}
                </text>
              </g>
            ))}
          </svg>

          <figcaption class="panel-caption">
            <span class="caption-label">{copy.rightLabel}</span>
            <p class="caption-bullets">
              {copy.rightBullets.join(" \u00B7 ")}
            </p>
          </figcaption>
        </figure>
      </ScrollReveal>
    </div>
  </div>
</section>

<style>
  .home-section--native {
    padding-block: 140px;
  }

  .container {
    max-width: 1280px;
    margin: 0 auto;
    padding-inline: 1.5rem;
  }

  /* Heading: left-aligned (rhythm break from centered §7). */
  .native-header {
    max-width: 760px;
    margin: 0 0 64px 0;
    text-align: left;
  }

  .eyebrow {
    font-family: ui-monospace, "JetBrains Mono", "IBM Plex Mono", monospace;
    font-size: 12px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--amber, #f59e0b);
    margin: 0 0 1rem;
  }

  .native-heading {
    font-family: var(--font-heading, Georgia, serif);
    font-size: clamp(32px, 4vw, 52px);
    font-weight: 500;
    line-height: 1.1;
    letter-spacing: -0.01em;
    color: var(--text, #fafafa);
    margin: 0 0 1rem;
  }

  .native-sub {
    font-size: 17px;
    line-height: 1.55;
    color: var(--text-muted, #a1a1aa);
    margin: 0;
    max-width: 640px;
  }

  .native-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    padding-block: 80px 0;
  }

  .panel {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .panel-title-row {
    display: flex;
    align-items: baseline;
    gap: 16px;
  }

  .panel-index {
    font-family: ui-monospace, "JetBrains Mono", "IBM Plex Mono", monospace;
    font-size: 11px;
    letter-spacing: 0.12em;
    color: var(--text, #fafafa);
    opacity: 0.3;
  }

  .panel-title {
    font-family: var(--font-heading, Georgia, serif);
    font-size: 20px;
    font-weight: 500;
    color: var(--text, #fafafa);
    margin: 0;
    letter-spacing: -0.005em;
  }

  .panel-svg {
    width: 100%;
    height: auto;
    display: block;
  }

  .panel-caption {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .caption-label {
    font-family: ui-monospace, "JetBrains Mono", "IBM Plex Mono", monospace;
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text, #fafafa);
    opacity: 0.35;
  }

  .caption-bullets {
    font-size: 14px;
    line-height: 1.55;
    color: var(--text-muted, #a1a1aa);
    margin: 0;
  }

  /* Subtle amber pulse on the SAP Business One unified container. */
  .sap-pulse {
    transform-origin: center;
    transform-box: fill-box;
    animation: sapPulse 2s ease-in-out infinite;
  }

  @keyframes sapPulse {
    0%, 100% {
      stroke-opacity: 1;
      fill-opacity: 0.04;
    }
    50% {
      stroke-opacity: 0.7;
      fill-opacity: 0.08;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .sap-pulse {
      animation: none;
    }
  }

  @media (max-width: 860px) {
    .home-section--native {
      padding-block: 96px;
    }
    .native-grid {
      grid-template-columns: 1fr;
      gap: 48px;
      padding-block: 56px 0;
    }
    .native-header {
      margin-bottom: 48px;
    }
  }
</style>
