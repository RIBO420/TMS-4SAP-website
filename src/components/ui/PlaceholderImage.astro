---
interface Props {
  /** Aspect ratio class: '16:9' | '4:3' | '1:1' | '3:2' | '21:9' */
  aspect?: string;
  /** Label shown on the placeholder */
  label?: string;
  /** Optional height override */
  height?: string;
  /** Border radius */
  rounded?: boolean;
  /** Additional CSS class */
  class?: string;
}

const {
  aspect = '16:9',
  label = 'Image placeholder',
  height,
  rounded = true,
  class: className = '',
} = Astro.props;

const aspectMap: Record<string, string> = {
  '16:9': '56.25%',
  '4:3': '75%',
  '1:1': '100%',
  '3:2': '66.67%',
  '21:9': '42.86%',
  '3:4': '133.33%',
};

const paddingBottom = height ? undefined : aspectMap[aspect] || '56.25%';
---

<div
  class:list={['placeholder-img', className, { 'placeholder-rounded': rounded }]}
  style={height ? `height: ${height}` : `padding-bottom: ${paddingBottom}`}
  role="img"
  aria-label={label}
>
  <div class="placeholder-inner">
    <svg class="placeholder-icon" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
      <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
      <circle cx="8.5" cy="8.5" r="1.5"/>
      <polyline points="21 15 16 10 5 21"/>
    </svg>
    <span class="placeholder-label">{label}</span>
  </div>
</div>

<style>
  .placeholder-img {
    position: relative;
    width: 100%;
    background: linear-gradient(135deg, rgba(245, 158, 11, 0.06) 0%, rgba(9, 9, 11, 0.4) 50%, rgba(245, 158, 11, 0.04) 100%);
    border: 1px dashed rgba(245, 158, 11, 0.2);
    overflow: hidden;
  }

  .placeholder-rounded {
    border-radius: var(--radius-lg, 12px);
  }

  .placeholder-inner {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 12px;
  }

  .placeholder-icon {
    color: rgba(245, 158, 11, 0.25);
  }

  .placeholder-label {
    font-size: 0.75rem;
    font-weight: 500;
    color: rgba(245, 158, 11, 0.35);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
</style>
