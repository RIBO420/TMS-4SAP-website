---
import '../styles/global.css';
import Nav from '../components/global/Nav.astro';
import Footer from '../components/global/Footer.astro';
import { defaultLang, languages, type Lang } from '../i18n/config';
import { getLocalizedPath } from '../i18n/utils';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  lang?: Lang;
}

const {
  title,
  description,
  ogImage = `${import.meta.env.BASE_URL}og-default.png`,
  lang = defaultLang,
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site);

// Build hreflang alternate URLs
const currentPathStripped = Astro.url.pathname.replace(/^\/(en|nl|de)(\/|$)/, '/');
const langCodes = Object.keys(languages) as Lang[];
---

<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />

  <!-- SEO -->
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />

  <!-- Hreflang alternates -->
  {langCodes.map((l) => {
    const altPath = getLocalizedPath(currentPathStripped, l);
    const altUrl = new URL(altPath, Astro.site);
    return <link rel="alternate" hreflang={l} href={altUrl.href} />;
  })}
  <link rel="alternate" hreflang="x-default" href={new URL(currentPathStripped, Astro.site).href} />

  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:type" content="website" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <!-- Typography: Plus Jakarta Sans + DM Sans -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,300..700&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap"
    rel="stylesheet"
  />
</head>
<body>
  <Nav lang={lang} />

  <main id="main-content">
    <slot />
  </main>

  <Footer lang={lang} />

  <!-- Scroll animations for [data-animate] elements -->
  <script>
    import { initAnimations } from '../scripts/animations.js';
    initAnimations();

    // Re-run after Astro page transitions (View Transitions)
    document.addEventListener('astro:page-load', () => {
      initAnimations();
    });
  </script>
</body>
</html>
