---
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogPostCard from '../../components/cards/BlogPostCard.astro';
import SectionHeader from '../../components/ui/SectionHeader.astro';
import CTABanner from '../../components/ui/CTABanner.astro';
import { withBase } from '../../i18n/utils';
import { posts as allPosts } from '@data/blog';

export const getStaticPaths = (() => {
  const locale = 'en';
  return allPosts.map((p) => {
    const localized = p.i18n[locale];
    return {
      params: { slug: p.slug },
      props: {
        slug: p.slug,
        date: p.date,
        author: p.author[locale],
        title: localized.title,
        description: localized.description,
        category: localized.category,
        content: localized.content,
      },
    };
  });
}) satisfies GetStaticPaths;

interface Props {
  slug: string;
  date: string;
  author: string;
  title: string;
  description: string;
  category: string;
  content: string;
}

const post = Astro.props as Props;

const relatedPosts = allPosts
  .filter((p) => p.slug !== post.slug)
  .map((p) => ({
    slug: p.slug,
    date: p.date,
    author: p.author.en,
    title: p.i18n.en.title,
    description: p.i18n.en.description,
    category: p.i18n.en.category,
  }));

const formattedDate = new Date(post.date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

// Estimate reading time (~200 words per minute)
const wordCount = post.content.replace(/<[^>]*>/g, '').split(/\s+/).length;
const readingTime = Math.max(1, Math.ceil(wordCount / 200));
---

<BaseLayout
  title={`${post.title} | TMS 4SAP Blog`}
  description={post.description}
>
  <!-- Breadcrumbs + Article Header -->
  <section class="article-hero">
    <div class="container">
      <nav class="breadcrumbs" aria-label="Breadcrumb">
        <ol>
          <li>
            <a href={withBase('/')}>Home</a>
            <span class="breadcrumb-sep" aria-hidden="true">/</span>
          </li>
          <li>
            <a href={withBase('/blog')}>Blog</a>
            <span class="breadcrumb-sep" aria-hidden="true">/</span>
          </li>
          <li>
            <span aria-current="page">{post.title}</span>
          </li>
        </ol>
      </nav>

      <div class="article-header">
        <div class="article-meta-top">
          <span class="article-category">{post.category}</span>
          <span class="article-reading-time">{readingTime} min read</span>
        </div>
        <h1 class="article-title">{post.title}</h1>
        <div class="article-meta-bottom">
          <span class="article-author">{post.author}</span>
          <span class="article-dot" aria-hidden="true"></span>
          <time class="article-date" datetime={post.date}>{formattedDate}</time>
        </div>
      </div>
    </div>
  </section>

  <!-- Article Body -->
  <article class="article-body section">
    <div class="container">
      <div class="article-content prose" set:html={post.content} />
    </div>
  </article>

  <!-- Author Bio -->
  <section class="author-section">
    <div class="container">
      <div class="author-card">
        <div class="author-avatar" aria-hidden="true">
          <span class="author-avatar-text">TE</span>
        </div>
        <div class="author-info">
          <span class="author-label">Written by</span>
          <span class="author-name">{post.author}</span>
          <p class="author-bio">
            The TMS Editorial team publishes insights on manufacturing technology,
            ERP best practices, and Industry 4.0 trends. Our articles draw on
            decades of combined experience helping manufacturers optimise their
            production operations with SAP Business One and TMS modules.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Related Articles -->
  <section class="related-section section">
    <div class="container">
      <SectionHeader
        tag="Related Articles"
        title="Continue"
        titleAccent="Reading"
        description="Explore more insights on manufacturing technology and ERP."
      />
      <div class="related-grid">
        {relatedPosts.map((relPost) => (
          <BlogPostCard
            title={relPost.title}
            description={relPost.description}
            date={relPost.date}
            author={relPost.author}
            category={relPost.category}
            slug={relPost.slug}
          />
        ))}
      </div>
    </div>
  </section>

  <CTABanner
    title="Ready to modernize your"
    titleAccent="manufacturing?"
    description="Book a free 1-hour demo with our experts and see how TMS 4SAP can transform your production floor."
    primaryCTA={{ label: 'Book a Demo', href: '/demo' }}
    secondaryCTA={{ label: 'Download Brochure', href: '/downloads' }}
  />
</BaseLayout>

<style>
  /* ============================================
     ARTICLE HERO
     ============================================ */
  .article-hero {
    position: relative;
    padding-top: clamp(7rem, 12vw, 10rem);
    padding-bottom: clamp(2rem, 4vw, 3rem);
    overflow: hidden;
  }

  .article-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse 70% 50% at 50% 0%,
      rgba(245, 158, 11, 0.04) 0%,
      transparent 70%
    );
    pointer-events: none;
  }

  /* ---- Breadcrumbs ---- */
  .breadcrumbs {
    position: relative;
    z-index: 1;
    margin-bottom: 32px;
  }

  .breadcrumbs ol {
    display: flex;
    align-items: center;
    list-style: none;
    padding: 0;
    margin: 0;
    flex-wrap: wrap;
  }

  .breadcrumbs li {
    display: flex;
    align-items: center;
    font-size: 0.875rem;
    color: var(--text-dim);
  }

  .breadcrumbs a {
    color: var(--text-dim);
    transition: color 0.2s var(--ease);
  }

  .breadcrumbs a:hover {
    color: var(--amber);
  }

  .breadcrumb-sep {
    margin: 0 10px;
    color: var(--border-hover);
    user-select: none;
  }

  .breadcrumbs [aria-current="page"] {
    color: var(--text-muted);
    /* Truncate long titles in breadcrumb */
    max-width: 320px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  /* ---- Article Header ---- */
  .article-header {
    position: relative;
    z-index: 1;
    max-width: 720px;
  }

  .article-meta-top {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 20px;
  }

  .article-category {
    display: inline-block;
    padding: 4px 12px;
    background: var(--amber-dim);
    border: 1px solid rgba(245, 158, 11, 0.15);
    border-radius: 100px;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--amber);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .article-reading-time {
    font-size: 0.8125rem;
    color: var(--text-dim);
  }

  .article-title {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 4.5vw, 3rem);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: var(--text);
    margin-bottom: 20px;
  }

  .article-meta-bottom {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 0.9375rem;
  }

  .article-author {
    color: var(--text-muted);
    font-weight: 500;
  }

  .article-dot {
    width: 4px;
    height: 4px;
    background: var(--text-dim);
    border-radius: 50%;
  }

  .article-date {
    color: var(--text-dim);
  }

  /* ============================================
     ARTICLE BODY (Prose)
     ============================================ */
  .article-body {
    padding-top: 0;
    padding-bottom: clamp(3rem, 6vw, 5rem);
  }

  .article-content {
    max-width: 720px;
    margin: 0 auto;
  }

  /* Prose typography */
  .prose :global(p) {
    font-size: 1.0625rem;
    color: var(--text-muted);
    line-height: 1.8;
    margin-bottom: 1.5em;
  }

  .prose :global(h2) {
    font-family: var(--font-heading);
    font-size: clamp(1.375rem, 2.5vw, 1.75rem);
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: -0.02em;
    color: var(--text);
    margin-top: 2.5em;
    margin-bottom: 0.75em;
  }

  .prose :global(h3) {
    font-family: var(--font-heading);
    font-size: clamp(1.125rem, 2vw, 1.375rem);
    font-weight: 600;
    line-height: 1.3;
    letter-spacing: -0.01em;
    color: var(--text);
    margin-top: 2em;
    margin-bottom: 0.5em;
  }

  .prose :global(ul),
  .prose :global(ol) {
    margin-bottom: 1.5em;
    padding-left: 1.5em;
  }

  .prose :global(li) {
    font-size: 1.0625rem;
    color: var(--text-muted);
    line-height: 1.7;
    margin-bottom: 0.5em;
  }

  .prose :global(li strong) {
    color: var(--text);
  }

  .prose :global(strong) {
    color: var(--text);
    font-weight: 600;
  }

  .prose :global(a) {
    color: var(--amber);
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: color 0.2s var(--ease);
  }

  .prose :global(a:hover) {
    color: var(--amber-hover);
  }

  /* First paragraph after hero -- slightly larger */
  .prose :global(p:first-child) {
    font-size: 1.1875rem;
    line-height: 1.75;
    color: var(--text);
  }

  /* ============================================
     AUTHOR BIO CARD
     ============================================ */
  .author-section {
    padding-bottom: clamp(2rem, 4vw, 3rem);
  }

  .author-card {
    max-width: 720px;
    margin: 0 auto;
    display: flex;
    gap: 20px;
    padding: 28px;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
  }

  .author-avatar {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: var(--amber-dim);
    border: 1px solid rgba(245, 158, 11, 0.15);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .author-avatar-text {
    font-family: var(--font-heading);
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--amber);
    letter-spacing: 0.02em;
  }

  .author-info {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .author-label {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-dim);
  }

  .author-name {
    font-family: var(--font-heading);
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--text);
  }

  .author-bio {
    font-size: 0.9375rem;
    color: var(--text-muted);
    line-height: 1.6;
    margin-top: 4px;
  }

  /* ============================================
     RELATED ARTICLES
     ============================================ */
  .related-section {
    border-top: 1px solid var(--border);
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }

  /* ============================================
     RESPONSIVE
     ============================================ */
  @media (max-width: 768px) {
    .related-grid {
      grid-template-columns: 1fr;
    }

    .author-card {
      flex-direction: column;
      align-items: flex-start;
    }

    .breadcrumbs [aria-current="page"] {
      max-width: 200px;
    }
  }

  @media (max-width: 480px) {
    .article-title {
      font-size: clamp(1.75rem, 6vw, 2.25rem);
    }
  }
</style>
