---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HeroInner from '../../components/ui/HeroInner.astro';
import CTABanner from '../../components/ui/CTABanner.astro';
---

<BaseLayout
  lang="de"
  title="Kontakt | TMS 4SAP"
  description="Nehmen Sie Kontakt mit dem Team von The Manufacturing Suite auf. Erreichen Sie unseren Hauptsitz in Maastricht, rufen Sie uns an oder senden Sie uns eine Nachricht. Wir helfen Ihnen gerne bei Ihren Anforderungen an Fertigungssoftware."
>
  <!-- Hero -->
  <HeroInner
    breadcrumbs={[
      { label: 'Startseite', href: '/de/' },
      { label: 'Kontakt', href: '/de/contact' },
    ]}
    tag="Kontakt"
    title="Kontaktieren Sie uns"
    description="Ob Sie eine Frage zu unseren Modulen haben, technischen Support benötigen oder erfahren möchten, wie TMS 4SAP Ihre Fertigungsabläufe transformieren kann — unser Team steht Ihnen gerne zur Verfügung."
  />

  <!-- Contact Section: Info + Form -->
  <section class="section contact-section">
    <div class="container">
      <div class="contact-grid">
        <!-- LEFT: Contact Info Cards -->
        <div class="contact-info" data-animate>
          <h2>Wir freuen uns auf <span class="text-amber">Ihre Nachricht</span></h2>
          <p class="contact-desc">
            Unser Team aus Spezialisten für Fertigungssoftware steht Ihnen zur Verfügung, um Ihre Fragen zu beantworten,
            Ihre Anforderungen zu besprechen und die richtige Lösung für Ihre Produktionsumgebung zu finden.
          </p>

          <div class="contact-details">
            <!-- Headquarters -->
            <div class="contact-card">
              <div class="contact-card-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
                  <polyline points="9 22 9 12 15 12 15 22"></polyline>
                </svg>
              </div>
              <div class="contact-card-body">
                <span class="contact-label">Hauptsitz</span>
                <span class="contact-value">Il Flore<br/>Avenue Ceramique 221<br/>6221 KX, Maastricht<br/>Niederlande</span>
              </div>
            </div>

            <!-- Phone -->
            <div class="contact-card">
              <div class="contact-card-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
                </svg>
              </div>
              <div class="contact-card-body">
                <span class="contact-label">Telefon</span>
                <a href="tel:+31432340050" class="contact-value contact-link">+31 43 234 00 50</a>
              </div>
            </div>

            <!-- Email -->
            <div class="contact-card">
              <div class="contact-card-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect width="20" height="16" x="2" y="4" rx="2"></rect>
                  <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
                </svg>
              </div>
              <div class="contact-card-body">
                <span class="contact-label">E-Mail</span>
                <a href="mailto:info@themanufacturingsuite.com" class="contact-value contact-link">info@themanufacturingsuite.com</a>
              </div>
            </div>

            <!-- Support Hours -->
            <div class="contact-card">
              <div class="contact-card-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="12" cy="12" r="10"></circle>
                  <polyline points="12 6 12 12 16 14"></polyline>
                </svg>
              </div>
              <div class="contact-card-body">
                <span class="contact-label">Supportzeiten</span>
                <span class="contact-value">Montag &ndash; Freitag<br/>08:00 &ndash; 17:00 MEZ</span>
              </div>
            </div>
          </div>
        </div>

        <!-- RIGHT: Contact Form -->
        <div class="contact-form-card" data-animate>
          <h3 class="form-card-title">Nachricht senden</h3>
          <form class="contact-form" id="contactForm" novalidate>
            <div class="form-row">
              <div class="form-group">
                <label for="contact-name">Vollständiger Name <span class="required" aria-label="required">*</span></label>
                <input type="text" id="contact-name" name="name" placeholder="Ihr vollständiger Name" required autocomplete="name" />
              </div>
              <div class="form-group">
                <label for="contact-email">Geschäftliche E-Mail <span class="required" aria-label="required">*</span></label>
                <input type="email" id="contact-email" name="email" placeholder="sie@unternehmen.de" required autocomplete="email" />
              </div>
            </div>

            <div class="form-row">
              <div class="form-group">
                <label for="contact-company">Unternehmen <span class="required" aria-label="required">*</span></label>
                <input type="text" id="contact-company" name="company" placeholder="Ihr Unternehmensname" required autocomplete="organization" />
              </div>
              <div class="form-group">
                <label for="contact-phone">Telefon</label>
                <input type="tel" id="contact-phone" name="phone" placeholder="+49 ..." autocomplete="tel" />
              </div>
            </div>

            <div class="form-group">
              <label for="contact-subject">Betreff <span class="required" aria-label="required">*</span></label>
              <select id="contact-subject" name="subject" required>
                <option value="" disabled selected>Betreff auswählen</option>
                <option value="general">Allgemeine Anfrage</option>
                <option value="sales">Vertrieb</option>
                <option value="support">Support</option>
                <option value="partnership">Partnerschaft</option>
                <option value="other">Sonstiges</option>
              </select>
            </div>

            <div class="form-group">
              <label for="contact-message">Nachricht <span class="required" aria-label="required">*</span></label>
              <textarea id="contact-message" name="message" placeholder="Wie können wir Ihnen helfen?" rows="5" required></textarea>
            </div>

            <button type="submit" class="btn btn-primary btn-lg btn-full">Nachricht senden</button>

            <!-- Success message -->
            <div class="form-success" id="contactSuccess" role="alert" aria-live="polite">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                <polyline points="22 4 12 14.01 9 11.01"></polyline>
              </svg>
              <span>Vielen Dank! Ihre Nachricht wurde gesendet. Wir melden uns innerhalb eines Werktages bei Ihnen.</span>
            </div>

            <p class="form-privacy">
              Mit dem Absenden dieses Formulars stimmen Sie unserer
              <a href="/de/legal/privacy">Datenschutzerklärung</a> zu. Wir verwenden Ihre
              Daten ausschließlich zur Beantwortung Ihrer Anfrage.
            </p>
          </form>
        </div>
      </div>
    </div>
  </section>

  <!-- Map Placeholder -->
  <section class="section map-section" data-animate>
    <div class="container">
      <div class="map-card">
        <div class="map-pin">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"></path>
            <circle cx="12" cy="10" r="3"></circle>
          </svg>
        </div>
        <div class="map-info">
          <h3>TMS 4SAP Hauptsitz</h3>
          <p>Il Flore, Avenue Ceramique 221, 6221 KX Maastricht, Niederlande</p>
        </div>
        <div class="map-grid-bg" aria-hidden="true"></div>
      </div>
    </div>
  </section>

  <!-- CTA Banner -->
  <CTABanner
    title="Lieber eine Live-Demo?"
    titleAccent="Kostenlose Präsentation buchen"
    description="Erleben Sie TMS 4SAP in Aktion mit einer persönlichen Online-Demonstration, geleitet von unseren Fertigungsexperten. Unverbindlich und kostenfrei."
    primaryCTA={{ label: 'Demo buchen', href: '/de/demo' }}
    secondaryCTA={{ label: 'Jetzt anrufen', href: 'tel:+31432340050' }}
  />
</BaseLayout>

<script>
  function initContactForm() {
    const form = document.getElementById('contactForm') as HTMLFormElement | null;
    const success = document.getElementById('contactSuccess');

    if (!form || !success) return;

    form.addEventListener('submit', (e: Event) => {
      e.preventDefault();

      // Basic validation
      const requiredFields = form.querySelectorAll('[required]') as NodeListOf<HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement>;
      let valid = true;

      requiredFields.forEach((field) => {
        field.classList.remove('field-error');
        if (!field.value.trim()) {
          field.classList.add('field-error');
          valid = false;
        }
      });

      const emailField = form.querySelector('[type="email"]') as HTMLInputElement | null;
      if (emailField && emailField.value && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(emailField.value)) {
        emailField.classList.add('field-error');
        valid = false;
      }

      if (!valid) return;

      // Show success
      success.classList.add('visible');
      form.querySelectorAll('input, textarea, select, button[type="submit"]').forEach((el) => {
        (el as HTMLInputElement).disabled = true;
      });

      // Reset after 3 seconds
      setTimeout(() => {
        form.reset();
        success.classList.remove('visible');
        form.querySelectorAll('input, textarea, select, button[type="submit"]').forEach((el) => {
          (el as HTMLInputElement).disabled = false;
          (el as HTMLInputElement).classList.remove('field-error');
        });
      }, 3000);
    });
  }

  initContactForm();
  document.addEventListener('astro:page-load', initContactForm);
</script>

<style>
  /* ---- Contact Section ---- */
  .contact-section {
    padding-top: clamp(2rem, 4vw, 3rem);
  }

  /* ---- Contact Info Side ---- */
  .contact-info h2 {
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
  }

  .contact-desc {
    color: var(--text-muted);
    font-size: 1rem;
    line-height: 1.7;
    max-width: 480px;
  }

  .contact-details {
    display: flex;
    flex-direction: column;
    gap: 16px;
    margin-top: 24px;
  }

  /* ---- Contact Cards ---- */
  .contact-card {
    display: flex;
    align-items: flex-start;
    gap: 16px;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 20px;
    transition: border-color 0.2s var(--ease);
  }

  .contact-card:hover {
    border-color: var(--border-hover);
  }

  .contact-card-icon {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--amber-dim);
    border-radius: var(--radius-sm);
    color: var(--amber);
    flex-shrink: 0;
  }

  .contact-card-body {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .contact-label {
    display: block;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--amber);
  }

  .contact-value {
    display: block;
    font-size: 0.9375rem;
    color: var(--text-muted);
    line-height: 1.5;
  }

  .contact-link {
    transition: color 0.2s var(--ease);
  }

  .contact-link:hover {
    color: var(--amber);
  }

  /* ---- Form Card ---- */
  .contact-form-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-xl);
    padding: clamp(1.5rem, 3vw, 2.5rem);
  }

  .form-card-title {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    margin-bottom: 24px;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .form-group label {
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--text-muted);
  }

  .required {
    color: var(--amber);
  }

  .form-group input,
  .form-group textarea,
  .form-group select {
    padding: 12px 16px;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    font-size: 0.9375rem;
    color: var(--text);
    transition: border-color 0.2s var(--ease), box-shadow 0.2s var(--ease);
    outline: none;
    font-family: var(--font-body);
  }

  .form-group select {
    appearance: none;
    -webkit-appearance: none;
    background-image: url("data:image/svg+xml,%3Csvg width='12' height='8' viewBox='0 0 12 8' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1.5L6 6.5L11 1.5' stroke='%2371717A' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
    background-repeat: no-repeat;
    background-position: right 16px center;
    padding-right: 40px;
    cursor: pointer;
  }

  .form-group select option {
    background: var(--bg);
    color: var(--text);
  }

  .form-group input::placeholder,
  .form-group textarea::placeholder {
    color: var(--text-dim);
  }

  .form-group input:focus,
  .form-group textarea:focus,
  .form-group select:focus {
    border-color: var(--amber);
    box-shadow: 0 0 0 3px var(--amber-dim);
  }

  .form-group textarea {
    resize: vertical;
    min-height: 120px;
  }

  /* Field error state */
  .form-group input:global(.field-error),
  .form-group textarea:global(.field-error),
  .form-group select:global(.field-error) {
    border-color: #ef4444;
    box-shadow: 0 0 0 3px rgba(239, 68, 68, 0.1);
  }

  /* Success message */
  .form-success {
    display: none;
    align-items: center;
    gap: 12px;
    padding: 16px;
    background: rgba(34, 197, 94, 0.08);
    border: 1px solid rgba(34, 197, 94, 0.2);
    border-radius: var(--radius-sm);
    font-size: 0.9375rem;
    color: #4ade80;
  }

  .form-success:global(.visible) {
    display: flex;
  }

  .form-success svg {
    flex-shrink: 0;
    color: #4ade80;
  }

  /* Privacy note */
  .form-privacy {
    font-size: 0.8125rem;
    color: var(--text-dim);
    line-height: 1.5;
  }

  .form-privacy a {
    color: var(--amber);
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: color 0.2s var(--ease);
  }

  .form-privacy a:hover {
    color: var(--amber-hover);
  }

  /* ---- Map Section ---- */
  .map-section {
    padding-top: 0;
  }

  .map-card {
    position: relative;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-xl);
    padding: clamp(3rem, 5vw, 5rem);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    gap: 16px;
    min-height: 300px;
    overflow: hidden;
  }

  .map-pin {
    width: 56px;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--amber-dim);
    border-radius: 50%;
    color: var(--amber);
    position: relative;
    z-index: 1;
  }

  .map-pin::after {
    content: '';
    position: absolute;
    inset: -8px;
    border: 1px solid rgba(245, 158, 11, 0.15);
    border-radius: 50%;
    animation: map-pulse 3s var(--ease) infinite;
  }

  @keyframes map-pulse {
    0%, 100% { transform: scale(1); opacity: 0.4; }
    50% { transform: scale(1.15); opacity: 0.1; }
  }

  .map-info {
    position: relative;
    z-index: 1;
  }

  .map-info h3 {
    font-family: var(--font-heading);
    font-size: 1.125rem;
    font-weight: 600;
    margin-bottom: 8px;
  }

  .map-info p {
    font-size: 0.9375rem;
    color: var(--text-muted);
    line-height: 1.5;
    max-width: 400px;
  }

  /* Grid pattern background for map card */
  .map-grid-bg {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(var(--border) 1px, transparent 1px),
      linear-gradient(90deg, var(--border) 1px, transparent 1px);
    background-size: 48px 48px;
    opacity: 0.3;
    mask-image: radial-gradient(ellipse 60% 60% at 50% 50%, black 10%, transparent 70%);
    -webkit-mask-image: radial-gradient(ellipse 60% 60% at 50% 50%, black 10%, transparent 70%);
  }

  /* ---- Responsive ---- */
  @media (max-width: 768px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }

    .form-row {
      grid-template-columns: 1fr;
    }
  }
</style>
