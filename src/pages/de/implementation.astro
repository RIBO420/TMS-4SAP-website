---
import BaseLayout from '@layouts/BaseLayout.astro';
import HeroInner from '@components/ui/HeroInner.astro';
import SectionHeader from '@components/ui/SectionHeader.astro';
import CTABanner from '@components/ui/CTABanner.astro';

const breadcrumbs = [
  { label: 'Startseite', href: '/de' },
  { label: 'Implementierung', href: '/de/implementation' },
];

interface Phase {
  number: number;
  title: string;
  duration: string;
  tasks: string[];
  deliverable: string;
}

const phases: Phase[] = [
  {
    number: 1,
    title: 'Analyse',
    duration: '2-3 Wochen',
    tasks: [
      'Prozessanalyse und Anforderungserhebung',
      'Bewertung der aktuellen Systeme',
      'Modulauswahl und Umfangsdefinition',
    ],
    deliverable: 'Implementierungsfahrplan',
  },
  {
    number: 2,
    title: 'Konzeption',
    duration: '3-4 Wochen',
    tasks: [
      'Systemkonfigurationsdesign',
      'Planung der Datenmigration',
      'Integrationsmapping',
    ],
    deliverable: 'Lösungsdesign-Dokument',
  },
  {
    number: 3,
    title: 'Aufbau',
    duration: '6-8 Wochen',
    tasks: [
      'Systemkonfiguration',
      'Durchführung der Datenmigration',
      'Individuelle Entwicklung bei Bedarf',
      'Integrationseinrichtung',
    ],
    deliverable: 'Konfiguriertes System',
  },
  {
    number: 4,
    title: 'Test',
    duration: '2-3 Wochen',
    tasks: [
      'Benutzerakzeptanztest',
      'Integrationstest',
      'Leistungstest',
    ],
    deliverable: 'Testfreigabe',
  },
  {
    number: 5,
    title: 'Go-Live & Support',
    duration: '2 Wochen + fortlaufend',
    tasks: [
      'Go-Live-Vorbereitung',
      'Anwenderschulung',
      'Hypercare-Supportphase',
      'Übergang zum Standardsupport',
    ],
    deliverable: 'Produktivsystem',
  },
];

const expectations = [
  {
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>',
    title: 'Typischer Zeitrahmen',
    description: 'Die meisten Implementierungen werden innerhalb von 3 bis 6 Monaten abgeschlossen, abhängig von der Anzahl der Module und der Komplexität Ihrer Fertigungsprozesse.',
  },
  {
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>',
    title: 'Schulung inklusive',
    description: 'Jede Implementierung beinhaltet umfassende Endanwenderschulungen, Administrator-Workshops und Super-User-Zertifizierungen, damit Ihr Team vom ersten Tag an sicher arbeiten kann.',
  },
  {
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>',
    title: 'Dedizierter Projektmanager',
    description: 'Ein zentraler Ansprechpartner begleitet Ihr Projekt vom Kickoff über den Go-Live bis in den Support. Er versteht die Fertigung und sorgt dafür, dass Ihre Implementierung im Zeit- und Budgetrahmen bleibt.',
  },
];
---

<BaseLayout
  lang="de"
  title="Implementierung | TMS 4SAP"
  description="Erfahren Sie mehr über die TMS-Implementierungsmethodik: ein bewährter 5-Phasen-Ansatz für den Erfolg Ihres Fertigungs-ERP mit SAP Business One. Typischer Go-Live in 3-6 Monaten."
>
  <!-- Hero -->
  <HeroInner
    breadcrumbs={breadcrumbs}
    tag="Methodik"
    title="Implementierungs-"
    titleAccent="methodik"
    description="Ein bewährter Ansatz für den Erfolg Ihres Fertigungs-ERP. Unsere strukturierte 5-Phasen-Methodik stellt sicher, dass Ihre TMS-Implementierung pünktlich und im Budget Mehrwert liefert."
  />

  <!-- Timeline -->
  <section class="section timeline-section">
    <div class="container">
      <SectionHeader
        tag="5 Phasen"
        title="Von der Analyse bis zum"
        titleAccent="Go-Live"
        description="Jede TMS-Implementierung folgt einer strukturierten Methodik, die über Hunderte von Fertigungsprojekten verfeinert wurde."
      />

      <!-- Desktop horizontal timeline connector -->
      <div class="timeline-connector" aria-hidden="true">
        <div class="connector-line"></div>
        {phases.map((phase) => (
          <div class="connector-dot">
            <span>{phase.number}</span>
          </div>
        ))}
      </div>

      <!-- Phase cards -->
      <div class="phases-grid">
        {phases.map((phase) => (
          <div class="phase-card" data-animate>
            <!-- Mobile: phase number badge -->
            <div class="phase-number-mobile" aria-hidden="true">
              <span>{phase.number}</span>
            </div>

            <div class="phase-header">
              <span class="phase-badge">Phase {phase.number}</span>
              <span class="phase-duration">{phase.duration}</span>
            </div>

            <h3 class="phase-title">{phase.title}</h3>

            <ul class="phase-tasks" role="list">
              {phase.tasks.map((task) => (
                <li>
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                  <span>{task}</span>
                </li>
              ))}
            </ul>

            <div class="phase-deliverable">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
              <span>Ergebnis: <strong>{phase.deliverable}</strong></span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- What to Expect -->
  <section class="section expect-section">
    <div class="container">
      <SectionHeader
        tag="Was Sie erwartet"
        title="Für Ihren"
        titleAccent="Erfolg konzipiert"
        description="Über die Methodik hinaus bietet jede TMS-Implementierung die Ressourcen und die Unterstützung, die Sie für Ihren Erfolg benötigen."
      />

      <div class="expect-grid">
        {expectations.map((item) => (
          <div class="expect-card" data-animate>
            <div class="expect-icon">
              <Fragment set:html={item.icon} />
            </div>
            <h3>{item.title}</h3>
            <p>{item.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Banner -->
  <CTABanner
    title="Bereit, Ihre Implementierung"
    titleAccent="zu starten?"
    description="Sprechen Sie mit unserem Team, um Ihre Anforderungen zu besprechen und einen maßgeschneiderten Implementierungsplan für Ihre Fertigungsumgebung zu erhalten."
    primaryCTA={{ label: 'Demo buchen', href: '/de/demo' }}
    secondaryCTA={{ label: 'Kontakt aufnehmen', href: '/de/contact' }}
  />
</BaseLayout>

<style>
  /* ---- Timeline Section ---- */
  .timeline-section {
    padding-top: clamp(2rem, 4vw, 3rem);
  }

  /* ---- Desktop Horizontal Connector ---- */
  .timeline-connector {
    display: none;
    position: relative;
    margin-bottom: 32px;
    padding: 0 40px;
    align-items: center;
    justify-content: space-between;
  }

  .connector-line {
    position: absolute;
    top: 50%;
    left: 40px;
    right: 40px;
    height: 2px;
    background: var(--border);
    transform: translateY(-50%);
  }

  .connector-line::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, var(--amber) 0%, rgba(245, 158, 11, 0.3) 100%);
    border-radius: 1px;
  }

  .connector-dot {
    position: relative;
    z-index: 1;
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--bg);
    border: 2px solid var(--amber);
    border-radius: 50%;
    font-family: var(--font-heading);
    font-size: 0.8125rem;
    font-weight: 700;
    color: var(--amber);
  }

  /* ---- Phase Cards Grid ---- */
  .phases-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
  }

  .phase-card {
    position: relative;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 28px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    transition: all 0.3s var(--ease);
  }

  .phase-card:hover {
    background: var(--bg-card-hover);
    border-color: var(--border-hover);
  }

  /* ---- Mobile Phase Number (vertical timeline indicator) ---- */
  .phase-number-mobile {
    position: absolute;
    top: 28px;
    right: 28px;
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--amber-dim);
    border: 1px solid rgba(245, 158, 11, 0.2);
    border-radius: 50%;
    font-family: var(--font-heading);
    font-size: 0.8125rem;
    font-weight: 700;
    color: var(--amber);
  }

  /* ---- Phase Header ---- */
  .phase-header {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
  }

  .phase-badge {
    display: inline-flex;
    align-items: center;
    padding: 4px 12px;
    background: var(--amber-dim);
    border: 1px solid rgba(245, 158, 11, 0.2);
    border-radius: 100px;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--amber);
  }

  .phase-duration {
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--text-dim);
  }

  .phase-title {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 600;
    line-height: 1.3;
    letter-spacing: -0.01em;
  }

  /* ---- Task List ---- */
  .phase-tasks {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .phase-tasks li {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: 0.9375rem;
    color: var(--text-muted);
    line-height: 1.5;
  }

  .phase-tasks li svg {
    flex-shrink: 0;
    color: var(--amber);
    margin-top: 3px;
    opacity: 0.7;
  }

  /* ---- Deliverable Badge ---- */
  .phase-deliverable {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 16px;
    background: rgba(245, 158, 11, 0.04);
    border: 1px solid rgba(245, 158, 11, 0.12);
    border-radius: var(--radius-sm);
    font-size: 0.8125rem;
    color: var(--text-muted);
    margin-top: auto;
  }

  .phase-deliverable svg {
    color: var(--amber);
    flex-shrink: 0;
    opacity: 0.8;
  }

  .phase-deliverable strong {
    color: var(--text);
    font-weight: 600;
  }

  /* ---- What to Expect Section ---- */
  .expect-section {
    border-top: 1px solid var(--border);
  }

  .expect-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .expect-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 32px 28px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    transition: all 0.3s var(--ease);
  }

  .expect-card:hover {
    background: var(--bg-card-hover);
    border-color: var(--border-hover);
    transform: translateY(-2px);
  }

  .expect-icon {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--amber-dim);
    border-radius: var(--radius-sm);
    color: var(--amber);
    flex-shrink: 0;
  }

  .expect-card h3 {
    font-family: var(--font-heading);
    font-size: 1.125rem;
    font-weight: 600;
    line-height: 1.3;
    letter-spacing: -0.01em;
  }

  .expect-card p {
    font-size: 0.9375rem;
    color: var(--text-muted);
    line-height: 1.7;
  }

  /* ---- Desktop: horizontal timeline + grid ---- */
  @media (min-width: 1024px) {
    .timeline-connector {
      display: flex;
    }

    .phase-number-mobile {
      display: none;
    }

    .phases-grid {
      grid-template-columns: repeat(5, 1fr);
      gap: 16px;
    }

    .phase-card {
      padding: 24px;
    }

    .phase-title {
      font-size: 1.125rem;
    }

    .phase-tasks li {
      font-size: 0.875rem;
    }

    .phase-deliverable {
      font-size: 0.75rem;
      padding: 8px 12px;
    }
  }

  /* ---- Tablet: 2-col + last card full width ---- */
  @media (min-width: 640px) and (max-width: 1023px) {
    .phases-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .phase-card:last-child {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 900px) {
    .expect-grid {
      grid-template-columns: 1fr;
      gap: 16px;
    }
  }
</style>
