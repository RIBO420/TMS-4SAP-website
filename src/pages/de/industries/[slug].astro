/* ===================================================================
   Static Paths
   =================================================================== */

export function getStaticPaths() {
  return [
    { params: { slug: 'kunststof' } },
    { params: { slug: 'automotive' } },
    { params: { slug: 'metaalbewerking' } },
    { params: { slug: 'elektronica' } },
  ];
}

/* ===================================================================
   Page Data
   =================================================================== */

const { slug } = Astro.params;
const industry = industriesData.find((i) => i.slug === slug);

if (!industry) {
  return Astro.redirect('/de/industries');
}

const relevantModules = allModules.filter((m) =>
  industry.relevantModuleSlugs.includes(m.slug)
);

// Friendly display name for breadcrumbs
const displayNames: Record<string, string> = {
  kunststof: 'Kunststoffverarbeitung',
  automotive: 'Automobilzulieferer',
  metaalbewerking: 'Metallbearbeitung & Zerspanung',
  elektronica: 'Elektronikfertigung',
};

const displayName = displayNames[slug!] || industry.title;
---

<BaseLayout
  title={`${industry.title} | TMS 4SAP`}
  description={industry.metaDescription}
  lang="de"
>
  <!-- Hero -->
  <section class="ind-hero">
    <div class="ind-hero-bg" aria-hidden="true"></div>
    <div class="container">
      <div class="breadcrumbs-wrap">
        <Breadcrumbs
          items={[
            { label: 'Branchen', href: '/de/industries' },
            { label: displayName, href: `/de/industries/${slug}` },
          ]}
        />
      </div>
      <div class="ind-hero-content" data-animate>
        <span class="section-tag">Branchenlösung</span>
        <h1 class="ind-hero-title">{industry.title}</h1>
        <p class="ind-hero-tagline">{industry.tagline}</p>
        <p class="ind-hero-intro">{industry.intro}</p>
        <div class="ind-hero-actions">
          <a href="/de/demo" class="btn btn-primary btn-lg">Demo buchen</a>
          <a href="/de/contact" class="btn btn-ghost btn-lg">Vertrieb kontaktieren</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Challenges -->
  <section class="section">
    <div class="container">
      <SectionHeader
        tag="Herausforderungen"
        title="Die Probleme,"
