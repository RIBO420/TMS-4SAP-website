---
import BaseLayout from '@layouts/BaseLayout.astro';
import CTABanner from '@components/ui/CTABanner.astro';
import '@styles/utilities.css';
import { withBase } from '../../../i18n/utils';

const title = 'Impressum';
const lastUpdated = '2026-03-01';
const formattedDate = new Date(lastUpdated).toLocaleDateString('de-DE', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout
  lang="de"
  title="Impressum | TMS 4SAP"
  description="Impressum der TheManufacturingSuite BV. Hier finden Sie unsere Unternehmensdaten, Registrierungsinformationen und rechtliche Hinweise gemäß Impressumspflicht."
>
  <!-- Breadcrumbs -->
  <nav class="container breadcrumbs" aria-label="Breadcrumb">
    <a href={withBase('/de')}>Startseite</a>
    <span class="breadcrumbs-separator" aria-hidden="true">/</span>
    <a href={withBase('/de/legal/impressum')}>Recht</a>
    <span class="breadcrumbs-separator" aria-hidden="true">/</span>
    <span class="breadcrumbs-current" aria-current="page">{title}</span>
  </nav>

  <!-- Legal content -->
  <section class="section legal-section">
    <div class="container">
      <div class="legal-width">
        <!-- Page header -->
        <header class="legal-header">
          <h1>{title}</h1>
          <p class="legal-last-updated">
            Zuletzt aktualisiert: <time datetime={lastUpdated}>{formattedDate}</time>
          </p>
        </header>

        <!-- Prose content -->
        <div class="prose">

          <h2 id="company-details">Angaben gemäß Impressumspflicht</h2>

          <div class="company-info-card">
            <div class="company-info-row">
              <span class="company-info-label">Firmenname</span>
              <span class="company-info-value">TheManufacturingSuite BV</span>
            </div>
            <div class="company-info-row">
              <span class="company-info-label">Adresse</span>
              <span class="company-info-value">
                Il Flore<br />
                Avenue Ceramique 221<br />
                6221 KX, Maastricht<br />
                Niederlande
              </span>
            </div>
            <div class="company-info-row">
              <span class="company-info-label">Telefon</span>
              <span class="company-info-value">
                <a href="tel:+31432340050">+31 43 234 00 50</a>
              </span>
            </div>
            <div class="company-info-row">
              <span class="company-info-label">E-Mail</span>
              <span class="company-info-value">
                <a href="mailto:info@themanufacturingsuite.com">info@themanufacturingsuite.com</a>
              </span>
            </div>
            <div class="company-info-row">
              <span class="company-info-label">Website</span>
              <span class="company-info-value">
                <a href="https://themanufacturingsuite.com">themanufacturingsuite.com</a>
              </span>
            </div>
            <div class="company-info-row">
              <span class="company-info-label">Handelskammer</span>
              <span class="company-info-value">KvK Limburg 14XXXXXX</span>
            </div>
            <div class="company-info-row">
              <span class="company-info-label">USt-IdNr.</span>
              <span class="company-info-value">NL00XXXXXXXXB01</span>
            </div>
            <div class="company-info-row">
              <span class="company-info-label">Geschäftsführer</span>
              <span class="company-info-value">Wird noch bestätigt</span>
            </div>
          </div>

          <h2 id="disclaimer">Haftungsausschluss</h2>

          <h3>Haftung für Inhalte</h3>
          <p>
            Die Inhalte unserer Website wurden mit größter Sorgfalt erstellt. Die TheManufacturingSuite BV kann
            jedoch keine Gewähr für die Richtigkeit, Vollständigkeit oder Aktualität der bereitgestellten
            Informationen übernehmen. Als Diensteanbieter sind wir für eigene Inhalte auf diesen Seiten nach
            den allgemeinen Gesetzen verantwortlich. Wir sind jedoch nicht verpflichtet, übermittelte oder
            gespeicherte fremde Informationen zu überwachen oder nach Umständen zu forschen, die auf eine
            rechtswidrige Tätigkeit hinweisen.
          </p>
          <p>
            Verpflichtungen zur Entfernung oder Sperrung der Nutzung von Informationen nach den allgemeinen
            Gesetzen bleiben hiervon unberührt. Eine diesbezügliche Haftung ist jedoch erst ab dem Zeitpunkt der
            Kenntnis einer konkreten Rechtsverletzung möglich. Bei Bekanntwerden von entsprechenden
            Rechtsverletzungen werden wir diese Inhalte umgehend entfernen.
          </p>

          <h3>Haftung für Links</h3>
          <p>
            Unsere Website kann Links zu externen Websites Dritter enthalten, auf deren Inhalte wir keinen
            Einfluss haben. Deshalb können wir für diese fremden Inhalte keine Gewähr übernehmen. Für die
            Inhalte der verlinkten Seiten ist stets der jeweilige Anbieter oder Betreiber der Seiten
            verantwortlich. Die verlinkten Seiten wurden zum Zeitpunkt der Verlinkung auf mögliche
            Rechtsverstöße überprüft. Rechtswidrige Inhalte waren zum Zeitpunkt der Verlinkung nicht erkennbar.
          </p>
          <p>
            Eine permanente inhaltliche Kontrolle der verlinkten Seiten ist jedoch ohne konkrete Anhaltspunkte
            einer Rechtsverletzung nicht zumutbar. Bei Bekanntwerden von Rechtsverletzungen werden wir derartige
            Links umgehend entfernen.
          </p>

          <h3>Urheberrecht</h3>
          <p>
            Die durch den Seitenbetreiber erstellten Inhalte und Werke auf dieser Website unterliegen dem
            niederländischen Urheberrecht. Die Vervielfältigung, Bearbeitung, Verbreitung und jede Art der
            Verwertung außerhalb der Grenzen des Urheberrechts bedürfen der vorherigen schriftlichen Zustimmung
            der TheManufacturingSuite BV. Downloads und Kopien dieser Seite sind nur für den privaten,
            nicht-kommerziellen Gebrauch gestattet.
          </p>
          <p>
            Soweit die Inhalte auf dieser Seite nicht vom Betreiber erstellt wurden, werden die Urheberrechte
            Dritter beachtet. Insbesondere werden Inhalte Dritter als solche gekennzeichnet. Sollten Sie
            trotzdem auf eine Urheberrechtsverletzung aufmerksam werden, bitten wir um einen entsprechenden
            Hinweis. Bei Bekanntwerden von Rechtsverletzungen werden wir derartige Inhalte umgehend entfernen.
          </p>

          <h2 id="dispute-resolution">Streitbeilegung</h2>
          <p>
            Die Europäische Kommission stellt eine Plattform für die Online-Streitbeilegung (OS) bereit, die
            unter
            <a href="https://ec.europa.eu/consumers/odr" target="_blank" rel="noopener noreferrer">
              https://ec.europa.eu/consumers/odr
            </a> zu finden ist. Wir sind weder bereit noch verpflichtet, an Streitbeilegungsverfahren vor
            einer Verbraucherschlichtungsstelle teilzunehmen.
          </p>

          <h2 id="copyright-notice">Urheberrechtshinweis</h2>
          <p>
            &copy; {new Date().getFullYear()} TheManufacturingSuite BV. Alle Rechte vorbehalten.
          </p>
          <p>
            TMS, TMS 4SAP und das TMS-Logo sind eingetragene Marken der TheManufacturingSuite BV. SAP und SAP
            Business One sind Marken oder eingetragene Marken der SAP SE in Deutschland und anderen Ländern. Alle
            anderen Produktnamen, Logos und Marken sind Eigentum ihrer jeweiligen Inhaber und werden auf dieser
            Website nur zu Identifikationszwecken verwendet. Die Verwendung dieser Namen, Logos und Marken
            bedeutet keine Billigung.
          </p>

        </div>
      </div>
    </div>
  </section>

  <!-- CTA Banner -->
  <CTABanner
    title="Möchten Sie mehr über"
    titleAccent="TMS 4SAP erfahren?"
    description="Entdecken Sie, wie unsere Fertigungssoftware-Lösungen Ihre Produktionsabläufe optimieren können. Nehmen Sie noch heute Kontakt mit unserem Team auf."
    primaryCTA={{ label: 'Kontakt aufnehmen', href: withBase('/de/contact') }}
    secondaryCTA={{ label: 'Module ansehen', href: withBase('/de/modules') }}
  />
</BaseLayout>

<style>
  .legal-section {
    padding-top: clamp(1rem, 2vw, 2rem);
  }

  .company-info-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: clamp(1.5rem, 3vw, 2rem);
    margin-top: 1.5em;
  }

  .company-info-row {
    display: flex;
    gap: 16px;
    padding: 14px 0;
    border-bottom: 1px solid var(--border);
  }

  .company-info-row:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .company-info-row:first-child {
    padding-top: 0;
  }

  .company-info-label {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--text-dim);
    min-width: 180px;
    flex-shrink: 0;
    font-family: var(--font-heading);
    letter-spacing: -0.01em;
  }

  .company-info-value {
    font-size: 0.9375rem;
    color: var(--text-muted);
    line-height: 1.5;
  }

  .company-info-value a {
    color: var(--amber);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color 0.2s var(--ease);
  }

  .company-info-value a:hover {
    color: var(--amber-hover);
  }

  @media (max-width: 600px) {
    .company-info-row {
      flex-direction: column;
      gap: 4px;
    }

    .company-info-label {
      min-width: auto;
    }
  }
</style>
