---
import BaseLayout from '@layouts/BaseLayout.astro';
import HeroInner from '@components/ui/HeroInner.astro';
import SectionHeader from '@components/ui/SectionHeader.astro';
import CTABanner from '@components/ui/CTABanner.astro';
import { withBase } from '../../i18n/utils';

const breadcrumbs = [
  { label: 'Startseite', href: withBase('/de/') },
  { label: 'Partner', href: withBase('/de/partners') },
];

type PartnerTier = 'Gold' | 'Silver' | 'Technology';

interface Partner {
  name: string;
  tier: PartnerTier;
  country: string;
  city: string;
  description: string;
  specialties: string[];
}

const partnerTiers: { tier: PartnerTier; title: string; description: string }[] = [
  {
    tier: 'Gold',
    title: 'Gold-Partner',
    description: 'Vollständige Implementierungskompetenz. Gold-Partner liefern End-to-End-TMS-Einführungen, von der Erstbewertung über den Go-Live bis zum langfristigen Support. Sie verfügen über das höchste Zertifizierungsniveau und können alle Module implementieren.',
  },
  {
    tier: 'Silver',
    title: 'Silver-Partner',
    description: 'Modulspezifische Expertise. Silver-Partner sind auf bestimmte TMS-Module oder Funktionsbereiche spezialisiert und liefern tiefgehendes Wissen und nachgewiesene Erfolge in ihren Schwerpunktbereichen.',
  },
  {
    tier: 'Technology',
    title: 'Technologie-Partner',
    description: 'Integration und Konnektivität. Technologie-Partner erweitern das TMS-Ökosystem durch Systemintegration, IoT-Konnektivität, Cloud-Infrastruktur und ergänzende Technologielösungen.',
  },
];

const partners: Partner[] = [
  {
    name: 'G3G Consulting',
    tier: 'Gold',
    country: 'Niederlande',
    city: 'Maastricht',
    description: 'Vollständiger SAP Business One- und TMS-Implementierungspartner mit 12 Jahren Fertigungsexpertise. Spezialisiert auf diskrete und prozessorientierte Fertigungsbranchen in der Benelux-Region.',
    specialties: ['SAP B1', 'Gesamte TMS Suite', 'Go-Live Support'],
  },
  {
    name: 'DigiFactory Solutions',
    tier: 'Gold',
    country: 'Deutschland',
    city: 'Düsseldorf',
    description: 'Digitalisierungsunternehmen für die Fertigung, das mittelständische Hersteller beim Umstieg von Legacy-Systemen auf integrierte TMS- und SAP-Umgebungen unterstützt. Starker Fokus auf Change Management und Benutzerakzeptanz.',
    specialties: ['Digitale Transformation', 'MES', 'Schulung'],
  },
  {
    name: 'SAP Experts BV',
    tier: 'Silver',
    country: 'Belgien',
    city: 'Antwerpen',
    description: 'SAP Business One-Spezialisten mit zertifizierten TMS-Beratern für Planungs- und Steuerungsmodule. Bewährte Methodik für schnelle Einführungen in der Automobil- und Elektronikbranche.',
    specialties: ['PPS', 'APS', 'SAP B1 Add-ons'],
  },
  {
    name: 'ProMES Integration',
    tier: 'Silver',
    country: 'Niederlande',
    city: 'Eindhoven',
    description: 'MES- und Shopfloor-Systemintegrator, der die Brücke zwischen ERP und Betriebstechnik schlägt. Expertise in Maschinenanbindung, Datenerfassungsterminals und Echtzeit-Produktionsüberwachung.',
    specialties: ['MES', 'BDE', 'Shopfloor-IT'],
  },
  {
    name: 'QualityFirst GmbH',
    tier: 'Silver',
    country: 'Deutschland',
    city: 'Stuttgart',
    description: 'Qualitätsmanagement-Beratung mit Fokus auf IATF 16949- und ISO 9001-Compliance. Implementiert TMS-Qualitätsmanagement- und Dokumentenmanagement-Module für Automobilzulieferer.',
    specialties: ['QM', 'DMS', 'IATF 16949'],
  },
  {
    name: 'TechBridge Partners',
    tier: 'Technology',
    country: 'Niederlande',
    city: 'Amsterdam',
    description: 'Systemintegrationsunternehmen, das TMS mit PLM-, CAD- und ERP-Drittanbieterplattformen verbindet. Entwickelt individuelle Konnektoren, API-Integrationen und Datenpipelines für Fertigungsumgebungen.',
    specialties: ['API-Integration', 'PLM', 'Datenmigration'],
  },
  {
    name: 'IndustryConnect',
    tier: 'Technology',
    country: 'Deutschland',
    city: 'München',
    description: 'IoT- und Maschinenkonnektivitäts-Anbieter für die Echtzeit-Datenerfassung von CNC-Maschinen, SPSen und Sensoren. Liefert die Hardware- und Middleware-Schicht, die TMS MES und BDE speist.',
    specialties: ['IoT', 'OPC-UA', 'Maschinenkonnektivität'],
  },
  {
    name: 'CloudManufacturing AG',
    tier: 'Technology',
    country: 'Schweiz',
    city: 'Zürich',
    description: 'Cloud-Infrastruktur und Managed Services für Fertigungs-IT. Bietet sicheres Hosting, Disaster Recovery und Leistungsoptimierung für TMS- und SAP Business One-Umgebungen.',
    specialties: ['Cloud Hosting', 'Sicherheit', 'Managed Services'],
  },
];

const tierColors: Record<PartnerTier, string> = {
  Gold: 'tier-gold',
  Silver: 'tier-silver',
  Technology: 'tier-tech',
};
---

<BaseLayout
  lang="de"
  title="Partner | TMS 4SAP"
  description="Finden Sie einen zertifizierten TMS-Integrator in Ihrer Nähe. Unser Partnernetzwerk erstreckt sich über Benelux, DACH und darüber hinaus mit Gold-, Silver- und Technologie-Partnern."
>
  <HeroInner
    breadcrumbs={breadcrumbs}
    tag="Partnernetzwerk"
    title="Partner-"
    titleAccent="netzwerk"
    description="Finden Sie einen zertifizierten TMS-Integrator in Ihrer Nähe. Unser Partner-Ökosystem vereint Implementierungsexperten, Fachspezialisten und Technologieanbieter."
  />

  <!-- Partner Tiers Explanation -->
  <section class="section tiers-section">
    <div class="container">
      <SectionHeader
        tag="Partnerstufen"
        title="Drei Stufen der"
        titleAccent="Expertise"
        description="Unser abgestuftes Partnerprogramm stellt sicher, dass Sie den richtigen Partner für Ihren Projektumfang und Ihre technischen Anforderungen finden."
      />
      <div class="tiers-grid">
        {partnerTiers.map((pt) => (
          <div class:list={['tier-card', tierColors[pt.tier]]} data-animate>
            <div class="tier-badge-wrapper">
              <span class:list={['tier-badge', tierColors[pt.tier]]}>
                {pt.tier === 'Gold' && (
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"/>
                    <path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"/>
                    <path d="M4 22h16"/>
                    <path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"/>
                    <path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"/>
                    <path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"/>
                  </svg>
                )}
                {pt.tier === 'Silver' && (
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M12 2 2 7l10 5 10-5-10-5Z"/>
                    <path d="m2 17 10 5 10-5"/>
                    <path d="m2 12 10 5 10-5"/>
                  </svg>
                )}
                {pt.tier === 'Technology' && (
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/>
                    <path d="m2 12 10-5 10 5"/>
                    <path d="m2 12 10 5 10-5"/>
                    <path d="M12 2v20"/>
                  </svg>
                )}
                {pt.tier}
              </span>
            </div>
            <h3 class="tier-title">{pt.title}</h3>
            <p class="tier-desc">{pt.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Partner Directory -->
  <section class="section partners-directory-section">
    <div class="container">
      <SectionHeader
        tag="Verzeichnis"
        title="Unsere zertifizierten"
        titleAccent="Partner"
        description="Jeder Partner wird geprüft, geschult und zertifiziert, um TMS-Implementierungen zu liefern, die unseren Qualitätsstandards entsprechen."
      />
      <div class="partners-grid" role="list" aria-label="Partnerverzeichnis">
        {partners.map((partner) => (
          <article class:list={['partner-card', tierColors[partner.tier]]} data-animate role="listitem">
            <div class="partner-card-header">
              <span class:list={['partner-tier-badge', tierColors[partner.tier]]}>
                {partner.tier}
              </span>
              <span class="partner-location">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/>
                  <circle cx="12" cy="10" r="3"/>
                </svg>
                {partner.city}, {partner.country}
              </span>
            </div>
            <h3 class="partner-name">{partner.name}</h3>
            <p class="partner-desc">{partner.description}</p>
            <div class="partner-specialties">
              {partner.specialties.map((spec) => (
                <span class="specialty-tag">{spec}</span>
              ))}
            </div>
            <a href={withBase(`/de/contact?partner=${encodeURIComponent(partner.name)}`)} class="btn btn-ghost btn-sm partner-cta">
              Partner kontaktieren
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M5 12h14"/>
                <path d="m12 5 7 7-7 7"/>
              </svg>
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Become a Partner -->
  <section class="section become-partner-section">
    <div class="container">
      <div class="become-partner-card" data-animate>
        <div class="become-partner-content">
          <span class="section-tag">Unserem Netzwerk beitreten</span>
          <h2 class="become-partner-title">Werden Sie <span class="text-amber">TMS-Partner</span></h2>
          <p class="become-partner-desc">
            Sind Sie ein Beratungsunternehmen, Systemintegrator oder Technologieanbieter im Fertigungssektor?
            Treten Sie unserem Partnerprogramm bei und erhalten Sie Zugang zu Zertifizierungsschulungen, Co-Marketing-Ressourcen, Lead-Sharing
            und dediziertem Partner-Support. Wir erweitern aktiv unser Netzwerk in ganz Europa.
          </p>
          <div class="become-partner-benefits">
            <div class="benefit-item">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
                <polyline points="22 4 12 14.01 9 11.01"/>
              </svg>
              <span>Zertifizierungs- und Schulungsprogramm</span>
            </div>
            <div class="benefit-item">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
                <polyline points="22 4 12 14.01 9 11.01"/>
              </svg>
              <span>Lead-Vermittlung und Co-Selling</span>
            </div>
            <div class="benefit-item">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
                <polyline points="22 4 12 14.01 9 11.01"/>
              </svg>
              <span>Marketing- und Demo-Ressourcen</span>
            </div>
            <div class="benefit-item">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
                <polyline points="22 4 12 14.01 9 11.01"/>
              </svg>
              <span>Dediziertes Partner-Support-Portal</span>
            </div>
          </div>
          <a href={withBase('/de/contact?subject=Partnership')} class="btn btn-primary btn-lg">
            Für Partnerprogramm bewerben
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M5 12h14"/>
              <path d="m12 5 7 7-7 7"/>
            </svg>
          </a>
        </div>
        <div class="become-partner-visual" aria-hidden="true">
          <div class="network-visual">
            <div class="network-node node-center">
              <span>TMS</span>
            </div>
            <div class="network-node node-1">
              <span>Gold</span>
            </div>
            <div class="network-node node-2">
              <span>Silver</span>
            </div>
            <div class="network-node node-3">
              <span>Tech</span>
            </div>
            <div class="network-line line-1"></div>
            <div class="network-line line-2"></div>
            <div class="network-line line-3"></div>
            <div class="network-ring ring-1"></div>
            <div class="network-ring ring-2"></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <CTABanner
    title="Bereit"
    titleAccent="loszulegen?"
    description="Ob Sie einen Partner suchen oder selbst einer werden möchten — wir sind für Sie da. Kontaktieren Sie noch heute unser Team."
    primaryCTA={{ label: 'Demo buchen', href: withBase('/de/demo') }}
    secondaryCTA={{ label: 'Kontaktieren Sie uns', href: withBase('/de/contact') }}
  />
</BaseLayout>

<style>
  /* --- Tier Cards --- */
  .tiers-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .tier-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 32px 28px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    transition: all 0.3s var(--ease);
  }

  .tier-card:hover {
    background: var(--bg-card-hover);
    border-color: var(--border-hover);
  }

  .tier-card.tier-gold {
    border-top: 3px solid var(--amber);
  }

  .tier-card.tier-silver {
    border-top: 3px solid var(--text-dim);
  }

  .tier-card.tier-tech {
    border-top: 3px solid #3b82f6;
  }

  .tier-badge-wrapper {
    display: flex;
  }

  .tier-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 4px 12px;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    border-radius: 100px;
  }

  .tier-badge.tier-gold {
    color: var(--amber);
    background: var(--amber-dim);
    border: 1px solid rgba(245, 158, 11, 0.15);
  }

  .tier-badge.tier-silver {
    color: var(--text-muted);
    background: rgba(161, 161, 170, 0.08);
    border: 1px solid rgba(161, 161, 170, 0.15);
  }

  .tier-badge.tier-tech {
    color: #3b82f6;
    background: rgba(59, 130, 246, 0.08);
    border: 1px solid rgba(59, 130, 246, 0.15);
  }

  .tier-title {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 600;
    line-height: 1.3;
    color: var(--text);
  }

  .tier-desc {
    font-size: 0.9375rem;
    color: var(--text-muted);
    line-height: 1.7;
  }

  /* --- Partners Directory Grid --- */
  .partners-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
  }

  /* --- Partner Card --- */
  .partner-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 28px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    transition: all 0.3s var(--ease);
  }

  .partner-card:hover {
    background: var(--bg-card-hover);
    border-color: var(--border-hover);
    transform: translateY(-2px);
  }

  .partner-card.tier-gold:hover {
    border-color: rgba(245, 158, 11, 0.3);
  }

  .partner-card.tier-tech:hover {
    border-color: rgba(59, 130, 246, 0.3);
  }

  .partner-card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 8px;
  }

  .partner-tier-badge {
    display: inline-flex;
    align-items: center;
    padding: 3px 10px;
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    border-radius: 100px;
  }

  .partner-tier-badge.tier-gold {
    color: var(--amber);
    background: var(--amber-dim);
    border: 1px solid rgba(245, 158, 11, 0.15);
  }

  .partner-tier-badge.tier-silver {
    color: var(--text-muted);
    background: rgba(161, 161, 170, 0.08);
    border: 1px solid rgba(161, 161, 170, 0.15);
  }

  .partner-tier-badge.tier-tech {
    color: #3b82f6;
    background: rgba(59, 130, 246, 0.08);
    border: 1px solid rgba(59, 130, 246, 0.15);
  }

  .partner-location {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: 0.8125rem;
    color: var(--text-dim);
  }

  .partner-name {
    font-family: var(--font-heading);
    font-size: 1.125rem;
    font-weight: 600;
    line-height: 1.3;
    color: var(--text);
  }

  .partner-desc {
    font-size: 0.9375rem;
    color: var(--text-muted);
    line-height: 1.7;
    flex-grow: 1;
  }

  .partner-specialties {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .specialty-tag {
    display: inline-flex;
    align-items: center;
    padding: 3px 10px;
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    color: var(--text-dim);
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: 6px;
  }

  .partner-cta {
    align-self: flex-start;
    margin-top: 4px;
  }

  /* --- Stagger Animations for Partners Grid --- */
  .partners-grid [data-animate]:nth-child(1) { transition-delay: 0ms; }
  .partners-grid [data-animate]:nth-child(2) { transition-delay: 80ms; }
  .partners-grid [data-animate]:nth-child(3) { transition-delay: 160ms; }
  .partners-grid [data-animate]:nth-child(4) { transition-delay: 240ms; }
  .partners-grid [data-animate]:nth-child(5) { transition-delay: 320ms; }
  .partners-grid [data-animate]:nth-child(6) { transition-delay: 400ms; }
  .partners-grid [data-animate]:nth-child(7) { transition-delay: 480ms; }
  .partners-grid [data-animate]:nth-child(8) { transition-delay: 560ms; }

  /* --- Become a Partner Section --- */
  .become-partner-section {
    padding-bottom: 0;
  }

  .become-partner-card {
    display: grid;
    grid-template-columns: 1fr 1fr;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-xl);
    overflow: hidden;
    min-height: 480px;
  }

  .become-partner-content {
    padding: clamp(2.5rem, 4vw, 4rem);
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 16px;
  }

  .become-partner-title {
    font-family: var(--font-heading);
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.02em;
  }

  .become-partner-desc {
    font-size: 1rem;
    color: var(--text-muted);
    line-height: 1.7;
    max-width: 480px;
  }

  .become-partner-benefits {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin: 8px 0;
  }

  .benefit-item {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 0.9375rem;
    color: var(--text-muted);
  }

  .benefit-item svg {
    color: var(--amber);
    flex-shrink: 0;
  }

  /* --- Network Visual (Become a Partner) --- */
  .become-partner-visual {
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, rgba(245, 158, 11, 0.03) 0%, transparent 100%);
    position: relative;
    overflow: hidden;
  }

  .network-visual {
    position: relative;
    width: 280px;
    height: 280px;
  }

  .network-node {
    position: absolute;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 0.6875rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .node-center {
    width: 64px;
    height: 64px;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    background: var(--amber);
    color: #09090B;
    font-size: 0.8125rem;
    z-index: 2;
    box-shadow: 0 0 32px var(--amber-glow), 0 0 64px var(--amber-glow);
  }

  .node-1 {
    width: 48px;
    height: 48px;
    top: 12%;
    left: 50%;
    transform: translateX(-50%);
    background: var(--amber-dim);
    color: var(--amber);
    border: 1px solid rgba(245, 158, 11, 0.2);
  }

  .node-2 {
    width: 48px;
    height: 48px;
    bottom: 18%;
    left: 14%;
    background: rgba(161, 161, 170, 0.08);
    color: var(--text-muted);
    border: 1px solid rgba(161, 161, 170, 0.15);
  }

  .node-3 {
    width: 48px;
    height: 48px;
    bottom: 18%;
    right: 14%;
    background: rgba(59, 130, 246, 0.08);
    color: #3b82f6;
    border: 1px solid rgba(59, 130, 246, 0.15);
  }

  .network-line {
    position: absolute;
    background: var(--border);
    z-index: 1;
  }

  .line-1 {
    width: 1px;
    height: 70px;
    top: calc(12% + 48px);
    left: 50%;
    transform: translateX(-50%);
  }

  .line-2 {
    width: 90px;
    height: 1px;
