---
import BaseLayout from '@layouts/BaseLayout.astro';
import HeroInner from '@components/ui/HeroInner.astro';
import StatBar from '@components/ui/StatBar.astro';
import SectionHeader from '@components/ui/SectionHeader.astro';
import CTABanner from '@components/ui/CTABanner.astro';

const breadcrumbs = [
  { label: 'Startseite', href: '/de/' },
  { label: 'Referenzen', href: '/de/references' },
];

const stats = [
  { value: '500+', label: 'Implementierungen' },
  { value: '98%', label: 'Zufriedenheit' },
  { value: '12', label: 'Länder' },
  { value: '15+', label: 'Jahre' },
];

interface Reference {
  company: string;
  industry: string;
  country: string;
  quote: string;
  modules: string[];
}

const industries = ['Alle', 'Kunststoff', 'Automobil', 'Metallbearbeitung', 'Elektronik'];

const references: Reference[] = [
  {
    company: 'Precision Plastics BV',
    industry: 'Kunststoff',
    country: 'Niederlande',
    quote: 'TMS hat unsere Spritzgussplanung transformiert. Wir sind von Tabellenkalkulationen und Whiteboards zu einem vollständig digitalen Planungsworkflow übergegangen — Zykluszeitoptimierung und Werkzeugwechselplanung sind jetzt automatisiert.',
    modules: ['PPS', 'APS', 'MES'],
  },
  {
    company: 'AutoParts GmbH',
    industry: 'Automobil',
    country: 'Deutschland',
    quote: 'Die IATF 16949-Compliance wurde beherrschbar. TMS Qualitätsmanagement verfolgt jede Prüfung, jede Abweichung und jede Korrekturmaßnahme — Auditoren schätzen die Rückverfolgbarkeit.',
    modules: ['QM', 'PDC', 'BI'],
  },
  {
    company: 'MetalCraft Industries',
    industry: 'Metallbearbeitung',
    country: 'Belgien',
    quote: 'Echtzeit-Auftragskalkulation hat alles verändert. Wir sehen jetzt die tatsächlichen gegenüber den geschätzten Stunden pro Arbeitsauftrag während der Auftragsausführung, nicht erst Wochen nach dem Versand.',
    modules: ['MES', 'PDC', 'PPS', 'BI'],
  },
  {
    company: 'CircuitBoard Systems',
    industry: 'Elektronik',
    country: 'Niederlande',
    quote: 'Bauteilrückverfolgbarkeit auf Rollenebene war für unsere Luft- und Raumfahrtkunden unverhandelbar. TMS gab uns Chargenverfolgung und Genealogie vom Wareneingang bis zur Endprüfung.',
    modules: ['QM', 'PDM', 'MES'],
  },
  {
    company: 'FormTech Kunststoffen',
    industry: 'Kunststoff',
    country: 'Niederlande',
    quote: '40% weniger Planungsaufwand. Unsere Planer verbrachten früher den halben Tag damit, Aufträge und Maschinenzuordnungen zu jonglieren — APS generiert jetzt optimierte Pläne in Minuten.',
    modules: ['APS', 'PPS', 'PDC'],
  },
  {
    company: 'TurboGear Automotive',
    industry: 'Automobil',
    country: 'Deutschland',
    quote: 'Die EDI-Integration hat die manuelle Eingabe eliminiert. Lieferabrufe von OEMs fließen direkt in unsere Planung. Versandanzeigen gehen automatisch zurück. Kein Papier, keine Doppelerfassung.',
    modules: ['PPS', 'APS', 'DMS'],
  },
  {
    company: 'StaalWerk Engineering',
    industry: 'Metallbearbeitung',
    country: 'Niederlande',
    quote: 'Die OEE-Transparenz führte zu einer 15%igen Verbesserung im ersten Jahr. Sobald Bediener die Echtzeit-Leistung auf den Shopfloor-Displays sehen konnten, begannen sie sich selbst zu korrigieren.',
    modules: ['MES', 'BI', 'PDC'],
  },
  {
    company: 'MicroElec BV',
    industry: 'Elektronik',
    country: 'Belgien',
    quote: 'Der BOM-Import aus Altium spart wöchentlich Stunden. Ingenieure entwerfen in ihrem gewohnten Tool, und TMS importiert die vollständige Komponentenliste mit Alternativen und Spezifikationen automatisch.',
    modules: ['PDM', 'VC', 'PPS'],
  },
  {
    company: 'DuraPlast GmbH',
    industry: 'Kunststoff',
    country: 'Deutschland',
    quote: 'Qualitätsmanagement mit vollständiger Chargenrückverfolgung gibt uns absolute Sicherheit. Wenn ein Kunde nach einem bestimmten Los fragt, können wir jedes Rohmaterial, jeden Parameter und jedes Testergebnis in Sekunden aufrufen.',
    modules: ['QM', 'MES', 'DMS', 'BI'],
  },
];

const countryFlags: Record<string, string> = {
  'Niederlande': 'NL',
  'Deutschland': 'DE',
  'Belgien': 'BE',
};
---

<BaseLayout
  lang="de"
  title="Referenzen | TMS 4SAP"
  description="Erfahren Sie, wie über 500 Hersteller in ganz Europa TMS vertrauen, um Produktionsplanung, Qualitätsmanagement und Shopfloor-Ausführung zu digitalisieren."
>
  <HeroInner
    breadcrumbs={breadcrumbs}
    tag="Kundenreferenzen"
    title="Kunden-"
    titleAccent="referenzen"
    description="Erfahren Sie, wie Hersteller in ganz Europa TMS vertrauen, um ihre Produktionsabläufe mit integrierter Planung, Ausführung und Qualitätsmanagement zu transformieren."
  />

  <StatBar stats={stats} />

  <!-- Filter Bar -->
  <section class="filter-section">
    <div class="container">
      <div class="filter-bar" role="toolbar" aria-label="Referenzen nach Branche filtern">
        {industries.map((ind) => (
          <button
            class:list={['filter-btn', { active: ind === 'Alle' }]}
            data-filter={ind}
            aria-pressed={ind === 'Alle' ? 'true' : 'false'}
          >
            {ind}
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- References Grid -->
  <section class="section references-section">
    <div class="container">
      <div class="references-grid" role="list" aria-label="Kundenreferenzen">
        {references.map((ref) => (
          <article
            class="reference-card"
            data-industry={ref.industry}
            data-animate
            role="listitem"
          >
            <div class="reference-header">
              <div class="reference-meta">
                <span class="reference-industry-tag">{ref.industry}</span>
                <span class="reference-country">
                  <span class="country-code">{countryFlags[ref.country]}</span>
                  {ref.country}
                </span>
              </div>
            </div>
            <h3 class="reference-company">{ref.company}</h3>
            <blockquote class="reference-quote">
              <p>&ldquo;{ref.quote}&rdquo;</p>
            </blockquote>
            <div class="reference-modules">
              {ref.modules.map((mod) => (
                <a href={`/de/modules/${mod.toLowerCase()}`} class="module-tag">{mod}</a>
              ))}
            </div>
          </article>
        ))}
      </div>

      <!-- Empty state for filtered results -->
      <div class="empty-state" hidden aria-live="polite">
        <p>Keine Referenzen für die ausgewählte Branche gefunden.</p>
      </div>
    </div>
  </section>

  <CTABanner
    title="Schließen Sie sich über 500 Herstellern an,"
    titleAccent="die sich für TMS entschieden haben"
    description="Erfahren Sie, wie TMS Ihre Produktionsabläufe transformieren kann. Buchen Sie eine persönliche Demo oder sprechen Sie mit unserem Team."
    primaryCTA={{ label: 'Demo buchen', href: '/de/demo' }}
    secondaryCTA={{ label: 'Kontaktieren Sie uns', href: '/de/contact' }}
  />
</BaseLayout>

<style>
  /* --- Filter Section --- */
  .filter-section {
    padding: 32px 0 0;
  }

  .filter-bar {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
    padding: 16px 0;
    border-bottom: 1px solid var(--border);
  }

  .filter-btn {
    display: inline-flex;
    align-items: center;
    padding: 8px 18px;
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text-muted);
    background: transparent;
    border: 1px solid var(--border);
    border-radius: 100px;
    cursor: pointer;
    transition: all 0.2s var(--ease);
    white-space: nowrap;
  }

  .filter-btn:hover {
    color: var(--text);
    border-color: var(--border-hover);
    background: rgba(255, 255, 255, 0.03);
  }

  .filter-btn:focus-visible {
    outline: 2px solid var(--amber);
    outline-offset: 2px;
  }

  .filter-btn.active {
    color: #09090B;
    background: var(--amber);
    border-color: var(--amber);
  }

  .filter-btn.active:hover {
    background: var(--amber-hover);
    border-color: var(--amber-hover);
  }

  /* --- References Grid --- */
  .references-section {
    padding-top: clamp(2rem, 4vw, 3rem);
  }

  .references-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  /* --- Reference Card --- */
  .reference-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 28px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    transition: all 0.3s var(--ease);
  }

  .reference-card:hover {
    background: var(--bg-card-hover);
    border-color: var(--border-hover);
    transform: translateY(-2px);
  }

  .reference-card.hidden {
    display: none;
  }

  .reference-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
  }

  .reference-meta {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
  }

  .reference-industry-tag {
    display: inline-flex;
    align-items: center;
    padding: 3px 10px;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--amber);
    background: var(--amber-dim);
    border: 1px solid rgba(245, 158, 11, 0.15);
    border-radius: 100px;
  }

  .reference-country {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.8125rem;
    color: var(--text-dim);
  }

  .country-code {
    font-family: var(--font-heading);
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    color: var(--text-muted);
    padding: 1px 6px;
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: 4px;
  }

  .reference-company {
    font-family: var(--font-heading);
    font-size: 1.125rem;
    font-weight: 600;
    line-height: 1.3;
    color: var(--text);
  }

  .reference-quote {
    flex-grow: 1;
  }

  .reference-quote p {
    font-size: 0.9375rem;
    color: var(--text-muted);
    line-height: 1.7;
    font-style: italic;
  }

  .reference-modules {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: auto;
    padding-top: 8px;
    border-top: 1px solid var(--border);
  }

  .module-tag {
    display: inline-flex;
    align-items: center;
    padding: 3px 10px;
    font-family: var(--font-heading);
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-dim);
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    text-decoration: none;
    transition: all 0.2s var(--ease);
  }

  .module-tag:hover {
    color: var(--amber);
    border-color: rgba(245, 158, 11, 0.3);
    background: var(--amber-dim);
  }

  /* --- Empty State --- */
  .empty-state {
    text-align: center;
    padding: 4rem 0;
    color: var(--text-dim);
    font-size: 1rem;
  }

  /* --- Stagger Animations --- */
  .references-grid [data-animate]:nth-child(1) { transition-delay: 0ms; }
  .references-grid [data-animate]:nth-child(2) { transition-delay: 80ms; }
  .references-grid [data-animate]:nth-child(3) { transition-delay: 160ms; }
  .references-grid [data-animate]:nth-child(4) { transition-delay: 240ms; }
  .references-grid [data-animate]:nth-child(5) { transition-delay: 320ms; }
  .references-grid [data-animate]:nth-child(6) { transition-delay: 400ms; }
  .references-grid [data-animate]:nth-child(7) { transition-delay: 480ms; }
  .references-grid [data-animate]:nth-child(8) { transition-delay: 560ms; }
  .references-grid [data-animate]:nth-child(9) { transition-delay: 640ms; }

  /* --- Responsive --- */
  @media (max-width: 900px) {
    .references-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .references-grid {
      grid-template-columns: 1fr;
    }

    .filter-bar {
      gap: 6px;
    }

    .filter-btn {
      padding: 6px 14px;
      font-size: 0.8125rem;
    }
  }
</style>

<script>
  function initFilters() {
    const filterBtns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
    const cards = document.querySelectorAll<HTMLElement>('.reference-card');
    const emptyState = document.querySelector<HTMLElement>('.empty-state');

    if (!filterBtns.length || !cards.length) return;

    filterBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        const filter = btn.dataset.filter;
        if (!filter) return;

        // Update active button
        filterBtns.forEach((b) => {
          b.classList.remove('active');
          b.setAttribute('aria-pressed', 'false');
        });
        btn.classList.add('active');
        btn.setAttribute('aria-pressed', 'true');

        // Filter cards
        let visibleCount = 0;
        cards.forEach((card) => {
          const industry = card.dataset.industry;
          const shouldShow = filter === 'Alle' || industry === filter;
          card.classList.toggle('hidden', !shouldShow);
          if (shouldShow) visibleCount++;
        });

        // Toggle empty state
        if (emptyState) {
          emptyState.hidden = visibleCount > 0;
        }
      });
    });
  }

  initFilters();
  document.addEventListener('astro:page-load', initFilters);
</script>
