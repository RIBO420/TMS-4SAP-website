---
import BaseLayout from '@layouts/BaseLayout.astro';
import HeroInner from '@components/ui/HeroInner.astro';
import CTABanner from '@components/ui/CTABanner.astro';
---

<BaseLayout
  lang="de"
  title="ROI-Rechner | TMS 4SAP"
  description="Berechnen Sie den potenziellen Return on Investment durch die Implementierung von TMS 4SAP in Ihrem Fertigungsbetrieb. Schätzen Sie Einsparungen durch Planungseffizienz, Fehlerreduzierung und Automatisierung."
>
  <HeroInner
    breadcrumbs={[
      { label: 'Startseite', href: '/de' },
      { label: 'ROI-Rechner', href: '/de/roi-calculator' },
    ]}
    tag="ROI-Rechner"
    title="Berechnen Sie Ihren"
    titleAccent="ROI"
    description="Sehen Sie die potenzielle Wirkung von TMS auf Ihre Fertigungsabläufe"
  />

  <section class="roi-section section">
    <div class="container">
      <div class="roi-grid">

        <!-- LEFT: Input form -->
        <div class="roi-inputs" data-animate>
          <div class="roi-inputs-card">
            <h2 class="roi-inputs-title">Ihr Betrieb</h2>
            <p class="roi-inputs-subtitle">Passen Sie die Regler an Ihre aktuelle Situation an</p>

            <div class="roi-form" role="form" aria-label="ROI-Rechner Eingaben">

              <!-- Company Size -->
              <div class="roi-field">
                <div class="roi-field-header">
                  <label for="employees" class="roi-label">Unternehmensgröße</label>
                  <output for="employees" class="roi-value" id="employees-value">50 Mitarbeiter</output>
                </div>
                <input
                  type="range"
                  id="employees"
                  name="employees"
                  min="10"
                  max="500"
                  value="50"
                  step="10"
                  class="roi-slider"
                  aria-describedby="employees-value"
                />
                <div class="roi-range-labels" aria-hidden="true">
                  <span>10</span>
                  <span>500</span>
                </div>
              </div>

              <!-- Annual Revenue -->
              <div class="roi-field">
                <div class="roi-field-header">
                  <label for="revenue" class="roi-label">Jahresumsatz</label>
                  <output for="revenue" class="roi-value" id="revenue-value">&euro;10 Mio.</output>
                </div>
                <input
                  type="range"
                  id="revenue"
                  name="revenue"
                  min="1"
                  max="100"
                  value="10"
                  step="1"
                  class="roi-slider"
                  aria-describedby="revenue-value"
                />
                <div class="roi-range-labels" aria-hidden="true">
                  <span>&euro;1 Mio.</span>
                  <span>&euro;100 Mio.</span>
                </div>
              </div>

              <!-- Current Planning Method -->
              <fieldset class="roi-field roi-radio-group">
                <legend class="roi-label">Aktuelle Planungsmethode</legend>
                <div class="roi-radio-options">
                  <label class="roi-radio">
                    <input type="radio" name="planning" value="manual" />
                    <span class="roi-radio-control" aria-hidden="true"></span>
                    <span class="roi-radio-text">Manuell</span>
                  </label>
                  <label class="roi-radio">
                    <input type="radio" name="planning" value="spreadsheet" checked />
                    <span class="roi-radio-control" aria-hidden="true"></span>
                    <span class="roi-radio-text">Tabellenkalkulation</span>
                  </label>
                  <label class="roi-radio">
                    <input type="radio" name="planning" value="basic-erp" />
                    <span class="roi-radio-control" aria-hidden="true"></span>
                    <span class="roi-radio-text">Basis-ERP</span>
                  </label>
                  <label class="roi-radio">
                    <input type="radio" name="planning" value="advanced-erp" />
                    <span class="roi-radio-control" aria-hidden="true"></span>
                    <span class="roi-radio-text">Erweitertes ERP</span>
                  </label>
                </div>
              </fieldset>

              <!-- Production Errors Rate -->
              <div class="roi-field">
                <div class="roi-field-header">
                  <label for="errors" class="roi-label">Produktionsfehlerquote</label>
                  <output for="errors" class="roi-value" id="errors-value">5%</output>
                </div>
                <input
                  type="range"
                  id="errors"
                  name="errors"
                  min="1"
                  max="15"
                  value="5"
                  step="0.5"
                  class="roi-slider"
                  aria-describedby="errors-value"
                />
                <div class="roi-range-labels" aria-hidden="true">
                  <span>1%</span>
                  <span>15%</span>
                </div>
              </div>

              <!-- Manual Data Entry Hours/Week -->
              <div class="roi-field">
                <div class="roi-field-header">
                  <label for="manual-hours" class="roi-label">Manuelle Dateneingabe</label>
                  <output for="manual-hours" class="roi-value" id="manual-hours-value">20 Std./Woche</output>
                </div>
                <input
                  type="range"
                  id="manual-hours"
                  name="manual-hours"
                  min="5"
                  max="80"
                  value="20"
                  step="5"
                  class="roi-slider"
                  aria-describedby="manual-hours-value"
                />
                <div class="roi-range-labels" aria-hidden="true">
                  <span>5 Std.</span>
                  <span>80 Std.</span>
                </div>
              </div>

            </div>
          </div>
        </div>

        <!-- RIGHT: Results card -->
        <div class="roi-results-wrapper" data-animate>
          <div class="roi-results-card">
            <div class="roi-results-header">
              <span class="roi-results-tag">Geschätzte jährliche Einsparungen</span>
              <div class="roi-savings-amount" aria-live="polite" aria-atomic="true">
                <span class="roi-currency">&euro;</span><span id="total-savings" class="roi-total">0</span>
              </div>
              <p class="roi-savings-note">Basierend auf Branchenbenchmarks und TMS-Implementierungsdaten</p>
            </div>

            <div class="roi-breakdown">
              <h3 class="roi-breakdown-title">Einsparungsaufschlüsselung</h3>

              <div class="roi-breakdown-item">
                <div class="roi-breakdown-row">
                  <div class="roi-breakdown-icon" aria-hidden="true">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
                    </svg>
                  </div>
                  <span class="roi-breakdown-label">Planungseffizienz</span>
                </div>
                <span class="roi-breakdown-value" id="planning-savings">&euro;0</span>
              </div>

              <div class="roi-breakdown-item">
                <div class="roi-breakdown-row">
                  <div class="roi-breakdown-icon" aria-hidden="true">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/>
                    </svg>
                  </div>
                  <span class="roi-breakdown-label">Fehlerreduzierung</span>
                </div>
                <span class="roi-breakdown-value" id="error-savings">&euro;0</span>
              </div>

              <div class="roi-breakdown-item">
                <div class="roi-breakdown-row">
                  <div class="roi-breakdown-icon" aria-hidden="true">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/>
                    </svg>
                  </div>
                  <span class="roi-breakdown-label">Wegfall manueller Eingabe</span>
                </div>
                <span class="roi-breakdown-value" id="manual-savings">&euro;0</span>
              </div>
            </div>

            <div class="roi-timeline">
              <div class="roi-timeline-icon" aria-hidden="true">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/>
                  <polyline points="17 6 23 6 23 12"/>
                </svg>
              </div>
              <div>
                <span class="roi-timeline-label">Typische Amortisationszeit</span>
                <span class="roi-timeline-value">8 - 14 Monate</span>
              </div>
            </div>

            <a href="/de/demo" class="btn btn-primary btn-lg btn-full roi-results-cta">
              Individuelle Bewertung erhalten
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="5" y1="12" x2="19" y2="12" />
                <polyline points="12 5 19 12 12 19" />
              </svg>
            </a>
          </div>

          <!-- Methodology note -->
          <p class="roi-disclaimer">
            Diese Schätzungen basieren auf Branchendurchschnitten von Fertigungsunternehmen, die TMS 4SAP implementiert haben. Ihre tatsächlichen Ergebnisse können abweichen. Kontaktieren Sie uns für eine detaillierte, individuelle ROI-Analyse.
          </p>
        </div>

      </div>
    </div>
  </section>

  <!-- How we calculate section -->
  <section class="roi-methodology section">
    <div class="container">
      <div class="section-header">
        <span class="section-tag">Methodik</span>
        <h2>So berechnen wir <span class="text-amber">Ihre Einsparungen</span></h2>
        <p class="section-desc">Unser ROI-Modell basiert auf gemessenen Ergebnissen aus Hunderten von TMS-Implementierungen in der Fertigungsindustrie.</p>
      </div>

      <div class="method-grid">
        <div class="method-card" data-animate>
          <div class="method-icon" aria-hidden="true">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
            </svg>
          </div>
          <h3>Planungseffizienz</h3>
          <p>Gemessen an Zeiteinsparungen bei Produktionsplanung, Auftragsverwaltung und Ressourcenzuordnung. Größere Teams sehen proportional größere Verbesserungen durch die Reduzierung des Koordinationsaufwands.</p>
        </div>

        <div class="method-card" data-animate>
          <div class="method-icon" aria-hidden="true">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/>
            </svg>
          </div>
          <h3>Fehlerreduzierung</h3>
          <p>Basierend auf der Korrelation zwischen Produktionsfehlerquoten und Umsatzverlust. Qualitätsmanagement und Echtzeitüberwachung reduzieren fehlerbedingte Kosten typischerweise um 40-60%.</p>
        </div>

        <div class="method-card" data-animate>
          <div class="method-icon" aria-hidden="true">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/>
            </svg>
          </div>
          <h3>Automatisierungseinsparungen</h3>
          <p>Berechnet aus eliminierten manuellen Dateneingabestunden, bewertet zu durchschnittlichen Mischarbeitskosten. MES- und BDE-Module automatisieren typischerweise 70-85% der manuellen Datenerfassungsaufgaben.</p>
        </div>
      </div>
    </div>
  </section>

  <CTABanner
    title="Möchten Sie eine detaillierte"
    titleAccent="ROI-Analyse?"
    description="Unsere Fertigungsberater können einen maßgeschneiderten Business Case basierend auf Ihren spezifischen Abläufen, Prozessen und Verbesserungszielen erstellen."
    primaryCTA={{ label: 'Demo buchen', href: '/de/demo' }}
    secondaryCTA={{ label: 'Broschüre herunterladen', href: '/de/downloads' }}
  />
</BaseLayout>

<script>
  function initROICalculator() {
    // Elements
    const employeesSlider = document.getElementById('employees') as HTMLInputElement | null;
    const revenueSlider = document.getElementById('revenue') as HTMLInputElement | null;
    const errorsSlider = document.getElementById('errors') as HTMLInputElement | null;
    const manualHoursSlider = document.getElementById('manual-hours') as HTMLInputElement | null;
    const planningRadios = document.querySelectorAll<HTMLInputElement>('input[name="planning"]');

    const employeesOutput = document.getElementById('employees-value');
    const revenueOutput = document.getElementById('revenue-value');
    const errorsOutput = document.getElementById('errors-value');
    const manualHoursOutput = document.getElementById('manual-hours-value');

    const totalSavingsEl = document.getElementById('total-savings');
    const planningSavingsEl = document.getElementById('planning-savings');
    const errorSavingsEl = document.getElementById('error-savings');
    const manualSavingsEl = document.getElementById('manual-savings');

    if (
      !employeesSlider || !revenueSlider || !errorsSlider || !manualHoursSlider ||
      !totalSavingsEl || !planningSavingsEl || !errorSavingsEl || !manualSavingsEl
    ) {
      return;
    }

    // Planning method multipliers
    const planningMultipliers: Record<string, number> = {
      'manual': 1.5,
      'spreadsheet': 1.2,
      'basic-erp': 1.0,
      'advanced-erp': 0.7,
    };

    function getSelectedPlanning(): string {
      const checked = document.querySelector<HTMLInputElement>('input[name="planning"]:checked');
      return checked?.value || 'spreadsheet';
    }

    function formatCurrency(value: number): string {
      if (value >= 1_000_000) {
        return new Intl.NumberFormat('de-DE', {
          minimumFractionDigits: 0,
          maximumFractionDigits: 0,
        }).format(Math.round(value));
      }
      return new Intl.NumberFormat('de-DE', {
        minimumFractionDigits: 0,
        maximumFractionDigits: 0,
      }).format(Math.round(value));
    }

    // Animate number changes
    let animationFrame: number | null = null;
    let currentDisplayValue = 0;

    function animateValue(target: number) {
      if (animationFrame) cancelAnimationFrame(animationFrame);

      const startValue = currentDisplayValue;
      const diff = target - startValue;
      const duration = 400;
      const startTime = performance.now();

      function step(timestamp: number) {
        const elapsed = timestamp - startTime;
        const progress = Math.min(elapsed / duration, 1);
        // Ease out cubic
        const eased = 1 - Math.pow(1 - progress, 3);
        currentDisplayValue = startValue + diff * eased;

        if (totalSavingsEl) {
          totalSavingsEl.textContent = formatCurrency(currentDisplayValue);
        }

        if (progress < 1) {
          animationFrame = requestAnimationFrame(step);
        } else {
          currentDisplayValue = target;
          if (totalSavingsEl) {
            totalSavingsEl.textContent = formatCurrency(target);
          }
        }
      }

      animationFrame = requestAnimationFrame(step);
    }

    function updateSliderFill(slider: HTMLInputElement) {
      const min = parseFloat(slider.min);
      const max = parseFloat(slider.max);
      const val = parseFloat(slider.value);
      const percentage = ((val - min) / (max - min)) * 100;
      slider.style.setProperty('--slider-fill', `${percentage}%`);
    }

    function calculate() {
      const employees = parseInt(employeesSlider!.value, 10);
      const revenueM = parseInt(revenueSlider!.value, 10);
      const revenue = revenueM * 1_000_000;
      const errorRate = parseFloat(errorsSlider!.value) / 100;
      const manualHours = parseInt(manualHoursSlider!.value, 10);
      const planningMethod = getSelectedPlanning();
      const multiplier = planningMultipliers[planningMethod] || 1;

      // Update output labels
      if (employeesOutput) employeesOutput.textContent = `${employees} Mitarbeiter`;
      if (revenueOutput) revenueOutput.textContent = `\u20AC${revenueM} Mio.`;
      if (errorsOutput) errorsOutput.textContent = `${errorsSlider!.value}%`;
      if (manualHoursOutput) manualHoursOutput.textContent = `${manualHours} Std./Woche`;

      // Update slider fills
      updateSliderFill(employeesSlider!);
      updateSliderFill(revenueSlider!);
      updateSliderFill(errorsSlider!);
      updateSliderFill(manualHoursSlider!);

      // Calculate savings
      // Planning efficiency: employees * 2000 * multiplier
      const planningSavings = employees * 2000 * multiplier;

      // Error reduction: errorRate * revenue * 0.01
      const errorSavings = errorRate * revenue * 0.01;

      // Manual entry elimination: manualHours * 50 * 48
      const manualEntrySavings = manualHours * 50 * 48;

      // Total: employees * 2000 + revenue * 0.02 + errorRate * revenue * 0.01 + manualHours * 50 * 48
      // Using the multiplier to modulate planning savings
      const total = planningSavings + (revenue * 0.02) + errorSavings + manualEntrySavings;

      // Update breakdown
      if (planningSavingsEl) planningSavingsEl.textContent = `\u20AC${formatCurrency(planningSavings + revenue * 0.02)}`;
      if (errorSavingsEl) errorSavingsEl.textContent = `\u20AC${formatCurrency(errorSavings)}`;
      if (manualSavingsEl) manualSavingsEl.textContent = `\u20AC${formatCurrency(manualEntrySavings)}`;

      // Animate total
      animateValue(total);
    }

    // Bind events
    const sliders = [employeesSlider, revenueSlider, errorsSlider, manualHoursSlider];
    sliders.forEach((slider) => {
      if (slider) {
        slider.addEventListener('input', calculate);
      }
    });

    planningRadios.forEach((radio) => {
      radio.addEventListener('change', calculate);
    });

    // Initial calculation
    calculate();
  }

  initROICalculator();
  document.addEventListener('astro:page-load', initROICalculator);
</script>

<style>
  /* ============================================
     ROI SECTION LAYOUT
     ============================================ */
  .roi-section {
    padding-top: 0;
  }

  .roi-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2rem, 4vw, 3rem);
    align-items: start;
  }

  /* ============================================
     INPUTS CARD
     ============================================ */
  .roi-inputs-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-xl);
    padding: clamp(1.5rem, 3vw, 2.5rem);
  }

  .roi-inputs-title {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 4px;
  }

  .roi-inputs-subtitle {
    font-size: 0.9375rem;
    color: var(--text-muted);
    margin-bottom: 32px;
  }

  .roi-form {
    display: flex;
    flex-direction: column;
    gap: 28px;
  }

  /* ============================================
     FORM FIELDS
     ============================================ */
  .roi-field {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .roi-field-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }

  .roi-label {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--text);
  }

  .roi-value {
    font-family: var(--font-heading);
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--amber);
    background: var(--amber-dim);
    padding: 3px 10px;
    border-radius: 100px;
    border: 1px solid rgba(245, 158, 11, 0.15);
  }

  /* ============================================
     RANGE SLIDER
     ============================================ */
  .roi-slider {
    -webkit-appearance: none;
    appearance: none;
    width: 100%;
    height: 6px;
    border-radius: 3px;
    outline: none;
    cursor: pointer;
    background: linear-gradient(
      to right,
      var(--amber) 0%,
      var(--amber) var(--slider-fill, 50%),
      var(--border) var(--slider-fill, 50%),
      var(--border) 100%
    );
    transition: background 0.1s var(--ease);
  }

  .roi-slider::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: var(--amber);
    border: 3px solid var(--bg);
    box-shadow: 0 0 0 1px rgba(245, 158, 11, 0.3), 0 2px 8px rgba(0, 0, 0, 0.3);
    cursor: pointer;
    transition: box-shadow 0.2s var(--ease), transform 0.15s var(--ease);
  }

  .roi-slider::-webkit-slider-thumb:hover {
    box-shadow: 0 0 0 4px rgba(245, 158, 11, 0.15), 0 2px 12px rgba(0, 0, 0, 0.4);
    transform: scale(1.1);
  }

  .roi-slider::-webkit-slider-thumb:active {
    transform: scale(0.95);
  }

  .roi-slider::-moz-range-thumb {
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: var(--amber);
    border: 3px solid var(--bg);
    box-shadow: 0 0 0 1px rgba(245, 158, 11, 0.3), 0 2px 8px rgba(0, 0, 0, 0.3);
    cursor: pointer;
    transition: box-shadow 0.2s var(--ease), transform 0.15s var(--ease);
  }

  .roi-slider::-moz-range-thumb:hover {
    box-shadow: 0 0 0 4px rgba(245, 158, 11, 0.15), 0 2px 12px rgba(0, 0, 0, 0.4);
  }

  .roi-slider::-moz-range-track {
    height: 6px;
    border-radius: 3px;
    background: var(--border);
  }

  .roi-slider::-moz-range-progress {
    height: 6px;
    border-radius: 3px;
    background: var(--amber);
  }

  .roi-slider:focus-visible {
    outline: 2px solid var(--amber);
    outline-offset: 4px;
    border-radius: 3px;
  }

  .roi-range-labels {
    display: flex;
    justify-content: space-between;
    font-size: 0.75rem;
    color: var(--text-dim);
  }

  /* ============================================
     RADIO GROUP
     ============================================ */
  .roi-radio-group {
    border: none;
    padding: 0;
    margin: 0;
  }

  .roi-radio-group legend {
    margin-bottom: 10px;
  }

  .roi-radio-options {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px;
  }

  .roi-radio {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px 14px;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    cursor: pointer;
    transition: all 0.2s var(--ease);
  }

  .roi-radio:hover {
    border-color: var(--border-hover);
    background: var(--bg-surface);
  }

  .roi-radio input {
    position: absolute;
    opacity: 0;
    pointer-events: none;
    width: 0;
    height: 0;
  }

  .roi-radio-control {
    width: 18px;
    height: 18px;
    border-radius: 50%;
    border: 2px solid var(--border-hover);
    flex-shrink: 0;
    position: relative;
    transition: all 0.2s var(--ease);
  }

  .roi-radio-control::after {
    content: '';
    position: absolute;
    inset: 3px;
    border-radius: 50%;
    background: var(--amber);
    transform: scale(0);
    transition: transform 0.2s var(--ease);
  }

  .roi-radio input:checked ~ .roi-radio-control {
    border-color: var(--amber);
  }

  .roi-radio input:checked ~ .roi-radio-control::after {
    transform: scale(1);
  }

  .roi-radio:has(input:checked) {
    border-color: rgba(245, 158, 11, 0.3);
