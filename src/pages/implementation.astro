---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroInner from '../components/ui/HeroInner.astro';
import SectionHeader from '../components/ui/SectionHeader.astro';
import CTABanner from '../components/ui/CTABanner.astro';

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Implementation', href: '/implementation' },
];

interface Phase {
  number: number;
  title: string;
  duration: string;
  tasks: string[];
  deliverable: string;
}

const phases: Phase[] = [
  {
    number: 1,
    title: 'Discovery',
    duration: '2-3 weeks',
    tasks: [
      'Process analysis and requirements gathering',
      'Current system assessment',
      'Module selection and scope definition',
    ],
    deliverable: 'Implementation roadmap',
  },
  {
    number: 2,
    title: 'Design',
    duration: '3-4 weeks',
    tasks: [
      'System configuration design',
      'Data migration planning',
      'Integration mapping',
    ],
    deliverable: 'Solution design document',
  },
  {
    number: 3,
    title: 'Build',
    duration: '6-8 weeks',
    tasks: [
      'System configuration',
      'Data migration execution',
      'Custom development if needed',
      'Integration setup',
    ],
    deliverable: 'Configured system',
  },
  {
    number: 4,
    title: 'Test',
    duration: '2-3 weeks',
    tasks: [
      'User acceptance testing',
      'Integration testing',
      'Performance testing',
    ],
    deliverable: 'Test sign-off',
  },
  {
    number: 5,
    title: 'Go-Live & Support',
    duration: '2 weeks + ongoing',
    tasks: [
      'Go-live preparation',
      'User training',
      'Hypercare support period',
      'Transition to standard support',
    ],
    deliverable: 'Production system',
  },
];

const expectations = [
  {
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>',
    title: 'Typical Timeline',
    description: 'Most implementations are completed within 3 to 6 months, depending on the number of modules and complexity of your manufacturing processes.',
  },
  {
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>',
    title: 'Training Included',
    description: 'Every implementation includes comprehensive end-user training, administrator workshops, and super-user certification to ensure your team is confident from day one.',
  },
  {
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>',
    title: 'Dedicated Project Manager',
    description: 'A single point of contact guides your project from kickoff through go-live and into support. They understand manufacturing and will keep your implementation on track and on budget.',
  },
];
---

<BaseLayout
  title="Implementation | TMS 4SAP"
  description="Learn about the TMS implementation methodology: a proven 5-phase approach to manufacturing ERP success with SAP Business One. Typical go-live in 3-6 months."
>
  <!-- Hero -->
  <HeroInner
    breadcrumbs={breadcrumbs}
    tag="Methodology"
    title="Implementation"
    titleAccent="Methodology"
    description="A proven approach to manufacturing ERP success. Our structured 5-phase methodology ensures your TMS implementation delivers value on time and within budget."
  />

  <!-- Timeline -->
  <section class="section timeline-section">
    <div class="container">
      <SectionHeader
        tag="5 Phases"
        title="From Discovery to"
        titleAccent="Go-Live"
        description="Every TMS implementation follows a structured methodology refined over hundreds of manufacturing projects."
      />

      <!-- Desktop horizontal timeline connector -->
      <div class="timeline-connector" aria-hidden="true">
        <div class="connector-line"></div>
        {phases.map((phase) => (
          <div class="connector-dot">
            <span>{phase.number}</span>
          </div>
        ))}
      </div>

      <!-- Phase cards -->
      <div class="phases-grid">
        {phases.map((phase) => (
          <div class="phase-card" data-animate>
            <!-- Mobile: phase number badge -->
            <div class="phase-number-mobile" aria-hidden="true">
              <span>{phase.number}</span>
            </div>

            <div class="phase-header">
              <span class="phase-badge">Phase {phase.number}</span>
              <span class="phase-duration">{phase.duration}</span>
            </div>

            <h3 class="phase-title">{phase.title}</h3>

            <ul class="phase-tasks" role="list">
              {phase.tasks.map((task) => (
                <li>
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                  <span>{task}</span>
                </li>
              ))}
            </ul>

            <div class="phase-deliverable">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
              <span>Deliverable: <strong>{phase.deliverable}</strong></span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- What to Expect -->
  <section class="section expect-section">
    <div class="container">
      <SectionHeader
        tag="What to Expect"
        title="Built for"
        titleAccent="Your Success"
        description="Beyond the methodology, every TMS implementation comes with the resources and support you need to succeed."
      />

      <div class="expect-grid">
        {expectations.map((item) => (
          <div class="expect-card" data-animate>
            <div class="expect-icon">
              <Fragment set:html={item.icon} />
            </div>
            <h3>{item.title}</h3>
            <p>{item.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Banner -->
  <CTABanner
    title="Ready to start your"
    titleAccent="implementation?"
    description="Speak with our team to discuss your requirements and receive a tailored implementation plan for your manufacturing environment."
    primaryCTA={{ label: 'Book a Demo', href: '/demo' }}
    secondaryCTA={{ label: 'Contact Us', href: '/contact' }}
  />
</BaseLayout>

<style>
  /* ---- Timeline Section ---- */
  .timeline-section {
    padding-top: clamp(2rem, 4vw, 3rem);
  }

  /* ---- Desktop Horizontal Connector ---- */
  .timeline-connector {
    display: none;
    position: relative;
    margin-bottom: 32px;
    padding: 0 40px;
    align-items: center;
    justify-content: space-between;
  }

  .connector-line {
    position: absolute;
    top: 50%;
    left: 40px;
    right: 40px;
    height: 2px;
    background: var(--border);
    transform: translateY(-50%);
  }

  .connector-line::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, var(--amber) 0%, rgba(245, 158, 11, 0.3) 100%);
    border-radius: 1px;
  }

  .connector-dot {
    position: relative;
    z-index: 1;
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--bg);
    border: 2px solid var(--amber);
    border-radius: 50%;
    font-family: var(--font-heading);
    font-size: 0.8125rem;
    font-weight: 700;
    color: var(--amber);
  }

  /* ---- Phase Cards Grid ---- */
  .phases-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
  }

  .phase-card {
    position: relative;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 28px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    transition: all 0.3s var(--ease);
  }

  .phase-card:hover {
    background: var(--bg-card-hover);
    border-color: var(--border-hover);
  }

  /* ---- Mobile Phase Number (vertical timeline indicator) ---- */
  .phase-number-mobile {
    position: absolute;
    top: 28px;
    right: 28px;
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--amber-dim);
    border: 1px solid rgba(245, 158, 11, 0.2);
    border-radius: 50%;
    font-family: var(--font-heading);
    font-size: 0.8125rem;
    font-weight: 700;
    color: var(--amber);
  }

  /* ---- Phase Header ---- */
  .phase-header {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
  }

  .phase-badge {
    display: inline-flex;
    align-items: center;
    padding: 4px 12px;
    background: var(--amber-dim);
    border: 1px solid rgba(245, 158, 11, 0.2);
    border-radius: 100px;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--amber);
  }

  .phase-duration {
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--text-dim);
  }

  .phase-title {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 600;
    line-height: 1.3;
    letter-spacing: -0.01em;
  }

  /* ---- Task List ---- */
  .phase-tasks {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .phase-tasks li {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: 0.9375rem;
    color: var(--text-muted);
    line-height: 1.5;
  }

  .phase-tasks li svg {
    flex-shrink: 0;
    color: var(--amber);
    margin-top: 3px;
    opacity: 0.7;
  }

  /* ---- Deliverable Badge ---- */
  .phase-deliverable {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 16px;
    background: rgba(245, 158, 11, 0.04);
    border: 1px solid rgba(245, 158, 11, 0.12);
    border-radius: var(--radius-sm);
    font-size: 0.8125rem;
    color: var(--text-muted);
    margin-top: auto;
  }

  .phase-deliverable svg {
    color: var(--amber);
    flex-shrink: 0;
    opacity: 0.8;
  }

  .phase-deliverable strong {
    color: var(--text);
    font-weight: 600;
  }

  /* ---- What to Expect Section ---- */
  .expect-section {
    border-top: 1px solid var(--border);
  }

  .expect-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .expect-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 32px 28px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    transition: all 0.3s var(--ease);
  }

  .expect-card:hover {
    background: var(--bg-card-hover);
    border-color: var(--border-hover);
    transform: translateY(-2px);
  }

  .expect-icon {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--amber-dim);
    border-radius: var(--radius-sm);
    color: var(--amber);
    flex-shrink: 0;
  }

  .expect-card h3 {
    font-family: var(--font-heading);
    font-size: 1.125rem;
    font-weight: 600;
    line-height: 1.3;
    letter-spacing: -0.01em;
  }

  .expect-card p {
    font-size: 0.9375rem;
    color: var(--text-muted);
    line-height: 1.7;
  }

  /* ---- Desktop: horizontal timeline + grid ---- */
  @media (min-width: 1024px) {
    .timeline-connector {
      display: flex;
    }

    .phase-number-mobile {
      display: none;
    }

    .phases-grid {
      grid-template-columns: repeat(5, 1fr);
      gap: 16px;
    }

    .phase-card {
      padding: 24px;
    }

    .phase-title {
      font-size: 1.125rem;
    }

    .phase-tasks li {
      font-size: 0.875rem;
    }

    .phase-deliverable {
      font-size: 0.75rem;
      padding: 8px 12px;
    }
  }

  /* ---- Tablet: 2-col + last card full width ---- */
  @media (min-width: 640px) and (max-width: 1023px) {
    .phases-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .phase-card:last-child {
      grid-column: 1 / -1;
    }
  }

  /* Tablet */
  @media (max-width: 768px) {
    .timeline-section {
      padding: clamp(2rem, 6vw, 3rem) 0;
    }

    .expect-section {
      padding: clamp(2rem, 6vw, 3rem) 0;
    }

    .phase-card {
      padding: 24px;
    }

    .expect-card {
      padding: 24px 20px;
    }

    .expect-card h3 {
      font-size: 1.0625rem;
    }
  }

  @media (max-width: 900px) {
    .expect-grid {
      grid-template-columns: 1fr;
      gap: 16px;
    }
  }

  /* iPhone / small mobile */
  @media (max-width: 480px) {
    .timeline-section {
      padding: 2rem 0;
    }

    .expect-section {
      padding: 2rem 0;
    }

    .phase-card {
      padding: 20px;
      gap: 12px;
    }

    .phase-number-mobile {
      width: 28px;
      height: 28px;
      font-size: 0.75rem;
      top: 20px;
      right: 20px;
    }

    .phase-badge {
      font-size: 0.6875rem;
      padding: 3px 10px;
    }

    .phase-duration {
      font-size: 0.75rem;
    }

    .phase-title {
      font-size: 1.125rem;
    }

    .phase-tasks li {
      font-size: 0.875rem;
      gap: 8px;
    }

    .phase-deliverable {
      font-size: 0.75rem;
      padding: 8px 12px;
    }

    .expect-card {
      padding: 20px 16px;
    }

    .expect-icon {
      width: 44px;
      height: 44px;
    }

    .expect-card h3 {
      font-size: 1rem;
    }

    .expect-card p {
      font-size: 0.875rem;
    }
  }
</style>
