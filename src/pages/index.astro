---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeader from '../components/ui/SectionHeader.astro';
import CTABanner from '../components/ui/CTABanner.astro';
import StatBar from '../components/ui/StatBar.astro';
import FeatureCard from '../components/cards/FeatureCard.astro';
import TestimonialCard from '../components/cards/TestimonialCard.astro';
import IndustryCard from '../components/cards/IndustryCard.astro';
import PlaceholderImage from '../components/ui/PlaceholderImage.astro';
import AnimatedText from '../components/motion/AnimatedText.tsx';
import FadeInView from '../components/motion/FadeInView.tsx';
import AnimatedCard from '../components/motion/AnimatedCard.tsx';
import AnimatedStatBar from '../components/motion/AnimatedStatBar.tsx';
import { modules } from '../data/modules';
import { industries } from '../data/industries';
import { heroStats } from '../data/stats';
import { testimonials } from '../data/testimonials';
import { clients } from '../data/clients';

const previewModules = modules.slice(0, 5);

/* Feature icons as SVG strings */
const featureIcons = {
  integrated: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>',
  flexible: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.375 2.625a2.121 2.121 0 1 1 3 3L12 15l-4 1 1-4Z"/></svg>',
  sap: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>',
  scalable: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="20" x2="12" y2="10"/><line x1="18" y1="20" x2="18" y2="4"/><line x1="6" y1="20" x2="6" y2="16"/></svg>',
};

---

<BaseLayout
  title="The Manufacturing Suite | 4SAP"
  description="The new standard for manufacturing with SAP Business One. 9 integrated modules for production planning, quality management, and business intelligence."
>
  <!-- ===== HERO ===== -->
  <section class="hero" id="hero">
    <div class="hero-bg" aria-hidden="true"></div>
    <div class="container hero-content">
      <div class="hero-badge">
        <span class="hero-badge-dot"></span>
        Built for SAP Business One
      </div>
      <AnimatedText
        client:visible
        text="The new standard for"
        accent="manufacturing."
        as="h1"
        className="hero-title"
        stagger={0.06}
      />
      <p class="hero-subtitle">
        A comprehensive, seamlessly integrated manufacturing solution
        with 9 specialized modules — from production planning to
        business intelligence.
      </p>
      <div class="hero-actions">
        <a href="/modules" class="btn btn-primary btn-lg">
          Explore Modules
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14" />
            <path d="m12 5 7 7-7 7" />
          </svg>
        </a>
        <a href="/contact" class="btn btn-ghost btn-lg">Contact Sales</a>
      </div>
      <div class="hero-trust">
        <div class="hero-trust-badge">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            <path d="m9 12 2 2 4-4"/>
          </svg>
          SAP Certified Integration
        </div>
        <div class="hero-trust-badge">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
            <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
          </svg>
          Enterprise-Grade Security
        </div>
        <div class="hero-trust-badge">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/>
            <path d="M2 12h20"/>
            <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
          </svg>
          Global Partner Network
        </div>
      </div>
      <div class="hero-image">
        <div class="hero-dashboard-wrap" id="heroDashboard">
          <picture>
            <source
              srcset="/images/hero-dashboard-960.webp 960w, /images/hero-dashboard.webp 1920w"
              sizes="(max-width: 768px) 960px, 1920px"
              type="image/webp"
            />
            <img
              src="/images/hero-dashboard.jpeg"
              alt="TMS 4SAP Production Planning Dashboard — Gantt chart with OEE analytics"
              width="1920"
              height="1080"
              loading="eager"
              decoding="async"
              class="hero-dashboard-img"
            />
          </picture>
          <div class="hero-cursor" id="heroCursor" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="white" stroke="none">
              <path d="M5 3l14 9-7 1.5L9 21z"/>
            </svg>
            <div class="hero-cursor-ring"></div>
          </div>
        </div>
      </div>
    </div>
    <AnimatedStatBar client:visible stats={heroStats} />
  </section>

  <!-- ===== LOGO CAROUSEL ===== -->
  <section class="logo-carousel-section" aria-label="Trusted by leading manufacturers">
    <div class="container">
      <p class="logo-carousel-label" data-animate>Trusted by leading manufacturers</p>
      <div class="logo-carousel" data-animate>
        <div class="logo-carousel-track">
          {clients.map((client) => (
            <div class="logo-carousel-item">
              <span class="logo-carousel-name">{client.name}</span>
            </div>
          ))}
          {/* Duplicate for seamless scroll */}
          {clients.map((client) => (
            <div class="logo-carousel-item" aria-hidden="true">
              <span class="logo-carousel-name">{client.name}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ===== WHY TMS? ===== -->
  <section class="section" id="why-tms">
    <div class="container">
      <SectionHeader
        tag="Why TMS?"
        title="One platform,"
        titleAccent="zero compromise."
        description="TheManufacturingSuite brings together everything a modern manufacturer needs inside SAP Business One — no middleware, no workarounds."
      />
      <div class="features-grid">
        <FadeInView client:visible delay={0}>
          <FeatureCard
            icon={featureIcons.integrated}
            title="Fully Integrated"
            description="All 9 modules share a single data model, eliminating silos and manual data transfers between departments."
          />
        </FadeInView>
        <FadeInView client:visible delay={0.1}>
          <FeatureCard
            icon={featureIcons.flexible}
            title="Modular & Flexible"
            description="Deploy only the modules you need today and scale as your operations grow. Each module works standalone or in concert."
          />
        </FadeInView>
        <FadeInView client:visible delay={0.2}>
          <FeatureCard
            icon={featureIcons.sap}
            title="SAP-Native"
            description="Built directly on SAP Business One with certified integration. No third-party middleware, no synchronization headaches."
          />
        </FadeInView>
        <FadeInView client:visible delay={0.3}>
          <FeatureCard
            icon={featureIcons.scalable}
            title="Enterprise-Scalable"
            description="From single-site operations to multi-plant deployments, TMS scales with your business without architectural rewrites."
          />
        </FadeInView>
      </div>
    </div>
  </section>

  <!-- ===== MODULES PREVIEW ===== -->
  <section class="section" id="modules-preview">
    <div class="container">
      <SectionHeader
        tag="Core Platform"
        title="System"
        titleAccent="Modules"
        description="Nine specialized modules working together to digitalize your entire manufacturing operation."
      />
      <div class="modules-grid">
        {previewModules.map((mod) => (
          <div
            class:list={['module-card', { 'module-featured': mod.featured }]}
          >
            <div class="module-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <Fragment set:html={mod.icon} />
              </svg>
            </div>
            <span class="module-abbr">{mod.abbr}</span>
            <h3>{mod.title}</h3>
            <p>{mod.tagline}</p>
            <a href={`/modules/${mod.slug}`} class="module-link" aria-label={`Learn more about ${mod.title}`}>
              Learn more <span aria-hidden="true">&rarr;</span>
            </a>
          </div>
        ))}
      </div>
      <div class="modules-cta" data-animate>
        <a href="/modules" class="btn btn-ghost">
          View all 9 modules
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14" />
            <path d="m12 5 7 7-7 7" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ===== INDUSTRY GRID ===== -->
  <section class="section" id="industries">
    <div class="container">
      <SectionHeader
        tag="Industry Solutions"
        title="Built for your"
        titleAccent="industry."
        description="Purpose-built configurations for the sectors where precision, traceability, and efficiency define success."
      />
      <div class="industry-grid">
        {industries.map((ind, i) => (
          <FadeInView client:visible delay={i * 0.1}>
            <IndustryCard industry={ind} />
          </FadeInView>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== TESTIMONIALS ===== -->
  <section class="section" id="testimonials">
    <div class="container">
      <SectionHeader
        tag="Customer Stories"
        title="What manufacturers"
        titleAccent="say."
        description="Hear from production leaders who streamlined their operations with TheManufacturingSuite."
      />
      <div class="testimonials-grid">
        {testimonials.map((t, i) => (
          <FadeInView client:visible delay={i * 0.12}>
            <TestimonialCard
              quote={t.quote}
              author={t.author}
              role={t.role}
              company={t.company}
            />
          </FadeInView>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== CTA BANNER ===== -->
  <CTABanner
    title="Ready to transform your"
    titleAccent="manufacturing?"
    description="Schedule a personalized demo with our manufacturing experts and see how TMS integrates with your SAP Business One environment."
    primaryCTA={{ label: "Book a Demo", href: "/demo" }}
    secondaryCTA={{ label: "Contact Sales", href: "/contact" }}
  />
</BaseLayout>

<script>
  function initHeroCursor() {
    const cursor = document.getElementById('heroCursor');
    const dashboard = document.getElementById('heroDashboard');
    if (!cursor || !dashboard) return;

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            cursor.classList.add('visible');
          } else {
            cursor.classList.remove('visible');
          }
        });
      },
      { threshold: 0.4 }
    );

    observer.observe(dashboard);
  }

  initHeroCursor();
  document.addEventListener('astro:page-load', initHeroCursor);
</script>

<style>
  /* ---- Hero Image ---- */
  .hero-image {
    max-width: 1120px;
    margin: 48px auto 0;
    position: relative;
    z-index: 1;
  }

  .hero-dashboard-wrap {
    position: relative;
    overflow: hidden;
    border-radius: var(--radius-lg, 12px);
    border: 1px solid var(--border);
    box-shadow: 0 24px 48px -12px rgba(0, 0, 0, 0.5), 0 0 0 1px rgba(245, 158, 11, 0.08);
  }

  .hero-dashboard-img {
    width: 100%;
    height: auto;
    display: block;
  }

  /* Cursor animation */
  .hero-cursor {
    position: absolute;
    top: 35%;
    left: 20%;
    pointer-events: none;
    opacity: 0;
    filter: drop-shadow(0 2px 4px rgba(0, 0, 0, 0.4));
    transition: opacity 0.3s ease;
  }

  .hero-cursor.visible {
    opacity: 1;
    animation: cursor-move 4s ease-in-out infinite;
  }

  .hero-cursor-ring {
    position: absolute;
    top: -4px;
    left: 6px;
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: rgba(245, 158, 11, 0.3);
    transform: scale(0);
    pointer-events: none;
  }

  .hero-cursor.visible .hero-cursor-ring {
    animation: cursor-click 4s ease-in-out infinite;
  }

  @keyframes cursor-move {
    0% { transform: translate(0, 0); }
    25% { transform: translate(180px, 60px); }
    40% { transform: translate(180px, 60px); }
    65% { transform: translate(320px, 20px); }
    80% { transform: translate(320px, 20px); }
    100% { transform: translate(0, 0); }
  }

  @keyframes cursor-click {
    0%, 23% { transform: scale(0); opacity: 0; }
    28% { transform: scale(1.5); opacity: 1; }
    35% { transform: scale(0); opacity: 0; }
    63% { transform: scale(0); opacity: 0; }
    68% { transform: scale(1.5); opacity: 1; }
    75% { transform: scale(0); opacity: 0; }
    100% { transform: scale(0); opacity: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-cursor { display: none; }
  }

  /* ---- Hero Trust Badges ---- */
  .hero-trust {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 24px;
    margin-top: 32px;
    flex-wrap: wrap;
  }

  .hero-trust-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.8125rem;
    color: var(--text-dim);
  }

  .hero-trust-badge svg {
    color: var(--amber);
    opacity: 0.7;
    flex-shrink: 0;
  }

  /* ---- Logo Carousel ---- */
  .logo-carousel-section {
    padding: clamp(2rem, 4vw, 3rem) 0;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }

  .logo-carousel-label {
    text-align: center;
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 24px;
  }

  .logo-carousel {
    overflow: hidden;
    -webkit-mask-image: linear-gradient(90deg, transparent 0%, black 10%, black 90%, transparent 100%);
    mask-image: linear-gradient(90deg, transparent 0%, black 10%, black 90%, transparent 100%);
  }

  .logo-carousel-track {
    display: flex;
    gap: 48px;
    animation: logo-scroll 30s linear infinite;
    width: max-content;
  }

  .logo-carousel-item {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 12px 24px;
  }

  .logo-carousel-name {
    font-family: var(--font-heading);
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--text-dim);
    opacity: 0.5;
    white-space: nowrap;
    letter-spacing: -0.01em;
    transition: color 0.2s var(--ease), opacity 0.2s var(--ease);
  }

  .logo-carousel-item:hover .logo-carousel-name {
    color: var(--text);
    opacity: 1;
  }

  @keyframes logo-scroll {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .logo-carousel-track {
      animation: none;
      flex-wrap: wrap;
      justify-content: center;
    }
  }

  /* ---- Features Grid ---- */
  .features-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }

  @media (max-width: 900px) {
    .features-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 540px) {
    .features-grid {
      grid-template-columns: 1fr;
    }
  }

  /* ---- Modules CTA ---- */
  .modules-cta {
    text-align: center;
    margin-top: clamp(2rem, 4vw, 3rem);
  }

  /* ---- Industry Grid ---- */
  .industry-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }

  @media (max-width: 900px) {
    .industry-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 540px) {
    .industry-grid {
      grid-template-columns: 1fr;
    }
  }

  /* ---- Testimonials Grid ---- */
  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
  }

  @media (max-width: 768px) {
    .testimonials-grid {
      grid-template-columns: 1fr;
    }
  }

  /* ============================================
     RESPONSIVE — Tablet (768px)
     ============================================ */
  @media (max-width: 768px) {
    /* Hero spacing */
    .hero-image {
      margin-top: 32px;
    }

    .hero-dashboard-wrap {
      border-radius: var(--radius, 12px);
    }

    .hero-dashboard-img {
      border-radius: 8px;
    }

    /* Scale down cursor animation for smaller viewport */
    .hero-cursor {
      display: none;
    }

    /* Logo carousel: tighter gap and faster animation */
    .logo-carousel-track {
      gap: 32px;
      animation-duration: 22s;
    }

    .logo-carousel-item {
      padding: 10px 16px;
    }

    .logo-carousel-name {
      font-size: 0.8125rem;
    }

    /* Modules CTA: ensure centered */
    .modules-cta {
      margin-top: 2rem;
    }
  }

  /* ============================================
     RESPONSIVE — Small tablet / large phone (640px)
     ============================================ */
  @media (max-width: 640px) {
    /* Hero trust badges: stack vertically */
    .hero-trust {
      flex-direction: column;
      gap: 12px;
      margin-top: 24px;
    }

    .hero-trust-badge {
      font-size: 0.75rem;
    }

    /* Hero actions: stack on small screens */
    .hero-actions {
      flex-direction: column;
      width: 100%;
    }

    .hero-actions :global(.btn) {
      width: 100%;
      justify-content: center;
    }

    /* Section descriptions: better mobile readability */
    .logo-carousel-label {
      font-size: 0.75rem;
      margin-bottom: 16px;
    }
  }

  /* ============================================
     RESPONSIVE — iPhone / small phones (480px)
     ============================================ */
  @media (max-width: 480px) {
    /* Hero image: let it breathe edge-to-edge */
    .hero-image {
      margin-top: 24px;
    }

    .hero-dashboard-wrap {
      margin-left: -16px;
      margin-right: -16px;
      border-radius: 8px;
    }

    .hero-dashboard-img {
      border-radius: 6px;
    }

    /* Hero content: tighter vertical spacing */
    .hero-content {
      padding: 0 16px;
    }

    .hero-badge {
      margin-bottom: 20px;
      font-size: 0.75rem;
      padding: 5px 12px;
    }

    .hero-trust {
      gap: 10px;
      margin-top: 20px;
    }

    .hero-trust-badge {
      font-size: 0.6875rem;
    }

    .hero-trust-badge svg {
      width: 14px;
      height: 14px;
    }

    /* Logo carousel: tighter on phone */
    .logo-carousel-track {
      gap: 24px;
      animation-duration: 18s;
    }

    .logo-carousel-item {
      padding: 8px 12px;
    }

    .logo-carousel-name {
      font-size: 0.75rem;
    }

    /* Modules CTA: full-width button */
    .modules-cta {
      margin-top: 1.5rem;
    }

    .modules-cta :global(.btn) {
      width: 100%;
      justify-content: center;
    }
  }

  /* ============================================
     RESPONSIVE — iPhone mini / narrowest (375px)
     ============================================ */
  @media (max-width: 390px) {
    .hero-content {
      padding: 0 12px;
    }

    .hero-dashboard-wrap {
      margin-left: -12px;
      margin-right: -12px;
      border-radius: 6px;
    }

    /* Ensure no horizontal overflow from any fixed-width element */
    .hero-image {
      max-width: 100%;
      overflow: hidden;
    }

    /* Logo carousel: minimal padding */
    .logo-carousel-item {
      padding: 6px 10px;
    }

    .logo-carousel-name {
      font-size: 0.6875rem;
    }

    .hero-trust-badge {
      font-size: 0.625rem;
      gap: 4px;
    }
  }
</style>
