import HeroAct1         from "@components/sections/home/HeroAct1.astro";
import StatStrip        from "@components/sections/home/StatStrip.astro";
import SchedulerAct4    from "@components/sections/home/SchedulerAct4.astro";
import ShopFloorBeats   from "@components/sections/home/ShopFloorBeats.astro";
import ModuleTrack      from "@components/sections/home/ModuleTrack.astro";
