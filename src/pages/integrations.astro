---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroInner from '../components/ui/HeroInner.astro';
import SectionHeader from '../components/ui/SectionHeader.astro';
import CTABanner from '../components/ui/CTABanner.astro';

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Integrations', href: '/integrations' },
];

type BadgeType = 'Native' | 'Certified' | 'Compatible';

interface Integration {
  name: string;
  description: string;
  badge: BadgeType;
  icon: string;
}

interface IntegrationCategory {
  category: string;
  description: string;
  integrations: Integration[];
}

const categories: IntegrationCategory[] = [
  {
    category: 'ERP Platform',
    description: 'The foundation of TMS — a deep, native connection with SAP Business One.',
    integrations: [
      {
        name: 'SAP Business One',
        description: 'Native integration with real-time bidirectional data synchronization. TMS is a certified SAP add-on running within the SAP B1 database, ensuring zero data latency and complete transactional consistency.',
        badge: 'Native',
        icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>',
      },
    ],
  },
  {
    category: 'CAD / PLM',
    description: 'Integrate your engineering tools directly with production planning and product data management.',
    integrations: [
      {
        name: 'Autodesk Inventor',
        description: 'Bidirectional BOM synchronization and drawing management. Engineering changes in Inventor are automatically reflected in TMS production BOMs, keeping your shop floor aligned with the latest revision.',
        badge: 'Certified',
        icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 20a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V8l-7 5V8l-7 5V4a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2Z"/></svg>',
      },
      {
        name: 'Autodesk Vault',
        description: 'Document management integration providing centralized access to CAD files, drawings, and engineering documentation from within TMS and SAP Business One.',
        badge: 'Certified',
        icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 20a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2h-7.9a2 2 0 0 1-1.69-.9L9.6 3.9A2 2 0 0 0 7.93 3H4a2 2 0 0 0-2 2v13a2 2 0 0 0 2 2Z"/></svg>',
      },
      {
        name: 'SOLIDWORKS',
        description: 'Model-to-BOM extraction enabling automatic creation of production bills of material from SOLIDWORKS assemblies, including material specifications and routing information.',
        badge: 'Compatible',
        icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>',
      },
      {
        name: 'EPLAN',
        description: 'Electrical engineering data integration for cable lists, terminal assignments, and component BOMs. Ideal for panel builders and machine manufacturers with electrical engineering requirements.',
        badge: 'Compatible',
        icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2 3 14h9l-1 8 10-12h-9l1-8z"/></svg>',
      },
    ],
  },
  {
    category: 'Communication',
    description: 'Automate data exchange with your customers and supply chain partners.',
    integrations: [
      {
        name: 'EDI',
        description: 'Automated electronic order and invoice exchange with OEM customers and tier-one suppliers. Support for EDIFACT, ANSI X12, and VDA standards commonly used in automotive and manufacturing supply chains.',
        badge: 'Certified',
        icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 11a9 9 0 0 1 9 9"/><path d="M4 4a16 16 0 0 1 16 16"/><circle cx="5" cy="19" r="1"/></svg>',
      },
    ],
  },
  {
    category: 'Data Capture',
    description: 'Connect your shop floor hardware for real-time production data collection.',
    integrations: [
      {
        name: 'Barcode Scanners',
        description: 'Full support for USB and Bluetooth barcode scanners from all major brands including Zebra, Honeywell, and Datalogic. Scan work orders, materials, and finished goods on the shop floor.',
        badge: 'Compatible',
        icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 7V5a2 2 0 0 1 2-2h2"/><path d="M17 3h2a2 2 0 0 1 2 2v2"/><path d="M21 17v2a2 2 0 0 1-2 2h-2"/><path d="M7 21H5a2 2 0 0 1-2-2v-2"/><line x1="7" y1="12" x2="17" y2="12"/></svg>',
      },
      {
        name: 'RFID Systems',
        description: 'Passive and active RFID tag support for automated material tracking, inventory management, and work-in-progress monitoring. Enables hands-free data capture in high-volume environments.',
        badge: 'Compatible',
        icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12h6"/><path d="M22 12h-6"/><path d="M12 2v6"/><path d="M12 22v-6"/><circle cx="12" cy="12" r="4"/></svg>',
      },
      {
        name: 'Machine Connectivity',
        description: 'Direct PLC integration and OPC-UA protocol support for automated data collection from CNC machines, injection molding equipment, and production lines. Capture cycle times, piece counts, and machine status in real time.',
        badge: 'Native',
        icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="6" width="20" height="12" rx="2"/><path d="M6 12h.01"/><path d="M10 12h.01"/><path d="M14 12h.01"/><path d="M18 12h.01"/></svg>',
      },
    ],
  },
  {
    category: 'Reporting',
    description: 'Extend your analytics and reporting capabilities with industry-standard tools.',
    integrations: [
      {
        name: 'Crystal Reports',
        description: 'Advanced report design and generation for production reports, quality certificates, delivery notes, and management dashboards. Full access to all TMS and SAP Business One data.',
        badge: 'Native',
        icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>',
      },
      {
        name: 'Microsoft Excel',
        description: 'Seamless data export and import capabilities with predefined templates for production planning, capacity analysis, and cost calculations. Familiar interface for ad-hoc reporting needs.',
        badge: 'Native',
        icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="3" y1="15" x2="21" y2="15"/><line x1="9" y1="3" x2="9" y2="21"/><line x1="15" y1="3" x2="15" y2="21"/></svg>',
      },
    ],
  },
];
---

<BaseLayout
  title="Integrations | TMS 4SAP"
  description="Explore TMS integration partners and capabilities: SAP Business One, Autodesk Inventor, SOLIDWORKS, EPLAN, EDI, barcode/RFID, OPC-UA machine connectivity, Crystal Reports, and more."
>
  <!-- Hero -->
  <HeroInner
    breadcrumbs={breadcrumbs}
    tag="Ecosystem"
    title="Integrations"
    description="TMS connects seamlessly with your existing tools and systems. From CAD platforms and shop floor hardware to reporting engines and supply chain communication."
  />

  <!-- Integration Categories -->
  {categories.map((cat) => (
    <section class="section integration-category">
      <div class="container">
        <div class="category-header" data-animate>
          <h2 class="category-title">{cat.category}</h2>
          <p class="category-desc">{cat.description}</p>
        </div>

        <div class:list={['integration-grid', { 'integration-grid--single': cat.integrations.length === 1 }]}>
          {cat.integrations.map((item) => (
            <div class="integration-card" data-animate>
              <div class="integration-card-top">
                <div class="integration-icon">
                  <Fragment set:html={item.icon} />
                </div>
                <span class:list={['integration-badge', `badge-${item.badge.toLowerCase()}`]}>
                  {item.badge}
                </span>
              </div>
              <h3>{item.name}</h3>
              <p>{item.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  ))}

  <!-- Custom Integration CTA -->
  <section class="section custom-integration-section">
    <div class="container">
      <div class="custom-integration-card" data-animate>
        <div class="custom-integration-content">
          <div class="custom-integration-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="3"/>
              <path d="M12 1v4"/>
              <path d="M12 19v4"/>
              <path d="M4.22 4.22l2.83 2.83"/>
              <path d="M16.95 16.95l2.83 2.83"/>
              <path d="M1 12h4"/>
              <path d="M19 12h4"/>
              <path d="M4.22 19.78l2.83-2.83"/>
              <path d="M16.95 7.05l2.83-2.83"/>
            </svg>
          </div>
          <div class="custom-integration-text">
            <h3>Need a custom integration?</h3>
            <p>
              If your manufacturing environment uses tools or systems not listed here, our integration
              team can build custom connectors. We have experience with a wide range of industrial
              protocols, APIs, and data formats used in discrete and process manufacturing.
            </p>
          </div>
          <a href="/contact" class="btn btn-primary btn-lg">Contact Our Team</a>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Banner -->
  <CTABanner
    title="See TMS integrations"
    titleAccent="in action"
    description="Book a demo to see how TMS connects with your existing SAP, CAD, and shop floor systems in a unified manufacturing platform."
    primaryCTA={{ label: 'Book a Demo', href: '/demo' }}
    secondaryCTA={{ label: 'Download Brochure', href: '/downloads' }}
  />
</BaseLayout>

<style>
  /* ---- Category Sections ---- */
  .integration-category {
    padding-top: clamp(2rem, 4vw, 3rem);
    padding-bottom: clamp(2rem, 4vw, 3rem);
  }

  .integration-category + .integration-category {
    border-top: 1px solid var(--border);
  }

  /* ---- Category Header ---- */
  .category-header {
    margin-bottom: clamp(1.5rem, 3vw, 2.5rem);
  }

  .category-title {
    font-family: var(--font-heading);
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin-bottom: 8px;
  }

  .category-desc {
    font-size: 1rem;
    color: var(--text-muted);
    line-height: 1.7;
    max-width: 600px;
  }

  /* ---- Integration Cards Grid ---- */
  .integration-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
  }

  .integration-grid--single {
    grid-template-columns: 1fr;
    max-width: 640px;
  }

  .integration-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 28px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    transition: all 0.3s var(--ease);
  }

  .integration-card:hover {
    background: var(--bg-card-hover);
    border-color: var(--border-hover);
    transform: translateY(-2px);
  }

  /* ---- Card Top: Icon + Badge ---- */
  .integration-card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }

  .integration-icon {
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--amber-dim);
    border-radius: var(--radius-sm);
    color: var(--amber);
    flex-shrink: 0;
  }

  /* ---- Badges ---- */
  .integration-badge {
    display: inline-flex;
    align-items: center;
    padding: 4px 10px;
    border-radius: 100px;
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    flex-shrink: 0;
  }

  .badge-native {
    background: rgba(245, 158, 11, 0.12);
    border: 1px solid rgba(245, 158, 11, 0.25);
    color: var(--amber);
  }

  .badge-certified {
    background: rgba(34, 197, 94, 0.08);
    border: 1px solid rgba(34, 197, 94, 0.2);
    color: #4ade80;
  }

  .badge-compatible {
    background: rgba(161, 161, 170, 0.08);
    border: 1px solid rgba(161, 161, 170, 0.2);
    color: var(--text-muted);
  }

  /* ---- Card Content ---- */
  .integration-card h3 {
    font-family: var(--font-heading);
    font-size: 1.125rem;
    font-weight: 600;
    line-height: 1.3;
    letter-spacing: -0.01em;
  }

  .integration-card p {
    font-size: 0.9375rem;
    color: var(--text-muted);
    line-height: 1.7;
  }

  /* ---- Custom Integration Section ---- */
  .custom-integration-section {
    padding-top: 0;
  }

  .custom-integration-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-xl);
    padding: clamp(2rem, 4vw, 3rem);
    position: relative;
    overflow: hidden;
  }

  /* Top edge glow */
  .custom-integration-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 15%;
    right: 15%;
    height: 1px;
    background: linear-gradient(90deg, transparent 0%, var(--amber) 50%, transparent 100%);
    opacity: 0.3;
  }

  .custom-integration-content {
    display: flex;
    align-items: center;
    gap: 24px;
  }

  .custom-integration-icon {
    width: 56px;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--amber-dim);
    border-radius: var(--radius);
    color: var(--amber);
    flex-shrink: 0;
  }

  .custom-integration-text {
    flex: 1;
  }

  .custom-integration-text h3 {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 600;
    line-height: 1.3;
    letter-spacing: -0.01em;
    margin-bottom: 8px;
  }

  .custom-integration-text p {
    font-size: 0.9375rem;
    color: var(--text-muted);
    line-height: 1.7;
    max-width: 640px;
  }

  .custom-integration-content > .btn {
    flex-shrink: 0;
    white-space: nowrap;
  }

  /* ---- Responsive ---- */
  @media (min-width: 1024px) {
    .integration-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* Tablet (768px) */
  @media (max-width: 768px) {
    .integration-category {
      padding-top: clamp(1.5rem, 6vw, 2.5rem);
      padding-bottom: clamp(1.5rem, 6vw, 2.5rem);
    }

    .integration-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 12px;
    }

    .custom-integration-content {
      flex-direction: column;
      align-items: flex-start;
      text-align: left;
      gap: 20px;
    }

    .custom-integration-content > .btn {
      align-self: flex-start;
    }
  }

  /* iPhone (375px - 430px) */
  @media (max-width: 480px) {
    .integration-category {
      padding: clamp(3rem, 8vw, 5rem) 0;
    }

    .integration-grid {
      grid-template-columns: 1fr;
    }

    .integration-card {
      padding: 20px;
    }

    .custom-integration-card {
      padding: clamp(1.5rem, 4vw, 2rem);
    }

    .custom-integration-content > .btn {
      align-self: stretch;
      text-align: center;
      justify-content: center;
      min-height: 44px;
    }

    .integration-badge {
      min-height: 44px;
      padding: 4px 14px;
    }
  }
</style>
