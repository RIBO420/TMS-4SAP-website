---
import BaseLayout from '@layouts/BaseLayout.astro';
import CTABanner from '@components/ui/CTABanner.astro';
import '@styles/utilities.css';

const title = 'Privacy Policy';
const lastUpdated = '2026-03-01';
const formattedDate = new Date(lastUpdated).toLocaleDateString('en-GB', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout
  title="Privacy Policy | TMS 4SAP"
  description="Learn how TheManufacturingSuite BV collects, uses, and protects your personal data. Read our Privacy Policy for details on your rights under GDPR."
>
  <!-- Breadcrumbs -->
  <nav class="container breadcrumbs" aria-label="Breadcrumb">
    <a href="/">Home</a>
    <span class="breadcrumbs-separator" aria-hidden="true">/</span>
    <a href="/legal/privacy">Legal</a>
    <span class="breadcrumbs-separator" aria-hidden="true">/</span>
    <span class="breadcrumbs-current" aria-current="page">{title}</span>
  </nav>

  <!-- Legal content -->
  <section class="section legal-section">
    <div class="container">
      <div class="legal-width">
        <!-- Page header -->
        <header class="legal-header">
          <h1>{title}</h1>
          <p class="legal-last-updated">
            Last updated: <time datetime={lastUpdated}>{formattedDate}</time>
          </p>
        </header>

        <!-- Prose content -->
        <div class="prose">

          <h2 id="introduction">1. Introduction</h2>
          <p>
            This Privacy Policy explains how <strong>TheManufacturingSuite BV</strong> ("TMS," "we," "us," or "our"),
            headquartered at Il Flore, Avenue Ceramique 221, 6221 KX Maastricht, The Netherlands, collects, uses,
            stores, and protects your personal data when you visit our website, use our services, or otherwise
            interact with us.
          </p>
          <p>
            We are committed to protecting your privacy and handling your data in an open and transparent manner.
            This policy is compliant with the European Union's General Data Protection Regulation (GDPR) and other
            applicable data protection laws.
          </p>

          <h2 id="data-collection">2. What Data We Collect</h2>
          <p>We may collect and process the following categories of personal data:</p>
          <ul>
            <li>
              <strong>Contact form data:</strong> When you submit a contact form, request a demo, or download a
              brochure, we collect your name, email address, company name, phone number, and the content of your
              message.
            </li>
            <li>
              <strong>Website analytics:</strong> We collect anonymised data about how you interact with our website,
              including pages visited, time spent on each page, referral sources, browser type, operating system,
              and device information.
            </li>
            <li>
              <strong>Cookies and tracking technologies:</strong> We use cookies and similar technologies to
              enhance your browsing experience, analyse website traffic, and deliver personalised content. See
              Section 8 for full details.
            </li>
            <li>
              <strong>Business correspondence:</strong> When you communicate with us via email, phone, or other
              channels, we may retain those communications to respond to your inquiries and maintain our records.
            </li>
          </ul>

          <h2 id="data-use">3. How We Use Your Data</h2>
          <p>We use your personal data for the following purposes:</p>
          <ul>
            <li>
              <strong>Respond to inquiries:</strong> To answer your questions, provide requested information about
              our products and services, and follow up on demo requests.
            </li>
            <li>
              <strong>Improve our website:</strong> To analyse usage patterns, diagnose technical issues, and
              enhance the user experience of our website and digital properties.
            </li>
            <li>
              <strong>Marketing communications:</strong> With your explicit consent, we may send you newsletters,
              product updates, event invitations, and other marketing materials. You can opt out at any time by
              clicking the "unsubscribe" link in any marketing email or by contacting us directly.
            </li>
            <li>
              <strong>Contract performance:</strong> To deliver our software solutions, provide implementation
              support, and fulfil our contractual obligations to customers and partners.
            </li>
            <li>
              <strong>Legal compliance:</strong> To comply with applicable laws, regulations, and legal processes.
            </li>
          </ul>

          <h2 id="legal-basis">4. Legal Basis for Processing</h2>
          <p>We process your personal data on the basis of one or more of the following legal grounds:</p>
          <ul>
            <li>
              <strong>Legitimate interest:</strong> We process certain data where it is necessary for our
              legitimate business interests, such as improving our website, analysing usage patterns, and
              protecting our systems, provided these interests are not overridden by your rights and freedoms.
            </li>
            <li>
              <strong>Consent:</strong> Where you have given us explicit consent to process your data for a
              specific purpose, such as receiving marketing communications or enabling non-essential cookies.
            </li>
            <li>
              <strong>Contract performance:</strong> Where processing is necessary to perform a contract with you
              or to take steps at your request before entering into a contract, such as responding to a demo
              request or providing our software services.
            </li>
            <li>
              <strong>Legal obligation:</strong> Where processing is necessary to comply with a legal obligation
              to which we are subject, such as tax reporting or regulatory requirements.
            </li>
          </ul>

          <h2 id="data-sharing">5. Data Sharing</h2>
          <p>
            We do <strong>not</strong> sell, trade, or rent your personal data to third parties. We may share your
            data only in the following limited circumstances:
          </p>
          <ul>
            <li>
              <strong>Service providers:</strong> We work with trusted third-party processors who assist us in
              operating our website, conducting our business, and servicing you (e.g., hosting providers, email
              service providers, analytics platforms). These partners are contractually obligated to keep your data
              confidential and to process it only as instructed by us.
            </li>
            <li>
              <strong>Legal requirements:</strong> We may disclose your data if required by law, regulation, legal
              process, or governmental request.
            </li>
            <li>
              <strong>Business transfers:</strong> In the event of a merger, acquisition, or sale of assets, your
              data may be transferred as part of the transaction. We will notify you of any such change and ensure
              that data protection standards are maintained.
            </li>
          </ul>

          <h2 id="data-retention">6. Data Retention</h2>
          <p>We retain your personal data only for as long as necessary to fulfil the purposes outlined in this policy:</p>
          <ul>
            <li>
              <strong>Contact form data:</strong> Retained for up to <strong>2 years</strong> from the date of your
              last interaction with us, unless a longer retention period is required for contractual or legal reasons.
            </li>
            <li>
              <strong>Website analytics data:</strong> Retained for up to <strong>26 months</strong>, after which it
              is automatically anonymised or deleted.
            </li>
            <li>
              <strong>Marketing consent records:</strong> Retained for as long as the consent remains valid, plus a
              reasonable period afterwards to demonstrate compliance.
            </li>
            <li>
              <strong>Contractual data:</strong> Retained for the duration of the contract and for up to 7 years
              afterwards, as required by Dutch fiscal legislation.
            </li>
          </ul>

          <h2 id="your-rights">7. Your Rights</h2>
          <p>
            Under the GDPR, you have the following rights regarding your personal data. You can exercise any of
            these rights by contacting us at
            <a href="mailto:privacy@themanufacturingsuite.com">privacy@themanufacturingsuite.com</a>.
          </p>
          <ul>
            <li>
              <strong>Right of access:</strong> You have the right to request a copy of the personal data we hold
              about you.
            </li>
            <li>
              <strong>Right to rectification:</strong> You have the right to request correction of any inaccurate
              or incomplete personal data.
            </li>
            <li>
              <strong>Right to erasure:</strong> You have the right to request deletion of your personal data where
              there is no compelling reason for us to continue processing it.
            </li>
            <li>
              <strong>Right to data portability:</strong> You have the right to receive your personal data in a
              structured, commonly used, and machine-readable format and to transfer it to another controller.
            </li>
            <li>
              <strong>Right to object:</strong> You have the right to object to the processing of your personal
              data where we rely on legitimate interest as our legal basis.
            </li>
            <li>
              <strong>Right to restrict processing:</strong> You have the right to request that we restrict the
              processing of your personal data under certain circumstances.
            </li>
            <li>
              <strong>Right to withdraw consent:</strong> Where processing is based on consent, you have the right
              to withdraw that consent at any time without affecting the lawfulness of processing carried out prior
              to withdrawal.
            </li>
          </ul>
          <p>
            We will respond to your request within 30 days. If you are unsatisfied with our response, you have the
            right to lodge a complaint with the Dutch Data Protection Authority (<em>Autoriteit Persoonsgegevens</em>).
          </p>

          <h2 id="cookies">8. Cookies</h2>
          <p>
            Our website uses cookies and similar tracking technologies to distinguish you from other users and to
            provide a better browsing experience. Cookies are small text files stored on your device by your browser.
          </p>
          <p>We use the following categories of cookies:</p>
          <ul>
            <li>
              <strong>Essential cookies:</strong> Required for the basic operation of the website. These cookies
              enable core functionality such as page navigation, security, and accessibility features. They cannot
              be disabled.
            </li>
            <li>
              <strong>Analytics cookies:</strong> Help us understand how visitors interact with our website by
              collecting and reporting information anonymously. We use these insights to improve the structure and
              content of our website. Analytics cookies are only placed with your consent.
            </li>
            <li>
              <strong>Marketing cookies:</strong> Used to track visitors across websites and to display advertisements
              that are relevant and engaging. Marketing cookies are only placed with your explicit consent.
            </li>
          </ul>
          <p>
            <strong>Managing your cookie preferences:</strong> When you first visit our website, you will be
            presented with a cookie consent banner where you can choose which categories of cookies to accept.
            You can change your cookie preferences at any time by clearing your browser cookies and revisiting
            our website, or by contacting us directly.
          </p>
          <p>
            You can also control cookies through your browser settings. Most browsers allow you to refuse or
            delete cookies. Please note that disabling certain cookies may affect the functionality of our website.
          </p>

          <h2 id="contact">9. Contact for Privacy Matters</h2>
          <p>
            If you have any questions, concerns, or requests regarding this Privacy Policy or the way we handle
            your personal data, please contact us:
          </p>
          <ul>
            <li><strong>Email:</strong> <a href="mailto:privacy@themanufacturingsuite.com">privacy@themanufacturingsuite.com</a></li>
            <li><strong>Phone:</strong> <a href="tel:+31432340050">+31 43 234 00 50</a></li>
            <li>
              <strong>Post:</strong> TheManufacturingSuite BV, Attn: Privacy Officer,
              Il Flore, Avenue Ceramique 221, 6221 KX Maastricht, The Netherlands
            </li>
          </ul>

        </div>
      </div>
    </div>
  </section>

  <!-- CTA Banner -->
  <CTABanner
    title="Questions about our"
    titleAccent="data practices?"
    description="Our team is happy to answer any questions about how we handle your personal data. Reach out to us directly."
    primaryCTA={{ label: 'Contact Us', href: '/contact' }}
    secondaryCTA={{ label: 'Back to Home', href: '/' }}
  />
</BaseLayout>

<style>
  .legal-section {
    padding-top: clamp(1rem, 2vw, 2rem);
  }
</style>
