---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HeroInner from '../../components/ui/HeroInner.astro';
import SectionHeader from '../../components/ui/SectionHeader.astro';
import CTABanner from '../../components/ui/CTABanner.astro';
---

<BaseLayout
  lang="nl"
  title="Vacatures | TMS 4SAP"
  description="Sluit u aan bij het TheManufacturingSuite-team in Maastricht. Ontdek openstaande functies in softwareontwikkeling, consultancy en support. Help de toekomst van productietechnologie vormgeven."
>
  <!-- Hero -->
  <HeroInner
    breadcrumbs={[
      { label: 'Home', href: '/nl' },
      { label: 'Vacatures', href: '/nl/careers' },
    ]}
    tag="Vacatures"
    title="Word lid van ons"
    titleAccent="Team"
    description="Help ons de toekomst van productietechnologie vormgeven. Wij bouwen software die productievloeren wereldwijd aandrijft -- en we hebben getalenteerde mensen nodig om dat te realiseren."
  />

  <!-- Why TMS? -->
  <section class="section why-section">
    <div class="container">
      <SectionHeader
        tag="Waarom TMS?"
        title="Meer dan een"
        titleAccent="werkplek"
        description="Wij geloven in het bouwen van een omgeving waar getalenteerde mensen hun beste werk kunnen leveren. Dit is wat u kunt verwachten wanneer u bij TMS komt werken."
      />

      <div class="benefits-grid" data-animate>
        <!-- Innovation -->
        <div class="benefit-card">
          <div class="benefit-icon" aria-hidden="true">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 2v4" /><path d="m6.34 7.34 2.83 2.83" /><path d="M2 12h4" /><path d="m6.34 16.66 2.83-2.83" /><path d="M12 18v4" /><path d="m14.83 14.83 2.83 2.83" /><path d="M18 12h4" /><path d="m14.83 9.17 2.83-2.83" />
            </svg>
          </div>
          <h3 class="benefit-title">Innovatie</h3>
          <p class="benefit-desc">
            Werk aan geavanceerde productietechnologie op het snijvlak van ERP-systemen, productieplanning en
            realtime shopfloor-uitvoering. Onze tech stack combineert SAP ABAP, moderne webframeworks en
            geavanceerde planningsalgoritmen.
          </p>
        </div>

        <!-- Growth -->
        <div class="benefit-card">
          <div class="benefit-icon" aria-hidden="true">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M2 20h20" /><path d="m5.5 16.5 2-4.5" /><path d="m7.5 12 3.5-6" /><path d="m11 6 3.5 6" /><path d="m14.5 12 2 4.5" /><circle cx="12" cy="5" r="1" />
            </svg>
          </div>
          <h3 class="benefit-title">Groei</h3>
          <p class="benefit-desc">
            Persoonlijke ontwikkeling is een prioriteit, geen bijzaak. Wij investeren in certificeringen,
            opleidingsprogramma's, congresbezoek en interne kennisdelingssessies. Uw carri\u00e8repad is aan u om te
            bepalen -- wij bieden de ondersteuning om er te komen.
          </p>
        </div>

        <!-- Flexibility -->
        <div class="benefit-card">
          <div class="benefit-icon" aria-hidden="true">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect width="18" height="18" x="3" y="3" rx="2" /><path d="M3 9h18" /><path d="M9 3v18" />
            </svg>
          </div>
          <h3 class="benefit-title">Flexibiliteit</h3>
          <p class="benefit-desc">
            Wij bieden hybride werkopties met een mix van kantoordagen op ons hoofdkantoor in Maastricht en thuiswerken.
            Flexibele werktijden betekenen dat u uw dag kunt indelen rond uw leven, niet andersom. Resultaten tellen
            meer dan klokuren.
          </p>
        </div>

        <!-- Impact -->
        <div class="benefit-card">
          <div class="benefit-icon" aria-hidden="true">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10" /><path d="m2 12 5.1 2.5" /><path d="m22 12-5.1 2.5" /><path d="m8 12 4-8 4 8" /><path d="M12 2a14.5 14.5 0 0 0 0 20" /><path d="M12 2a14.5 14.5 0 0 1 0 20" />
            </svg>
          </div>
          <h3 class="benefit-title">Impact</h3>
          <p class="benefit-desc">
            Uw werk raakt direct echte productievloeren wereldwijd -- van kunststoffabrikanten in Nederland tot
            automotive toeleveranciers in heel Europa. Elke functie die u bouwt, elke klant die u ondersteunt,
            heeft een tastbaar effect op hoe goederen worden gemaakt.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Open Positions -->
  <section class="section positions-section">
    <div class="container">
      <SectionHeader
        tag="Openstaande functies"
        title="Vind uw"
        titleAccent="Rol"
        description="Wij zoeken mensen die gepassioneerd zijn over technologie en productie. Bekijk hieronder onze huidige vacatures."
      />

      <div class="positions-list">
        <!-- Position 1: Senior Software Developer -->
        <article class="position-card" data-animate>
          <div class="position-header">
            <div class="position-meta">
              <span class="position-badge">Fulltime</span>
              <span class="position-location">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z" /><circle cx="12" cy="10" r="3" />
                </svg>
                Maastricht / Remote
              </span>
            </div>
            <h3 class="position-title">Senior Software Developer</h3>
          </div>
          <div class="position-body">
            <p class="position-desc">
              Wij zoeken een ervaren softwareontwikkelaar voor ons kernproductteam. U ontwerpt en bouwt nieuwe
              functies voor TMS 4SAP, werkend over de gehele stack van SAP ABAP backend-logica tot moderne
              webgebaseerde frontends. U werkt nauw samen met onze productmanagers en implementatieconsultants
              om klantbehoeften te vertalen naar robuuste, schaalbare oplossingen.
            </p>
            <div class="position-requirements">
              <h4>Wat wij zoeken:</h4>
              <ul>
                <li>5+ jaar professionele ervaring in softwareontwikkeling</li>
                <li>Sterke kennis van SAP ABAP en SAP Business One SDK</li>
                <li>Ervaring met moderne webtechnologie\u00ebn (JavaScript/TypeScript, HTML, CSS)</li>
                <li>Begrip van productieprocessen en ERP-concepten</li>
                <li>Bekendheid met SQL Server of HANA databasebeheer</li>
                <li>Vloeiend in het Engels; Nederlands of Duits is een plus</li>
              </ul>
            </div>
          </div>
          <div class="position-footer">
            <a href="mailto:careers@themanufacturingsuite.com?subject=Sollicitatie%3A%20Senior%20Software%20Developer" class="btn btn-primary">
              Nu Solliciteren
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M5 12h14" /><path d="m12 5 7 7-7 7" />
              </svg>
            </a>
          </div>
        </article>

        <!-- Position 2: Implementation Consultant -->
        <article class="position-card" data-animate>
          <div class="position-header">
            <div class="position-meta">
              <span class="position-badge">Fulltime</span>
              <span class="position-location">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z" /><circle cx="12" cy="10" r="3" />
                </svg>
                Maastricht + Reizen
              </span>
            </div>
            <h3 class="position-title">Implementatie Consultant</h3>
          </div>
          <div class="position-body">
            <p class="position-desc">
              Als Implementatie Consultant bent u het eerste aanspreekpunt voor klanten tijdens hun TMS 4SAP-uitrol.
              U beheert de volledige implementatiecyclus -- van inventarisatie van vereisten en procesmapping tot
              systeemconfiguratie, testen en go-live ondersteuning. Dit is een klantgerichte rol die technische
              expertise combineert met sterke communicatievaardigheden.
            </p>
            <div class="position-requirements">
              <h4>Wat wij zoeken:</h4>
              <ul>
                <li>3+ jaar ervaring met ERP- of productiesoftware-implementatie</li>
                <li>Hands-on ervaring met SAP Business One of vergelijkbare ERP-systemen</li>
                <li>Sterke projectmanagementvaardigheden en het vermogen om meerdere projecten tegelijk te beheren</li>
                <li>Uitstekende communicatie- en presentatievaardigheden</li>
                <li>Bereidheid om te reizen naar klantlocaties in heel Europa (circa 30-40%)</li>
                <li>Begrip van productieprocessen: productieplanning, stuklijstbeheer, kwaliteitscontrole</li>
                <li>Vloeiend in het Engels en Nederlands; Duits is een groot voordeel</li>
              </ul>
            </div>
          </div>
          <div class="position-footer">
            <a href="mailto:careers@themanufacturingsuite.com?subject=Sollicitatie%3A%20Implementatie%20Consultant" class="btn btn-primary">
              Nu Solliciteren
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M5 12h14" /><path d="m12 5 7 7-7 7" />
              </svg>
            </a>
          </div>
        </article>

        <!-- Position 3: Technical Support Engineer -->
        <article class="position-card" data-animate>
          <div class="position-header">
            <div class="position-meta">
              <span class="position-badge">Fulltime</span>
              <span class="position-location">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z" /><circle cx="12" cy="10" r="3" />
                </svg>
                Maastricht
              </span>
            </div>
            <h3 class="position-title">Technisch Support Engineer</h3>
          </div>
          <div class="position-body">
            <p class="position-desc">
              Sluit u aan bij ons supportteam als Technisch Support Engineer en word de vertrouwde adviseur waarop
              onze klanten dagelijks rekenen. U diagnosticeert en lost technische problemen op, begeleidt gebruikers
              door complexe workflows en werkt samen met ons ontwikkelteam om bugs te escaleren en te tracken.
              Uw doel is ervoor te zorgen dat onze klanten maximale waarde halen uit TMS 4SAP.
            </p>
            <div class="position-requirements">
              <h4>Wat wij zoeken:</h4>
              <ul>
                <li>2+ jaar ervaring in technische support, helpdesk of een vergelijkbare klantgerichte technische rol</li>
                <li>Praktische kennis van SQL (queries, troubleshooting, data-analyse)</li>
                <li>Ervaring met ERP-systemen, productiesoftware of bedrijfsapplicaties</li>
                <li>Sterke analytische en probleemoplossende vaardigheden</li>
                <li>Geduldige, empathische en heldere communicatiestijl</li>
                <li>Bekendheid met ticketingsystemen (bijv. Jira, Zendesk of ServiceNow)</li>
                <li>Vloeiend in het Engels; Nederlands of Duits is een plus</li>
              </ul>
            </div>
          </div>
          <div class="position-footer">
            <a href="mailto:careers@themanufacturingsuite.com?subject=Sollicitatie%3A%20Technisch%20Support%20Engineer" class="btn btn-primary">
              Nu Solliciteren
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M5 12h14" /><path d="m12 5 7 7-7 7" />
              </svg>
            </a>
          </div>
        </article>
      </div>
    </div>
  </section>

  <!-- Open Application -->
  <section class="section open-application-section">
    <div class="container">
      <div class="open-application-card" data-animate>
        <div class="open-application-content">
          <div class="open-application-icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" /><circle cx="9" cy="7" r="4" /><line x1="19" x2="19" y1="8" y2="14" /><line x1="22" x2="16" y1="11" y2="11" />
            </svg>
          </div>
          <h2>Geen passende functie gevonden?</h2>
          <p>
            Wij zijn altijd ge\u00efnteresseerd in contact met getalenteerde mensen, ook als er momenteel geen
            openstaande functie is die bij uw profiel past. Als u gepassioneerd bent over productietechnologie
            en denkt dat u een bijdrage kunt leveren aan ons team, moedigen wij u aan een open sollicitatie te
            sturen. Vertel ons over uzelf, wat u enthousiast maakt over TMS en hoe u denkt impact te kunnen maken.
          </p>
          <a href="mailto:careers@themanufacturingsuite.com?subject=Open%20Sollicitatie" class="btn btn-primary btn-lg">
            Verstuur Open Sollicitatie
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M5 12h14" /><path d="m12 5 7 7-7 7" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Culture -->
  <section class="section culture-section">
    <div class="container">
      <div class="culture-content" data-animate>
        <span class="section-tag">Onze cultuur</span>
        <h2>Gebouwd op vakmanschap, <span class="text-amber">gedreven door nieuwsgierigheid</span></h2>
        <p>
          Bij TMS zijn we een hecht team van engineers, consultants en domeinexperts die veel waarde hechten aan
          de kwaliteit van wat we bouwen. Ons hoofdkantoor in Maastricht, gelegen in het hart van de Euregio,
          geeft ons directe toegang tot een bloeiend productie-ecosysteem in Nederland, Belgi\u00eb en Duitsland.
        </p>
        <p>
          Wij waarderen directheid, eigenaarschap en continu verbeteren -- zowel in onze producten als in onszelf.
          Of u nu een complex planningsalgoritme debugt, een klant door hun eerste go-live begeleidt of
          brainstormt over de volgende generatie van ons platform, u vindt een omgeving die initiatief beloont
          en gezamenlijk succes viert.
        </p>
        <p>
          Wij houden vergaderingen lean, documentatie grondig en code reviews eerlijk. Vrijdagmiddagen zijn voor
          kennisdeling en experimenteren. En ja, we nemen onze koffiepauzes serieus.
        </p>
      </div>
    </div>
  </section>

  <!-- CTA Banner -->
  <CTABanner
    title="Ge\u00efnteresseerd in TMS als"
    titleAccent="product?"
    description="Ontdek hoe TMS 4SAP uw productieprocessen kan transformeren. Boek een persoonlijke demo met ons productteam."
    primaryCTA={{ label: 'Boek een Demo', href: '/nl/demo' }}
    secondaryCTA={{ label: 'Bekijk Modules', href: '/nl/modules' }}
  />
</BaseLayout>

<style>
  /* ============================================
     WHY TMS SECTION -- Benefit Cards
     ============================================ */
  .why-section {
    padding-top: clamp(2rem, 4vw, 3rem);
  }

  .benefits-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
  }

  .benefit-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: clamp(1.5rem, 3vw, 2rem);
    transition: all 0.3s var(--ease);
  }

  .benefit-card:hover {
    border-color: var(--border-hover);
    background: var(--bg-card-hover);
    transform: translateY(-2px);
  }

  .benefit-icon {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--amber-dim);
    border-radius: var(--radius-sm);
    color: var(--amber);
    margin-bottom: 16px;
  }

  .benefit-title {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    margin-bottom: 8px;
  }

  .benefit-desc {
    font-size: 0.9375rem;
    color: var(--text-muted);
    line-height: 1.7;
  }

  @media (max-width: 640px) {
    .benefits-grid {
      grid-template-columns: 1fr;
    }
  }

  /* ============================================
     OPEN POSITIONS -- Job Listings
     ============================================ */
  .positions-section {
    background: var(--bg-card);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }

  .positions-list {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .position-card {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: clamp(1.5rem, 3vw, 2rem);
    transition: border-color 0.3s var(--ease);
  }

  .position-card:hover {
    border-color: var(--border-hover);
  }

  .position-header {
    margin-bottom: 16px;
  }

  .position-meta {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 12px;
  }

  .position-badge {
    display: inline-flex;
    align-items: center;
    padding: 4px 12px;
    background: var(--amber-dim);
    border: 1px solid rgba(245, 158, 11, 0.2);
    border-radius: 100px;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--amber);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .position-location {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: 0.8125rem;
    color: var(--text-dim);
  }

  .position-title {
    font-family: var(--font-heading);
    font-size: clamp(1.25rem, 2vw, 1.5rem);
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.2;
  }

  .position-body {
    padding-bottom: 20px;
    border-bottom: 1px solid var(--border);
  }

  .position-desc {
    font-size: 0.9375rem;
    color: var(--text-muted);
    line-height: 1.7;
    margin-bottom: 16px;
  }

  .position-requirements h4 {
    font-family: var(--font-heading);
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 10px;
    letter-spacing: -0.01em;
  }

  .position-requirements ul {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .position-requirements li {
    position: relative;
    padding-left: 20px;
    font-size: 0.875rem;
    color: var(--text-muted);
    line-height: 1.6;
  }

  .position-requirements li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 8px;
    width: 6px;
    height: 6px;
    background: var(--amber);
    border-radius: 50%;
  }

  .position-footer {
    padding-top: 20px;
    display: flex;
    align-items: center;
  }

  /* ============================================
     OPEN APPLICATION
     ============================================ */
  .open-application-section {
    padding-top: 0;
  }

  .open-application-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-xl);
    padding: clamp(2rem, 4vw, 3rem);
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .open-application-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 10%;
    right: 10%;
    height: 1px;
    background: linear-gradient(90deg, transparent 0%, var(--amber) 50%, transparent 100%);
    opacity: 0.3;
  }

  .open-application-content {
    position: relative;
    z-index: 1;
    max-width: 600px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
  }

  .open-application-icon {
    width: 56px;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--amber-dim);
    border-radius: 50%;
    color: var(--amber);
  }

  .open-application-content h2 {
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  .open-application-content p {
    font-size: 1rem;
    color: var(--text-muted);
    line-height: 1.7;
  }

  .open-application-content .btn {
    margin-top: 8px;
  }

  /* ============================================
     CULTURE SECTION
     ============================================ */
  .culture-content {
    max-width: 720px;
    margin: 0 auto;
    text-align: center;
  }

  .culture-content h2 {
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-top: 12px;
    margin-bottom: 24px;
  }

  .culture-content p {
    font-size: 1.0625rem;
    color: var(--text-muted);
    line-height: 1.8;
    margin-bottom: 16px;
  }

  .culture-content p:last-of-type {
    margin-bottom: 0;
  }
</style>
