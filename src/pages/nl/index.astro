---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeader from '../../components/ui/SectionHeader.astro';
import CTABanner from '../../components/ui/CTABanner.astro';
import StatBar from '../../components/ui/StatBar.astro';
import FeatureCard from '../../components/cards/FeatureCard.astro';
import TestimonialCard from '../../components/cards/TestimonialCard.astro';
import IndustryCard from '../../components/cards/IndustryCard.astro';
import { modules } from '../../data/modules';
import { industries } from '../../data/industries';
import { heroStats } from '../../data/stats';
import { testimonials } from '../../data/testimonials';
import { clients } from '../../data/clients';
import { withBase } from '../../i18n/utils';

const previewModules = modules.slice(0, 5);

/* Feature icons as SVG strings */
const featureIcons = {
  integrated: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>',
  flexible: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.375 2.625a2.121 2.121 0 1 1 3 3L12 15l-4 1 1-4Z"/></svg>',
  sap: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>',
  scalable: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="20" x2="12" y2="10"/><line x1="18" y1="20" x2="18" y2="4"/><line x1="6" y1="20" x2="6" y2="16"/></svg>',
};

---

<BaseLayout
  title="The Manufacturing Suite | 4SAP"
  description="De nieuwe standaard voor productie met SAP Business One. 9 geintegreerde modules voor productieplanning, kwaliteitsbeheer en business intelligence."
  lang="nl"
>
  <!-- ===== HERO ===== -->
  <section class="hero" id="hero">
    <div class="hero-bg" aria-hidden="true"></div>
    <div class="container hero-content">
      <div class="hero-badge" data-animate>
        <span class="hero-badge-dot"></span>
        Gebouwd voor SAP Business One
      </div>
      <h1 class="hero-title" data-animate>
        De nieuwe standaard voor<br />
        <span class="text-amber">productie.</span>
      </h1>
      <p class="hero-subtitle" data-animate>
        Een complete, naadloos geintegreerde productieoplossing
        met 9 gespecialiseerde modules — van productieplanning tot
        business intelligence.
      </p>
      <div class="hero-actions" data-animate>
        <a href={withBase('/nl/modules')} class="btn btn-primary btn-lg">
          Bekijk modules
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14" />
            <path d="m12 5 7 7-7 7" />
          </svg>
        </a>
        <a href={withBase('/nl/contact')} class="btn btn-ghost btn-lg">Neem contact op</a>
      </div>
    </div>
    <StatBar stats={heroStats} />
  </section>

  <!-- ===== LOGO CAROUSEL ===== -->
  <section class="logo-carousel-section" aria-label="Vertrouwd door toonaangevende fabrikanten">
    <div class="container">
      <p class="logo-carousel-label" data-animate>Vertrouwd door toonaangevende fabrikanten</p>
      <div class="logo-carousel" data-animate>
        <div class="logo-carousel-track">
          {clients.map((client) => (
            <div class="logo-carousel-item">
              <span class="logo-carousel-name">{client.name}</span>
            </div>
          ))}
          {/* Duplicaat voor naadloos scrollen */}
          {clients.map((client) => (
            <div class="logo-carousel-item" aria-hidden="true">
              <span class="logo-carousel-name">{client.name}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ===== WHY TMS? ===== -->
  <section class="section" id="why-tms">
    <div class="container">
      <SectionHeader
        tag="Waarom TMS?"
        title="Eén platform,"
        titleAccent="zonder compromissen."
        description="TheManufacturingSuite brengt alles samen wat een moderne fabrikant nodig heeft binnen SAP Business One — geen middleware, geen workarounds."
      />
      <div class="features-grid">
        <FeatureCard
          icon={featureIcons.integrated}
          title="Volledig geïntegreerd"
          description="Alle 9 modules delen één datamodel, waardoor silo's en handmatige gegevensoverdracht tussen afdelingen worden geëlimineerd."
        />
        <FeatureCard
          icon={featureIcons.flexible}
          title="Modulair & flexibel"
          description="Implementeer alleen de modules die u vandaag nodig heeft en schaal mee naarmate uw activiteiten groeien. Elke module werkt zelfstandig of in samenwerking."
        />
        <FeatureCard
          icon={featureIcons.sap}
          title="SAP-native"
          description="Rechtstreeks gebouwd op SAP Business One met gecertificeerde integratie. Geen middleware van derden, geen synchronisatieproblemen."
        />
        <FeatureCard
          icon={featureIcons.scalable}
          title="Enterprise-schaalbaar"
          description="Van enkele locatie tot multi-plant implementaties, TMS schaalt mee met uw bedrijf zonder architecturele herzieningen."
        />
      </div>
    </div>
  </section>

  <!-- ===== MODULES PREVIEW ===== -->
  <section class="section" id="modules-preview">
    <div class="container">
      <SectionHeader
        tag="Kernplatform"
        title="Systeem"
        titleAccent="Modules"
        description="Negen gespecialiseerde modules die samenwerken om uw volledige productieoperatie te digitaliseren."
      />
      <div class="modules-grid">
        {previewModules.map((mod) => (
          <div
            class:list={['module-card', { 'module-featured': mod.featured }]}
            data-animate
          >
            <div class="module-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <Fragment set:html={mod.icon} />
              </svg>
            </div>
            <span class="module-abbr">{mod.abbr}</span>
            <h3>{mod.title}</h3>
            <p>{mod.tagline}</p>
            <a href={withBase(`/nl/modules/${mod.slug}`)} class="module-link" aria-label={`Meer informatie over ${mod.title}`}>
              Meer informatie <span aria-hidden="true">&rarr;</span>
            </a>
          </div>
        ))}
      </div>
      <div class="modules-cta" data-animate>
        <a href={withBase('/nl/modules')} class="btn btn-ghost">
          Bekijk alle 9 modules
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14" />
            <path d="m12 5 7 7-7 7" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ===== INDUSTRY GRID ===== -->
  <section class="section" id="industries">
    <div class="container">
      <SectionHeader
        tag="Industrieoplossingen"
        title="Gebouwd voor uw"
        titleAccent="industrie."
        description="Doelgerichte configuraties voor de sectoren waar precisie, traceerbaarheid en efficiëntie het verschil maken."
      />
      <div class="industry-grid">
        {industries.map((ind) => (
          <IndustryCard industry={ind} />
        ))}
      </div>
    </div>
  </section>

  <!-- ===== TESTIMONIALS ===== -->
  <section class="section" id="testimonials">
    <div class="container">
      <SectionHeader
        tag="Klantverhalen"
        title="Wat fabrikanten"
        titleAccent="zeggen."
        description="Hoor van productieleiders die hun activiteiten hebben gestroomlijnd met TheManufacturingSuite."
      />
      <div class="testimonials-grid">
        {testimonials.map((t) => (
          <TestimonialCard
            quote={t.quote}
            author={t.author}
            role={t.role}
            company={t.company}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ===== CTA BANNER ===== -->
  <CTABanner
    title="Klaar om uw"
    titleAccent="productie te transformeren?"
    description="Plan een persoonlijke demo met onze productie-experts en ontdek hoe TMS integreert met uw SAP Business One omgeving."
    primaryCTA={{ label: "Demo aanvragen", href: withBase("/nl/demo") }}
    secondaryCTA={{ label: "Neem contact op", href: withBase("/nl/contact") }}
  />
</BaseLayout>

<style>
  /* ---- Logo Carousel ---- */
  .logo-carousel-section {
    padding: clamp(2rem, 4vw, 3rem) 0;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }

  .logo-carousel-label {
    text-align: center;
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 24px;
  }

  .logo-carousel {
    overflow: hidden;
    -webkit-mask-image: linear-gradient(90deg, transparent 0%, black 10%, black 90%, transparent 100%);
    mask-image: linear-gradient(90deg, transparent 0%, black 10%, black 90%, transparent 100%);
  }

  .logo-carousel-track {
    display: flex;
    gap: 48px;
    animation: logo-scroll 30s linear infinite;
    width: max-content;
  }

  .logo-carousel-item {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 12px 24px;
  }

  .logo-carousel-name {
    font-family: var(--font-heading);
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--text-dim);
    white-space: nowrap;
    letter-spacing: -0.01em;
    transition: color 0.2s var(--ease);
  }

  .logo-carousel-item:hover .logo-carousel-name {
    color: var(--text-muted);
  }

  @keyframes logo-scroll {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .logo-carousel-track {
      animation: none;
      flex-wrap: wrap;
      justify-content: center;
    }
  }

  /* ---- Features Grid ---- */
  .features-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }

  @media (max-width: 900px) {
    .features-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 540px) {
    .features-grid {
      grid-template-columns: 1fr;
    }
  }

  /* ---- Modules CTA ---- */
  .modules-cta {
    text-align: center;
    margin-top: clamp(2rem, 4vw, 3rem);
  }

  /* ---- Industry Grid ---- */
  .industry-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }

  @media (max-width: 900px) {
    .industry-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 540px) {
    .industry-grid {
      grid-template-columns: 1fr;
    }
  }

  /* ---- Testimonials Grid ---- */
  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
  }

  @media (max-width: 768px) {
    .testimonials-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
