/* ===================================================================
   Static Paths
   =================================================================== */

export function getStaticPaths() {
  return [
    { params: { slug: 'kunststof' } },
    { params: { slug: 'automotive' } },
    { params: { slug: 'metaalbewerking' } },
    { params: { slug: 'elektronica' } },
  ];
}

/* ===================================================================
   Page Data
   =================================================================== */

const { slug } = Astro.params;
const industry = industriesData.find((i) => i.slug === slug);

if (!industry) {
  return Astro.redirect('/nl/industries');
}

const relevantModules = allModules.filter((m) =>
  industry.relevantModuleSlugs.includes(m.slug)
);

// Friendly display name for breadcrumbs
const displayNames: Record<string, string> = {
  kunststof: 'Kunststofproductie',
  automotive: 'Automotive toeleveranciers',
  metaalbewerking: 'Metaalbewerking & Verspaning',
  elektronica: 'Elektronica productie',
};

const displayName = displayNames[slug!] || industry.title;
---

<BaseLayout
  title={`${industry.title} | TMS 4SAP`}
  description={industry.metaDescription}
  lang="nl"
>
  <!-- Hero -->
  <section class="ind-hero">
    <div class="ind-hero-bg" aria-hidden="true"></div>
    <div class="container">
      <div class="breadcrumbs-wrap">
        <Breadcrumbs
          items={[
            { label: 'Industrieën', href: '/nl/industries' },
            { label: displayName, href: `/nl/industries/${slug}` },
          ]}
        />
      </div>
      <div class="ind-hero-content" data-animate>
        <span class="section-tag">Industrieoplossing</span>
        <h1 class="ind-hero-title">{industry.title}</h1>
        <p class="ind-hero-tagline">{industry.tagline}</p>
        <p class="ind-hero-intro">{industry.intro}</p>
        <div class="ind-hero-actions">
          <a href="/nl/demo" class="btn btn-primary btn-lg">Demo aanvragen</a>
          <a href="/nl/contact" class="btn btn-ghost btn-lg">Neem contact op</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Challenges -->
  <section class="section">
    <div class="container">
      <SectionHeader
        tag="Uitdagingen"
        title="De problemen"
        titleAccent="waarmee u te maken heeft"
        description="Dit zijn de specifieke uitdagingen waardoor generieke ERP-systemen tekortschieten in uw industrie. TMS is ontworpen om elk ervan aan te pakken."
      />
      <div class="challenges-grid">
        {industry.challenges.map((challenge, idx) => (
          <div class="challenge-card" data-animate>
            <span class="challenge-number">{String(idx + 1).padStart(2, '0')}</span>
            <h3 class="challenge-title">{challenge.title}</h3>
            <p class="challenge-desc">{challenge.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Relevant Modules -->
  <section class="section section-modules-bg">
    <div class="container">
      <SectionHeader
        tag="Hoe TMS het oplost"
        title="De juiste modules voor"
        titleAccent="uw productie"
        description="TMS biedt een modulair platform. Hier zijn de modules die het meest relevant zijn voor uw industrie, elk doelgericht gebouwd voor productieactiviteiten."
      />
      <div class="modules-grid">
        {relevantModules.map((mod) => (
          <a href={`/nl/modules/${mod.slug}`} class="rel-module-card" data-animate>
            <div class="rel-module-icon">
              <span class="rel-module-abbr">{mod.abbr}</span>
            </div>
            <div class="rel-module-body">
              <h3 class="rel-module-name">{mod.name}</h3>
              <p class="rel-module-desc">{mod.description}</p>
              <span class="rel-module-link">
                Meer informatie <span aria-hidden="true">&rarr;</span>
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Stats Bar -->
  <StatBar stats={industry.stats} />

  <!-- Key Capabilities -->
