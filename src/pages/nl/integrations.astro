---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HeroInner from '../../components/ui/HeroInner.astro';
import SectionHeader from '../../components/ui/SectionHeader.astro';
import CTABanner from '../../components/ui/CTABanner.astro';
import { withBase } from '../../i18n/utils';

const breadcrumbs = [
  { label: 'Home', href: withBase('/nl') },
  { label: 'Integraties', href: withBase('/nl/integrations') },
];

type BadgeType = 'Native' | 'Certified' | 'Compatible';

interface Integration {
  name: string;
  description: string;
  badge: BadgeType;
  icon: string;
}

interface IntegrationCategory {
  category: string;
  description: string;
  integrations: Integration[];
}

const categories: IntegrationCategory[] = [
  {
    category: 'ERP-platform',
    description: 'De basis van TMS \u2014 een diepe, native verbinding met SAP Business One.',
    integrations: [
      {
        name: 'SAP Business One',
        description: 'Native integratie met realtime bidirectionele datasynchronisatie. TMS is een gecertificeerde SAP add-on die draait binnen de SAP B1-database, wat zorgt voor nul datavertraging en volledige transactionele consistentie.',
        badge: 'Native',
        icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>',
      },
    ],
  },
  {
    category: 'CAD / PLM',
    description: 'Integreer uw engineeringtools rechtstreeks met productieplanning en productdatabeheer.',
    integrations: [
      {
        name: 'Autodesk Inventor',
        description: 'Bidirectionele BOM-synchronisatie en tekeningbeheer. Engineeringwijzigingen in Inventor worden automatisch doorgevoerd in TMS-productiestuklijsten, zodat uw werkvloer altijd in lijn is met de laatste revisie.',
        badge: 'Certified',
        icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 20a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V8l-7 5V8l-7 5V4a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2Z"/></svg>',
      },
      {
        name: 'Autodesk Vault',
        description: 'Documentbeheerintegratie die gecentraliseerde toegang biedt tot CAD-bestanden, tekeningen en engineeringdocumentatie vanuit TMS en SAP Business One.',
        badge: 'Certified',
        icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 20a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2h-7.9a2 2 0 0 1-1.69-.9L9.6 3.9A2 2 0 0 0 7.93 3H4a2 2 0 0 0-2 2v13a2 2 0 0 0 2 2Z"/></svg>',
      },
      {
        name: 'SOLIDWORKS',
        description: 'Model-naar-BOM extractie voor automatische aanmaak van productiestuklijsten vanuit SOLIDWORKS-samenstellingen, inclusief materiaalspecificaties en bewerkingsinformatie.',
        badge: 'Compatible',
        icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>',
      },
      {
        name: 'EPLAN',
        description: 'Integratie van elektrotechnische engineeringdata voor kabellijsten, klemmenstoeltoewijzingen en componentstuklijsten. Ideaal voor schakelkastbouwers en machinefabrikanten met elektrotechnische vereisten.',
        badge: 'Compatible',
        icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2 3 14h9l-1 8 10-12h-9l1-8z"/></svg>',
      },
    ],
  },
  {
    category: 'Communicatie',
    description: 'Automatiseer data-uitwisseling met uw klanten en ketenpartners.',
    integrations: [
      {
        name: 'EDI',
        description: 'Geautomatiseerde elektronische order- en factuuruitwisseling met OEM-klanten en eerstelijnsleveranciers. Ondersteuning voor EDIFACT, ANSI X12 en VDA-standaarden die veel worden gebruikt in de automotive- en productieketen.',
        badge: 'Certified',
        icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 11a9 9 0 0 1 9 9"/><path d="M4 4a16 16 0 0 1 16 16"/><circle cx="5" cy="19" r="1"/></svg>',
      },
    ],
  },
  {
    category: 'Dataregistratie',
    description: 'Verbind uw shopfloorhardware voor realtime productiedataverzameling.',
    integrations: [
      {
        name: 'Barcodescanners',
        description: 'Volledige ondersteuning voor USB- en Bluetooth-barcodescanners van alle grote merken, waaronder Zebra, Honeywell en Datalogic. Scan werkorders, materialen en eindproducten op de werkvloer.',
        badge: 'Compatible',
        icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 7V5a2 2 0 0 1 2-2h2"/><path d="M17 3h2a2 2 0 0 1 2 2v2"/><path d="M21 17v2a2 2 0 0 1-2 2h-2"/><path d="M7 21H5a2 2 0 0 1-2-2v-2"/><line x1="7" y1="12" x2="17" y2="12"/></svg>',
      },
      {
        name: 'RFID-systemen',
        description: 'Ondersteuning voor passieve en actieve RFID-tags voor geautomatiseerde materiaaltracking, voorraadbeheer en monitoring van onderhanden werk. Maakt handsfree dataregistratie mogelijk in omgevingen met hoge volumes.',
        badge: 'Compatible',
        icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12h6"/><path d="M22 12h-6"/><path d="M12 2v6"/><path d="M12 22v-6"/><circle cx="12" cy="12" r="4"/></svg>',
      },
      {
        name: 'Machineconnectiviteit',
        description: 'Directe PLC-integratie en OPC-UA protocolondersteuning voor geautomatiseerde dataverzameling van CNC-machines, spuitgietapparatuur en productielijnen. Registreer cyclustijden, stukaantallen en machinestatus in realtime.',
        badge: 'Native',
        icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="6" width="20" height="12" rx="2"/><path d="M6 12h.01"/><path d="M10 12h.01"/><path d="M14 12h.01"/><path d="M18 12h.01"/></svg>',
      },
    ],
  },
  {
    category: 'Rapportage',
    description: 'Breid uw analyse- en rapportagemogelijkheden uit met industriestandaard tools.',
    integrations: [
      {
        name: 'Crystal Reports',
        description: 'Geavanceerd rapportontwerp en -generatie voor productierapporten, kwaliteitscertificaten, leveringsbonnen en managementdashboards. Volledige toegang tot alle TMS- en SAP Business One-data.',
        badge: 'Native',
        icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>',
      },
      {
        name: 'Microsoft Excel',
        description: 'Naadloze data-export en -import met voorgedefinieerde sjablonen voor productieplanning, capaciteitsanalyse en kostencalculaties. Vertrouwde interface voor ad-hoc rapportagebehoefte.',
        badge: 'Native',
        icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="3" y1="15" x2="21" y2="15"/><line x1="9" y1="3" x2="9" y2="21"/><line x1="15" y1="3" x2="15" y2="21"/></svg>',
      },
    ],
  },
];
---

<BaseLayout
  lang="nl"
  title="Integraties | TMS 4SAP"
  description="Ontdek TMS-integratiepartners en -mogelijkheden: SAP Business One, Autodesk Inventor, SOLIDWORKS, EPLAN, EDI, barcode/RFID, OPC-UA machineconnectiviteit, Crystal Reports en meer."
>
  <!-- Hero -->
  <HeroInner
    breadcrumbs={breadcrumbs}
    tag="Ecosysteem"
    title="Integraties"
    description="TMS verbindt naadloos met uw bestaande tools en systemen. Van CAD-platformen en shopfloorhardware tot rapportage-engines en communicatie met uw keten."
  />

  <!-- Integration Categories -->
  {categories.map((cat) => (
    <section class="section integration-category">
      <div class="container">
        <div class="category-header" data-animate>
          <h2 class="category-title">{cat.category}</h2>
          <p class="category-desc">{cat.description}</p>
        </div>

        <div class:list={['integration-grid', { 'integration-grid--single': cat.integrations.length === 1 }]}>
          {cat.integrations.map((item) => (
            <div class="integration-card" data-animate>
              <div class="integration-card-top">
                <div class="integration-icon">
                  <Fragment set:html={item.icon} />
                </div>
                <span class:list={['integration-badge', `badge-${item.badge.toLowerCase()}`]}>
                  {item.badge}
                </span>
              </div>
              <h3>{item.name}</h3>
              <p>{item.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  ))}

  <!-- Custom Integration CTA -->
  <section class="section custom-integration-section">
    <div class="container">
      <div class="custom-integration-card" data-animate>
        <div class="custom-integration-content">
          <div class="custom-integration-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="3"/>
              <path d="M12 1v4"/>
              <path d="M12 19v4"/>
              <path d="M4.22 4.22l2.83 2.83"/>
              <path d="M16.95 16.95l2.83 2.83"/>
              <path d="M1 12h4"/>
              <path d="M19 12h4"/>
              <path d="M4.22 19.78l2.83-2.83"/>
              <path d="M16.95 7.05l2.83-2.83"/>
            </svg>
          </div>
          <div class="custom-integration-text">
            <h3>Heeft u een maatwerkintegratie nodig?</h3>
            <p>
              Als uw productieomgeving tools of systemen gebruikt die hier niet worden vermeld, kan ons
              integratieteam maatwerkconnectors bouwen. Wij hebben ervaring met een breed scala aan industri\u00eble
              protocollen, API's en dataformaten die worden gebruikt in discrete en procesmatige productie.
            </p>
          </div>
          <a href={withBase('/nl/contact')} class="btn btn-primary btn-lg">Neem Contact Op</a>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Banner -->
  <CTABanner
    title="Bekijk TMS-integraties"
    titleAccent="in actie"
    description="Boek een demo om te zien hoe TMS verbindt met uw bestaande SAP-, CAD- en shopfloorsystemen in een ge\u00efntegreerd productieplatform."
    primaryCTA={{ label: 'Boek een Demo', href: withBase('/nl/demo') }}
    secondaryCTA={{ label: 'Download Brochure', href: withBase('/nl/downloads') }}
  />
</BaseLayout>

<style>
  /* ---- Category Sections ---- */
  .integration-category {
    padding-top: clamp(2rem, 4vw, 3rem);
    padding-bottom: clamp(2rem, 4vw, 3rem);
  }

  .integration-category + .integration-category {
    border-top: 1px solid var(--border);
  }

  /* ---- Category Header ---- */
  .category-header {
    margin-bottom: clamp(1.5rem, 3vw, 2.5rem);
  }

  .category-title {
    font-family: var(--font-heading);
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin-bottom: 8px;
  }

  .category-desc {
    font-size: 1rem;
    color: var(--text-muted);
    line-height: 1.7;
    max-width: 600px;
  }

  /* ---- Integration Cards Grid ---- */
  .integration-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
  }

  .integration-grid--single {
    grid-template-columns: 1fr;
    max-width: 640px;
  }

  .integration-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 28px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    transition: all 0.3s var(--ease);
  }

  .integration-card:hover {
    background: var(--bg-card-hover);
    border-color: var(--border-hover);
    transform: translateY(-2px);
  }

  /* ---- Card Top: Icon + Badge ---- */
  .integration-card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }

  .integration-icon {
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--amber-dim);
    border-radius: var(--radius-sm);
    color: var(--amber);
    flex-shrink: 0;
  }

  /* ---- Badges ---- */
  .integration-badge {
    display: inline-flex;
    align-items: center;
    padding: 4px 10px;
    border-radius: 100px;
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    flex-shrink: 0;
  }

  .badge-native {
    background: rgba(245, 158, 11, 0.12);
    border: 1px solid rgba(245, 158, 11, 0.25);
    color: var(--amber);
  }

  .badge-certified {
    background: rgba(34, 197, 94, 0.08);
    border: 1px solid rgba(34, 197, 94, 0.2);
    color: #4ade80;
  }

  .badge-compatible {
    background: rgba(161, 161, 170, 0.08);
    border: 1px solid rgba(161, 161, 170, 0.2);
    color: var(--text-muted);
  }

  /* ---- Card Content ---- */
  .integration-card h3 {
    font-family: var(--font-heading);
    font-size: 1.125rem;
    font-weight: 600;
    line-height: 1.3;
    letter-spacing: -0.01em;
  }

  .integration-card p {
    font-size: 0.9375rem;
    color: var(--text-muted);
    line-height: 1.7;
  }

  /* ---- Custom Integration Section ---- */
  .custom-integration-section {
    padding-top: 0;
  }

  .custom-integration-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-xl);
    padding: clamp(2rem, 4vw, 3rem);
    position: relative;
    overflow: hidden;
  }

  /* Top edge glow */
  .custom-integration-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 15%;
    right: 15%;
    height: 1px;
    background: linear-gradient(90deg, transparent 0%, var(--amber) 50%, transparent 100%);
    opacity: 0.3;
  }

  .custom-integration-content {
    display: flex;
    align-items: center;
    gap: 24px;
  }

  .custom-integration-icon {
    width: 56px;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--amber-dim);
    border-radius: var(--radius);
    color: var(--amber);
    flex-shrink: 0;
  }

  .custom-integration-text {
    flex: 1;
  }

  .custom-integration-text h3 {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 600;
    line-height: 1.3;
    letter-spacing: -0.01em;
    margin-bottom: 8px;
  }

  .custom-integration-text p {
    font-size: 0.9375rem;
    color: var(--text-muted);
    line-height: 1.7;
    max-width: 640px;
  }

  .custom-integration-content > .btn {
    flex-shrink: 0;
    white-space: nowrap;
  }

  /* ---- Responsive ---- */
  @media (min-width: 1024px) {
    .integration-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 640px) {
    .integration-grid {
      grid-template-columns: 1fr;
    }

    .custom-integration-content {
      flex-direction: column;
      align-items: flex-start;
      text-align: left;
    }

    .custom-integration-content > .btn {
      align-self: flex-start;
    }
  }
</style>
