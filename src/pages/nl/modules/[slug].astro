/* -------------------------------------------------------
   Sidebar navigation data (same for every module page)
   ------------------------------------------------------- */
const sidebarModules = allModules.map((m) => ({
  slug: m.slug,
  abbr: m.abbr,
  name: m.name,
}));

/* -------------------------------------------------------
   getStaticPaths — one page per module
   ------------------------------------------------------- */
export function getStaticPaths() {
  return [
    { params: { slug: 'pps' } },
    { params: { slug: 'aps' } },
    { params: { slug: 'mes' } },
    { params: { slug: 'pdc' } },
    { params: { slug: 'qm' } },
    { params: { slug: 'pdm' } },
    { params: { slug: 'bi' } },
    { params: { slug: 'vc' } },
    { params: { slug: 'dms' } },
  ];
}

const { slug } = Astro.params;
const mod = allModules.find((m) => m.slug === slug)!;
const relatedModules = dataModules.filter((m) => mod.relatedSlugs.includes(m.slug));

const breadcrumbs = [
  { label: 'Home', href: '/nl' },
  { label: 'Modules', href: '/nl/modules' },
  { label: mod.name, href: `/nl/modules/${mod.slug}` },
];
---

<BaseLayout
  lang="nl"
  title={`${mod.abbr} — ${mod.name}`}
  description={`${mod.tagline}. ${mod.description}`}
>
  <HeroInner
    breadcrumbs={breadcrumbs}
    tag={mod.abbr}
    title={mod.name}
  />

  <!-- Main layout: sidebar + content -->
  <section class="module-detail section">
    <div class="container module-layout">

      <!-- Sidebar Navigation -->
      <aside class="module-sidebar" aria-label="Modulenavigatie">
        <nav>
          <span class="sidebar-title">Alle modules</span>
          <ul class="sidebar-list" role="list">
            {sidebarModules.map((sm) => (
              <li>
                <a
                  href={`/nl/modules/${sm.slug}`}
                  class:list={['sidebar-link', { 'sidebar-link--active': sm.slug === slug }]}
                  aria-current={sm.slug === slug ? 'page' : undefined}
                >
                  <span class="sidebar-abbr">{sm.abbr}</span>
                  <span class="sidebar-name">{sm.name}</span>
                </a>
              </li>
            ))}
          </ul>
        </nav>
      </aside>

      <!-- Main Content Area -->
      <div class="module-content">

        <!-- Module header with icon -->
        <div class="module-header" data-animate>
          <div class="module-header-icon" set:html={icons[mod.icon]} />
          <div class="module-header-info">
            <span class="module-header-abbr">{mod.abbr}</span>
            <h2 class="module-header-title">{mod.name}</h2>
          </div>
        </div>

        <!-- Tagline paragraph -->
        <p class="module-tagline" data-animate>{mod.tagline}. {mod.description}</p>

        <!-- Key Features -->
        <div class="module-section" data-animate>
          <SectionHeader
            tag="Mogelijkheden"
            title="Belangrijkste"
            titleAccent="functies"
            align="left"
          />
          <div class="features-grid">
            {mod.features.map((feat) => (
              <FeatureCard
                icon={featureIcons[feat.icon] || featureIcons['settings']}
                title={feat.title}
                description={feat.description}
              />
            ))}
          </div>
        </div>

        <!-- Benefits -->
        <div class="module-section" data-animate>
          <SectionHeader
            tag="Voordelen"
            title="Zakelijke"
            titleAccent="voordelen"
            align="left"
          />
          <ul class="benefits-list" role="list">
            {mod.benefits.map((benefit) => (
              <li class="benefit-item">
                <span class="benefit-check" aria-hidden="true">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="20 6 9 17 4 12"/>
                  </svg>
                </span>
                <span>{benefit}</span>
              </li>
            ))}
          </ul>
        </div>

        <!-- Related Modules -->
        {relatedModules.length > 0 && (
          <div class="module-section" data-animate>
            <SectionHeader
              tag="Werkt samen met"
              title="Gerelateerde"
              titleAccent="modules"
              align="left"
            />
            <div class="related-grid">
              {relatedModules.map((rel) => (
                <ModuleCard module={rel} />
              ))}
            </div>
          </div>
        )}
      </div>
    </div>
  </section>

  <!-- CTA Banner -->
  <CTABanner
    title={`Bekijk ${mod.abbr}`}
    titleAccent="in actie"
    description={`Vraag een persoonlijke demo aan en ontdek hoe ${mod.name} uw productieprocessen kan transformeren binnen SAP Business One.`}
    primaryCTA={{ label: 'Demo aanvragen', href: '/nl/demo' }}
    secondaryCTA={{ label: 'Brochure downloaden', href: '/nl/downloads' }}
  />
</BaseLayout>

<style>
  /* ========================================
     MODULE DETAIL LAYOUT
     ======================================== */
  .module-layout {
    display: grid;
    grid-template-columns: 240px 1fr;
    gap: clamp(2rem, 4vw, 3rem);
    align-items: start;
  }

  /* ---- Sidebar ---- */
  .module-sidebar {
    position: sticky;
    top: 100px;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 20px 0;
    overflow: hidden;
  }

  .sidebar-title {
    display: block;
    font-family: var(--font-heading);
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-dim);
    padding: 0 20px 12px;
    border-bottom: 1px solid var(--border);
    margin-bottom: 8px;
  }

  .sidebar-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .sidebar-link {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 8px 20px;
    font-size: 0.8125rem;
    color: var(--text-muted);
    transition: all 0.15s var(--ease);
    border-left: 3px solid transparent;
    text-decoration: none;
  }

  .sidebar-link:hover {
    color: var(--text);
    background: var(--bg-card-hover);
  }

  .sidebar-link--active {
    color: var(--text);
    background: rgba(245, 158, 11, 0.04);
    border-left-color: var(--amber);
  }

  .sidebar-link--active .sidebar-abbr {
    color: var(--amber);
    background: var(--amber-dim);
  }

  .sidebar-abbr {
    font-family: var(--font-heading);
    font-size: 0.625rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-dim);
    background: var(--bg-surface);
    padding: 2px 6px;
    border-radius: 4px;
    min-width: 34px;
    text-align: center;
    flex-shrink: 0;
  }

  .sidebar-name {
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* ---- Main content ---- */
  .module-content {
    min-width: 0; /* prevent grid blowout */
  }

  /* Module header */
  .module-header {
    display: flex;
    align-items: center;
    gap: 20px;
    margin-bottom: 24px;
  }

  .module-header-icon {
    width: 56px;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--amber-dim);
    border-radius: var(--radius);
    color: var(--amber);
    flex-shrink: 0;
  }

  .module-header-icon :global(svg) {
    width: 28px;
    height: 28px;
  }

  .module-header-abbr {
    font-family: var(--font-heading);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--amber);
  }

  .module-header-title {
    font-family: var(--font-heading);
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.02em;
    margin-top: 2px;
  }

  /* Tagline */
  .module-tagline {
    font-size: 1.0625rem;
    color: var(--text-muted);
    line-height: 1.75;
    max-width: 700px;
