---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HeroInner from '../../components/ui/HeroInner.astro';
import CTABanner from '../../components/ui/CTABanner.astro';
import { withBase } from '../../i18n/utils';

const stops = [
  {
    number: 1,
    id: 'planning',
    title: 'Begin met planning',
    module: 'PPS',
    description:
      'Elke succesvolle productieoperatie begint met een solide plan. De TMS-module Productieplanning & Scheduling transformeert hoe u productieorders beheert, resources toewijst en bewerkingen inplant. Vervang handmatige spreadsheets door intelligente planning die rekening houdt met machinecapaciteit, materiaalbeschikbaarheid en leverdeadlines in realtime.',
    features: [
      {
        title: 'Productieorderbeheer',
        desc: 'Maak, vrijgeef en volg productieorders rechtstreeks vanuit SAP Business One verkooporders met volledige stuklijstexplosie en bewerkingsroute.',
      },
      {
        title: 'Eindige capaciteitsplanning',
        desc: 'Visuele Gantt-gebaseerde planning die rekening houdt met machinecapaciteit, ploegkalenders en operatorvaardigheden voor realistische productieplannen.',
      },
      {
        title: 'Wat-als simulaties',
        desc: 'Test alternatieve planningsscenario\u2019s voordat u beslist. Evalueer de impact van spoedorders, machineuitval of wijzigingen in resources.',
      },
    ],
    icon: '<svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/><path d="M8 14h.01"/><path d="M12 14h.01"/><path d="M16 14h.01"/><path d="M8 18h.01"/><path d="M12 18h.01"/></svg>',
  },
  {
    number: 2,
    id: 'materials',
    title: 'Optimaliseer materialen',
    module: 'APS',
    description:
      'Materiaaltekorten en overmatige voorraad zijn twee kanten van dezelfde medaille, en beide kosten u geld. De module Geavanceerde Planning & Scheduling brengt intelligentie in uw materiaalbehoefteplanning en zorgt ervoor dat de juiste materialen op het juiste werkstation op precies het juiste moment aankomen.',
    features: [
      {
        title: 'MRP met intelligentie',
        desc: 'Ga verder dan standaard MRP. Houd rekening met variabiliteit in levertijden, leveranciersbetrouwbaarheid en historische verbruikspatronen voor slimmere inkoop.',
      },
      {
        title: 'Voorraadoptimalisatie',
        desc: 'Houd optimale voorraadniveaus aan met dynamische veiligheidsvoorraadberekeningen, bestelpunten en ABC/XYZ-classificatie.',
      },
      {
        title: 'Vraagvoorspelling',
        desc: 'Gebruik historische data en trendanalyse om toekomstige vraag te voorspellen. Stem productiecapaciteit en inkoop af op marktbehoeften.',
      },
    ],
    icon: '<svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>',
  },
  {
    number: 3,
    id: 'shopfloor',
    title: 'Verbind de werkvloer',
    module: 'MES + PDC',
    description:
      'Het gat tussen planning en realiteit bevindt zich op de werkvloer. De modules Manufacturing Execution System en Productiedataregistratie overbruggen deze kloof met realtime zichtbaarheid in elke machine, operator en order. Weet op elk moment precies wat er in de productie gebeurt, niet pas uren later via een papieren rapport.',
    features: [
      {
        title: 'Realtime monitoring',
        desc: 'Live dashboards met machinestatus, ordervoortgang, OEE en doorvoer. Identificeer knelpunten voordat ze problemen worden.',
      },
      {
        title: 'Operatorterminals',
        desc: 'Touchscreen-terminals op elk werkstation voor in-/uitklokken, bewerkingsregistratie, uitvalregistratie en digitale werkinstructies.',
      },
      {
        title: 'Machine-integratie',
        desc: 'Verbind rechtstreeks met PLC\u2019s en CNC-besturingen via OPC-UA. Registreer cyclustijden, aantallen en machinestatus automatisch.',
      },
    ],
    icon: '<svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/><path d="M6 8h.01"/><path d="M10 8h.01"/><path d="M14 8h.01"/></svg>',
  },
  {
    number: 4,
    id: 'quality',
    title: 'Borg de kwaliteit',
    module: 'QM',
    description:
      'Kwaliteit is geen bijzaak; het is verweven in elke stap van de productie. De module Kwaliteitsmanagement handhaaft inspectieplannen, registreert metingen en waarborgt volledige traceerbaarheid van grondstof tot eindproduct. Voldoe aan de strengste branchenormen, van IATF 16949 in de automotive tot FDA-vereisten voor medische hulpmiddelen.',
    features: [
      {
        title: 'Inspectieplannen',
        desc: 'Definieer inspectieplannen per artikel, bewerking of productiefase. Stel steekproefregels, meetspecificaties en acceptatiecriteria in.',
      },
      {
        title: 'Volledige traceerbaarheid',
        desc: 'Traceer elk component, elke batch en elk serienummer door de gehele productieketen. Directe terugroepcapaciteit wanneer nodig.',
      },
      {
        title: 'Compliance & certificaten',
        desc: 'Genereer Certificates of Analysis (CoA), onderhoud audittrails en produceer documentatie vereist door IATF, ISO en branchenormen.',
      },
    ],
    icon: '<svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/></svg>',
  },
  {
    number: 5,
    id: 'product-data',
    title: 'Beheer productdata',
    module: 'PDM + DMS',
    description:
      'Engineering en productie spreken verschillende talen \u2014 tot nu. De modules Productdatabeheer en Documentbeheer cre\u00ebren \u00e9\u00e9n bron van waarheid voor stuklijsten, tekeningen, specificaties en revisiegeschiedenissen. Elimineer de chaos van bestandsservers, e-mailbijlagen en verouderde prints op de werkvloer.',
    features: [
      {
        title: 'CAD-integratie',
        desc: 'Importeer stuklijsten rechtstreeks vanuit SolidWorks, AutoCAD, Inventor en andere CAD-systemen. Houd engineering- en productiestuklijsten gesynchroniseerd.',
      },
      {
        title: 'Documentbeheer',
        desc: 'Gecentraliseerd archief met versiebeheer, goedkeuringsworkflows en toegangsrechten. Altijd de laatste revisie, nooit een verouderde kopie.',
      },
      {
        title: 'Engineeringwijzigingen',
        desc: 'Beheer ECO\u2019s met gestructureerde workflows. Volg de impact van wijzigingen, vereist aftekening van relevante stakeholders en rol naadloos uit naar productie.',
      },
    ],
    icon: '<svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>',
  },
  {
    number: 6,
    id: 'analytics',
    title: 'Analyseer & besluit',
    module: 'BI + VC',
    description:
      'Data zonder inzicht is slechts ruis. De modules Business Intelligence en Variantconfiguratie transformeren ruwe productiedata in bruikbare dashboards en maken complexe productconfiguratie eenvoudig. Neem beslissingen op basis van feiten, spot trends vroegtijdig en geef sales de mogelijkheid om producten de eerste keer correct te configureren.',
    features: [
      {
        title: 'Productiedashboards',
        desc: 'Standaard en aanpasbare dashboards voor OEE, uitvalpercentages, leverprestaties en doorvoer. Realtime data, niet het rapport van gisteren.',
      },
      {
        title: 'KPI-tracking',
        desc: 'Definieer, meet en visualiseer uw belangrijkste productie-KPI\u2019s. Stel doelen, monitor trends en activeer alerts bij afwijkingen.',
      },
      {
        title: 'Productconfiguratie',
        desc: 'Begeleid sales en klanten door complexe productvarianten met regelgebaseerde configuratie. Genereer automatisch correcte stuklijsten en bewerkingsroutes.',
      },
    ],
    icon: '<svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/><line x1="2" y1="20" x2="22" y2="20"/></svg>',
  },
];
---

<BaseLayout
  lang="nl"
  title="Product Tour | TMS 4SAP"
  description="Verken alle TMS-modules op uw eigen tempo. Doorloop Productieplanning, MES, Kwaliteit, PDM, BI en meer in deze interactieve product tour."
>
  <HeroInner
    breadcrumbs={[
      { label: 'Home', href: withBase('/nl') },
      { label: 'Product Tour', href: withBase('/nl/product-tour') },
    ]}
    tag="Interactieve Tour"
    title="Neem de"
    titleAccent="Product Tour"
    description="Verken TMS-modules op uw eigen tempo. Ontdek hoe elk onderdeel samenwerkt om uw productieprocessen te transformeren."
  />

  <!-- Tour layout: sidebar + content -->
  <div class="tour-layout">
    <!-- Sticky sidebar navigation -->
    <nav class="tour-sidebar" aria-label="Tournavigatie">
      <ol class="tour-nav-list">
        {stops.map((stop) => (
          <li>
            <a
              href={`#${stop.id}`}
              class="tour-nav-item"
              data-tour-nav={stop.id}
              aria-label={`Stap ${stop.number}: ${stop.title}`}
            >
              <span class="tour-nav-dot" aria-hidden="true">{stop.number}</span>
              <span class="tour-nav-label">{stop.title}</span>
            </a>
          </li>
        ))}
      </ol>
    </nav>

    <!-- Tour content -->
    <div class="tour-content">
      {stops.map((stop) => (
        <section class="tour-stop" id={stop.id} data-tour-stop={stop.id}>
          <div class="tour-stop-header" data-animate>
            <span class="tour-step-number" aria-hidden="true">{String(stop.number).padStart(2, '0')}</span>
            <div class="tour-stop-meta">
              <span class="tour-module-badge">{stop.module}</span>
              <h2 class="tour-stop-title">{stop.title}</h2>
            </div>
          </div>

          <p class="tour-stop-description" data-animate>{stop.description}</p>

          <div class="tour-stop-body">
            <div class="tour-features-grid">
              {stop.features.map((feature) => (
                <div class="tour-feature-card" data-animate>
                  <div class="tour-feature-icon" aria-hidden="true">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <polyline points="20 6 9 17 4 12" />
                    </svg>
                  </div>
                  <h3 class="tour-feature-title">{feature.title}</h3>
                  <p class="tour-feature-desc">{feature.desc}</p>
                </div>
              ))}
            </div>

            <div class="tour-visual" data-animate aria-hidden="true">
              <div class="tour-visual-inner">
                <Fragment set:html={stop.icon} />
                <span class="tour-visual-label">{stop.module}</span>
              </div>
            </div>
          </div>
        </section>
      ))}

      <!-- Final CTA -->
      <section class="tour-final-cta" data-animate>
        <div class="tour-final-cta-inner">
          <h2 class="tour-final-title">Klaar om het live te zien?</h2>
          <p class="tour-final-desc">
            U hebt de volledige TMS-suite verkend. Laat nu onze experts u door een gepersonaliseerde demo leiden met uw eigen productiescenario's.
          </p>
          <a href={withBase('/nl/demo')} class="btn btn-primary btn-lg">
            Boek een Gepersonaliseerde Demo
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="5" y1="12" x2="19" y2="12" />
              <polyline points="12 5 19 12 12 19" />
            </svg>
          </a>
        </div>
      </section>
    </div>
  </div>

  <CTABanner
    title="Transformeer uw"
    titleAccent="productie"
    description="Boek een gratis demo van 1 uur met onze experts en ontdek hoe TMS 4SAP uw productievloer kan moderniseren."
    primaryCTA={{ label: 'Boek een Demo', href: withBase('/nl/demo') }}
    secondaryCTA={{ label: 'Download Brochure', href: withBase('/nl/downloads') }}
  />
</BaseLayout>

<script>
  function initTourNav() {
    const navItems = document.querySelectorAll<HTMLAnchorElement>('[data-tour-nav]');
    const sections = document.querySelectorAll<HTMLElement>('[data-tour-stop]');

    if (!navItems.length || !sections.length) return;

    // Track active section with IntersectionObserver
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const id = (entry.target as HTMLElement).dataset.tourStop;
            navItems.forEach((item) => {
              const isActive = item.dataset.tourNav === id;
              item.classList.toggle('tour-nav-item--active', isActive);
              item.setAttribute('aria-current', isActive ? 'step' : 'false');
            });
          }
        });
      },
      {
        threshold: 0,
        rootMargin: '-20% 0px -60% 0px',
      }
    );

    sections.forEach((section) => observer.observe(section));

    // Smooth scroll on click
    navItems.forEach((item) => {
      item.addEventListener('click', (e) => {
        e.preventDefault();
        const targetId = item.dataset.tourNav;
        const target = document.getElementById(targetId || '');
        if (target) {
          target.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      });
    });

    // Set initial active state
    if (navItems[0]) {
      navItems[0].classList.add('tour-nav-item--active');
      navItems[0].setAttribute('aria-current', 'step');
    }
  }

  initTourNav();
  document.addEventListener('astro:page-load', initTourNav);
</script>

<style>
  /* ============================================
     TOUR LAYOUT
     ============================================ */
  .tour-layout {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 48px;
    width: min(1200px, 92%);
    margin: 0 auto;
    padding-bottom: clamp(3rem, 6vw, 5rem);
    position: relative;
  }

  /* ============================================
     SIDEBAR NAVIGATION
     ============================================ */
  .tour-sidebar {
    position: sticky;
    top: 100px;
    height: fit-content;
    padding: 24px 0;
  }

  .tour-nav-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
    position: relative;
  }

  /* Vertical track line */
  .tour-nav-list::before {
    content: '';
    position: absolute;
    left: 17px;
    top: 20px;
    bottom: 20px;
    width: 1px;
    background: var(--border);
  }

  .tour-nav-item {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 10px 12px;
    border-radius: var(--radius-sm);
    transition: all 0.2s var(--ease);
    position: relative;
    text-decoration: none;
  }

  .tour-nav-item:hover {
    background: rgba(255, 255, 255, 0.03);
  }

  .tour-nav-dot {
    width: 34px;
    height: 34px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    font-family: var(--font-heading);
    font-size: 0.8125rem;
    font-weight: 600;
    background: var(--bg-card);
    border: 1px solid var(--border);
    color: var(--text-dim);
    transition: all 0.3s var(--ease);
    flex-shrink: 0;
    position: relative;
    z-index: 1;
  }

  .tour-nav-label {
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--text-dim);
    transition: color 0.2s var(--ease);
    line-height: 1.3;
  }

  /* Active state */
  .tour-nav-item--active .tour-nav-dot {
    background: var(--amber);
    border-color: var(--amber);
    color: #09090B;
    box-shadow: 0 0 16px rgba(245, 158, 11, 0.25);
  }

  .tour-nav-item--active .tour-nav-label {
    color: var(--text);
  }

  .tour-nav-item:hover .tour-nav-label {
    color: var(--text-muted);
  }

  .tour-nav-item--active:hover .tour-nav-label {
    color: var(--text);
  }

  /* ============================================
     TOUR CONTENT
     ============================================ */
  .tour-content {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  /* ============================================
     TOUR STOP
     ============================================ */
  .tour-stop {
    padding: clamp(3rem, 6vw, 5rem) 0;
    border-bottom: 1px solid var(--border);
    scroll-margin-top: 90px;
  }

  .tour-stop:last-of-type {
    border-bottom: none;
  }

  .tour-stop-header {
    display: flex;
    align-items: flex-start;
    gap: 20px;
    margin-bottom: 20px;
  }

  .tour-step-number {
    font-family: var(--font-heading);
    font-size: clamp(3rem, 6vw, 4.5rem);
    font-weight: 700;
    line-height: 1;
    letter-spacing: -0.03em;
    color: var(--amber);
    flex-shrink: 0;
    opacity: 0.35;
  }

  .tour-stop-meta {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding-top: 8px;
  }

  .tour-module-badge {
    display: inline-flex;
    align-items: center;
    padding: 4px 12px;
    background: var(--amber-dim);
    border: 1px solid rgba(245, 158, 11, 0.2);
    border-radius: 100px;
    font-family: var(--font-heading);
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--amber);
    width: fit-content;
  }

  .tour-stop-title {
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.02em;
  }

  .tour-stop-description {
    font-size: 1.0625rem;
    color: var(--text-muted);
    line-height: 1.7;
    max-width: 680px;
    margin-bottom: 32px;
  }

  /* ============================================
     TOUR STOP BODY: Features + Visual
     ============================================ */
  .tour-stop-body {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: 32px;
    align-items: start;
  }

  .tour-features-grid {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .tour-feature-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    transition: all 0.3s var(--ease);
  }

  .tour-feature-card:hover {
    background: var(--bg-card-hover);
    border-color: var(--border-hover);
    transform: translateX(4px);
  }

  .tour-feature-icon {
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--amber-dim);
    border-radius: var(--radius-sm);
    color: var(--amber);
    flex-shrink: 0;
    margin-bottom: 4px;
  }

  .tour-feature-title {
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 600;
    line-height: 1.3;
  }

  .tour-feature-desc {
    font-size: 0.9375rem;
    color: var(--text-muted);
    line-height: 1.6;
  }

  /* Visual placeholder */
  .tour-visual {
    position: sticky;
    top: 120px;
  }

  .tour-visual-inner {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    aspect-ratio: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 16px;
    color: var(--amber);
    opacity: 0.6;
    transition: all 0.4s var(--ease);
    position: relative;
    overflow: hidden;
  }

  .tour-visual-inner::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 50% 40%, rgba(245, 158, 11, 0.06) 0%, transparent 60%);
    pointer-events: none;
  }

  .tour-stop:hover .tour-visual-inner {
    opacity: 1;
    border-color: rgba(245, 158, 11, 0.2);
  }

  .tour-visual-label {
    font-family: var(--font-heading);
    font-size: 0.875rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-dim);
  }

  /* ============================================
     FINAL CTA
     ============================================ */
  .tour-final-cta {
    padding: clamp(3rem, 6vw, 5rem) 0;
  }

  .tour-final-cta-inner {
    background: linear-gradient(135deg, var(--bg-card) 0%, rgba(245, 158, 11, 0.04) 100%);
    border: 1px solid rgba(245, 158, 11, 0.15);
    border-radius: var(--radius-xl);
    padding: clamp(2.5rem, 5vw, 4rem);
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    position: relative;
    overflow: hidden;
  }

  .tour-final-cta-inner::before {
    content: '';
    position: absolute;
    top: 0;
    left: 15%;
    right: 15%;
    height: 1px;
    background: linear-gradient(90deg, transparent 0%, var(--amber) 50%, transparent 100%);
    opacity: 0.4;
  }

  .tour-final-title {
    font-family: var(--font-heading);
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.02em;
  }

  .tour-final-desc {
    font-size: 1.0625rem;
    color: var(--text-muted);
    line-height: 1.7;
    max-width: 520px;
  }

  .tour-final-cta .btn {
    margin-top: 8px;
  }

  /* ============================================
     RESPONSIVE
     ============================================ */
  @media (max-width: 960px) {
    .tour-layout {
      grid-template-columns: 1fr;
