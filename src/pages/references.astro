---
import BaseLayout from '@layouts/BaseLayout.astro';
import HeroInner from '@components/ui/HeroInner.astro';
import StatBar from '@components/ui/StatBar.astro';
import SectionHeader from '@components/ui/SectionHeader.astro';
import CTABanner from '@components/ui/CTABanner.astro';

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'References', href: '/references' },
];

const stats = [
  { value: '500+', label: 'Implementations' },
  { value: '98%', label: 'Satisfaction' },
  { value: '12', label: 'Countries' },
  { value: '15+', label: 'Years' },
];

interface Reference {
  company: string;
  industry: string;
  country: string;
  quote: string;
  modules: string[];
}

const industries = ['All', 'Plastics', 'Automotive', 'Metal Working', 'Electronics'];

const references: Reference[] = [
  {
    company: 'Precision Plastics BV',
    industry: 'Plastics',
    country: 'Netherlands',
    quote: 'TMS transformed our injection molding scheduling. We went from spreadsheets and whiteboards to a fully digital planning workflow — cycle time optimization and mold changeover planning are now automated.',
    modules: ['PPS', 'APS', 'MES'],
  },
  {
    company: 'AutoParts GmbH',
    industry: 'Automotive',
    country: 'Germany',
    quote: 'IATF 16949 compliance became manageable. TMS quality management tracks every inspection, every deviation, and every corrective action — auditors love the traceability.',
    modules: ['QM', 'PDC', 'BI'],
  },
  {
    company: 'MetalCraft Industries',
    industry: 'Metal Working',
    country: 'Belgium',
    quote: 'Real-time job costing changed everything. We now see actual versus estimated hours per work order as the job runs, not weeks after it shipped.',
    modules: ['MES', 'PDC', 'PPS', 'BI'],
  },
  {
    company: 'CircuitBoard Systems',
    industry: 'Electronics',
    country: 'Netherlands',
    quote: 'Component traceability at reel level was non-negotiable for our aerospace clients. TMS gave us lot tracking and genealogy from incoming goods through final test.',
    modules: ['QM', 'PDM', 'MES'],
  },
  {
    company: 'FormTech Kunststoffen',
    industry: 'Plastics',
    country: 'Netherlands',
    quote: '40% reduction in planning time. Our planners used to spend half their day juggling orders and machine assignments — APS now generates optimized schedules in minutes.',
    modules: ['APS', 'PPS', 'PDC'],
  },
  {
    company: 'TurboGear Automotive',
    industry: 'Automotive',
    country: 'Germany',
    quote: 'EDI integration eliminated manual entry. Delivery schedules from OEMs flow straight into our planning. Shipping notices go back automatically. Zero paper, zero rekeying.',
    modules: ['PPS', 'APS', 'DMS'],
  },
  {
    company: 'StaalWerk Engineering',
    industry: 'Metal Working',
    country: 'Netherlands',
    quote: 'OEE visibility drove 15% improvement in our first year. Once operators could see real-time performance on the shop floor displays, they started self-correcting.',
    modules: ['MES', 'BI', 'PDC'],
  },
  {
    company: 'MicroElec BV',
    industry: 'Electronics',
    country: 'Belgium',
    quote: 'BOM import from Altium saves hours weekly. Engineers design in their native tool, and TMS pulls in the full component list with alternates and specifications automatically.',
    modules: ['PDM', 'VC', 'PPS'],
  },
  {
    company: 'DuraPlast GmbH',
    industry: 'Plastics',
    country: 'Germany',
    quote: 'Quality management with full batch tracing gives us complete confidence. When a customer asks about a specific lot, we can pull up every raw material, every parameter, and every test result in seconds.',
    modules: ['QM', 'MES', 'DMS', 'BI'],
  },
];

const countryFlags: Record<string, string> = {
  'Netherlands': 'NL',
  'Germany': 'DE',
  'Belgium': 'BE',
};
---

<BaseLayout
  title="References | TMS 4SAP"
  description="See how 500+ manufacturers across Europe trust TMS to digitalize production planning, quality management, and shop floor execution."
>
  <HeroInner
    breadcrumbs={breadcrumbs}
    tag="Customer References"
    title="Customer Success"
    titleAccent="Stories"
    description="See how manufacturers across Europe trust TMS to transform their production operations with integrated planning, execution, and quality management."
  />

  <StatBar stats={stats} />

  <!-- Filter Bar -->
  <section class="filter-section">
    <div class="container">
      <div class="filter-bar" role="toolbar" aria-label="Filter references by industry">
        {industries.map((ind) => (
          <button
            class:list={['filter-btn', { active: ind === 'All' }]}
            data-filter={ind}
            aria-pressed={ind === 'All' ? 'true' : 'false'}
          >
            {ind}
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- References Grid -->
  <section class="section references-section">
    <div class="container">
      <div class="references-grid" role="list" aria-label="Customer references">
        {references.map((ref) => (
          <article
            class="reference-card"
            data-industry={ref.industry}
            data-animate
            role="listitem"
          >
            <div class="reference-header">
              <div class="reference-meta">
                <span class="reference-industry-tag">{ref.industry}</span>
                <span class="reference-country">
                  <span class="country-code">{countryFlags[ref.country]}</span>
                  {ref.country}
                </span>
              </div>
            </div>
            <h3 class="reference-company">{ref.company}</h3>
            <blockquote class="reference-quote">
              <p>&ldquo;{ref.quote}&rdquo;</p>
            </blockquote>
            <div class="reference-modules">
              {ref.modules.map((mod) => (
                <a href={`/modules/${mod.toLowerCase()}`} class="module-tag">{mod}</a>
              ))}
            </div>
          </article>
        ))}
      </div>

      <!-- Empty state for filtered results -->
      <div class="empty-state" hidden aria-live="polite">
        <p>No references found for the selected industry.</p>
      </div>
    </div>
  </section>

  <CTABanner
    title="Join 500+ manufacturers"
    titleAccent="who chose TMS"
    description="See how TMS can transform your production operations. Book a personalized demo or speak with our team."
    primaryCTA={{ label: 'Book a Demo', href: '/demo' }}
    secondaryCTA={{ label: 'Contact Us', href: '/contact' }}
  />
</BaseLayout>

<style>
  /* --- Filter Section --- */
  .filter-section {
    padding: 32px 0 0;
  }

  .filter-bar {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
    padding: 16px 0;
    border-bottom: 1px solid var(--border);
  }

  .filter-btn {
    display: inline-flex;
    align-items: center;
    padding: 8px 18px;
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text-muted);
    background: transparent;
    border: 1px solid var(--border);
    border-radius: 100px;
    cursor: pointer;
    transition: all 0.2s var(--ease);
    white-space: nowrap;
  }

  .filter-btn:hover {
    color: var(--text);
    border-color: var(--border-hover);
    background: rgba(255, 255, 255, 0.03);
  }

  .filter-btn:focus-visible {
    outline: 2px solid var(--amber);
    outline-offset: 2px;
  }

  .filter-btn.active {
    color: #09090B;
    background: var(--amber);
    border-color: var(--amber);
  }

  .filter-btn.active:hover {
    background: var(--amber-hover);
    border-color: var(--amber-hover);
  }

  /* --- References Grid --- */
  .references-section {
    padding-top: clamp(2rem, 4vw, 3rem);
  }

  .references-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  /* --- Reference Card --- */
  .reference-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 28px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    transition: all 0.3s var(--ease);
  }

  .reference-card:hover {
    background: var(--bg-card-hover);
    border-color: var(--border-hover);
    transform: translateY(-2px);
  }

  .reference-card.hidden {
    display: none;
  }

  .reference-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
  }

  .reference-meta {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
  }

  .reference-industry-tag {
    display: inline-flex;
    align-items: center;
    padding: 3px 10px;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--amber);
    background: var(--amber-dim);
    border: 1px solid rgba(245, 158, 11, 0.15);
    border-radius: 100px;
  }

  .reference-country {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.8125rem;
    color: var(--text-dim);
  }

  .country-code {
    font-family: var(--font-heading);
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    color: var(--text-muted);
    padding: 1px 6px;
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: 4px;
  }

  .reference-company {
    font-family: var(--font-heading);
    font-size: 1.125rem;
    font-weight: 600;
    line-height: 1.3;
    color: var(--text);
  }

  .reference-quote {
    flex-grow: 1;
  }

  .reference-quote p {
    font-size: 0.9375rem;
    color: var(--text-muted);
    line-height: 1.7;
    font-style: italic;
  }

  .reference-modules {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: auto;
    padding-top: 8px;
    border-top: 1px solid var(--border);
  }

  .module-tag {
    display: inline-flex;
    align-items: center;
    padding: 3px 10px;
    font-family: var(--font-heading);
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-dim);
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    text-decoration: none;
    transition: all 0.2s var(--ease);
  }

  .module-tag:hover {
    color: var(--amber);
    border-color: rgba(245, 158, 11, 0.3);
    background: var(--amber-dim);
  }

  /* --- Empty State --- */
  .empty-state {
    text-align: center;
    padding: 4rem 0;
    color: var(--text-dim);
    font-size: 1rem;
  }

  /* --- Stagger Animations --- */
  .references-grid [data-animate]:nth-child(1) { transition-delay: 0ms; }
  .references-grid [data-animate]:nth-child(2) { transition-delay: 80ms; }
  .references-grid [data-animate]:nth-child(3) { transition-delay: 160ms; }
  .references-grid [data-animate]:nth-child(4) { transition-delay: 240ms; }
  .references-grid [data-animate]:nth-child(5) { transition-delay: 320ms; }
  .references-grid [data-animate]:nth-child(6) { transition-delay: 400ms; }
  .references-grid [data-animate]:nth-child(7) { transition-delay: 480ms; }
  .references-grid [data-animate]:nth-child(8) { transition-delay: 560ms; }
  .references-grid [data-animate]:nth-child(9) { transition-delay: 640ms; }

  /* --- Responsive --- */

  /* Tablet (768px) */
  @media (max-width: 768px) {
    .references-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 16px;
    }

    .references-section {
      padding: clamp(3rem, 8vw, 5rem) 0;
      padding-top: clamp(1.5rem, 4vw, 2.5rem);
    }

    .reference-card {
      padding: 24px;
    }
  }

  /* iPhone (375px - 430px) */
  @media (max-width: 480px) {
    .references-grid {
      grid-template-columns: 1fr;
    }

    .filter-bar {
      gap: 6px;
    }

    .filter-btn {
      padding: 8px 14px;
      font-size: 0.8125rem;
      min-height: 44px;
    }

    .reference-card {
      padding: 20px;
    }

    .module-tag {
      min-height: 44px;
      padding: 8px 12px;
    }
  }
</style>

<script>
  function initFilters() {
    const filterBtns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
    const cards = document.querySelectorAll<HTMLElement>('.reference-card');
    const emptyState = document.querySelector<HTMLElement>('.empty-state');

    if (!filterBtns.length || !cards.length) return;

    filterBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        const filter = btn.dataset.filter;
        if (!filter) return;

        // Update active button
        filterBtns.forEach((b) => {
          b.classList.remove('active');
          b.setAttribute('aria-pressed', 'false');
        });
        btn.classList.add('active');
        btn.setAttribute('aria-pressed', 'true');

        // Filter cards
        let visibleCount = 0;
        cards.forEach((card) => {
          const industry = card.dataset.industry;
          const shouldShow = filter === 'All' || industry === filter;
          card.classList.toggle('hidden', !shouldShow);
          if (shouldShow) visibleCount++;
        });

        // Toggle empty state
        if (emptyState) {
          emptyState.hidden = visibleCount > 0;
        }
      });
    });
  }

  initFilters();
  document.addEventListener('astro:page-load', initFilters);
</script>
